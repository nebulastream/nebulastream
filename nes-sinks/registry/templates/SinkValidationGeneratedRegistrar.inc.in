#pragma once

#ifndef INCLUDED_FROM_SINK_VALIDATION_REGISTRY
#    error "This file should not be included directly! Include instead include SinkRegistry.hpp"
#endif

#include <string>
#include <vector>
#include <Util/Registry.hpp>
#include <Configurations/Descriptor.hpp>

namespace NES
{
SinkValidationRegistryReturnType validateTokioSinkFromRegistry(std::string name, SinkValidationRegistryArguments args);
std::vector<std::string> getRegisteredTokioSinkNames();

@REGISTER_FUNCTION_DECLARATIONS@
}

namespace NES
{
template <>
inline void Registrar<SinkValidationRegistry, std::string, SinkValidationRegistryReturnType, SinkValidationRegistryArguments>::registerAll(
    [[maybe_unused]] Registry<Registrar>& registry)
{
    for (const auto& n : getRegisteredTokioSinkNames())
    {
        registry.addEntry(n, [n](SinkValidationRegistryArguments args) {
            return validateTokioSinkFromRegistry(n, std::move(args));
        });
    }

    using namespace NES;
    @REGISTER_ALL_FUNCTION_CALLS@
}
}
