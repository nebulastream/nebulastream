#pragma once

#ifndef INCLUDED_FROM_SINK_REGISTRY
#    error "This file should not be included directly! Include instead include SinkRegistry.hpp"
#endif

#include <memory>
#include <string>
#include <Sinks/Sink.hpp>
#include <Sinks/SinkDescriptor.hpp>
#include <Util/Registry.hpp>

namespace NES
{

/// declaration of register functions for 'Sinks'
@REGISTER_FUNCTION_DECLARATIONS@
}

namespace NES
{
/// registerAll is only defined in the CMake-generated registrar translation unit of this registry's component
/// (see generate_plugin_registrar in cmake/PluginRegistrationUtil.cmake). All other translation units see just this
/// declaration, so including the registry header does not require the plugin registration symbols at link time;
/// only calling instance() does.
template <>
void Registrar<SinkRegistry, std::string, SinkRegistryReturnType, SinkRegistryArguments>::registerAll(Registry<Registrar>& registry);

#ifdef NES_DEFINE_SINK_REGISTER_ALL
template <>
void Registrar<SinkRegistry, std::string, SinkRegistryReturnType, SinkRegistryArguments>::registerAll([[maybe_unused]] Registry<Registrar>& registry)
{
    /// using namespace NES;
    @REGISTER_ALL_FUNCTION_CALLS@
}
#endif
}
