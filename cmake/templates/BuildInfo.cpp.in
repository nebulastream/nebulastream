/// This file is generated by cmake/BuildInfo.cmake at configure time. Do not edit.

#include <Version.hpp>

#include <ostream>
#include <string>
#include <string_view>
#include <BuildInfo.hpp>

namespace NES
{

std::string formatVersion(const std::string_view binaryName)
{
    std::string out;
    out += binaryName;
    out += ' ';
    out += BuildInfo::version;
    out += '\n';
    out += "  commit:         ";
    out += BuildInfo::gitCommit;
    out += '\n';
    out += "  build:          ";
    out += BuildInfo::buildType;
    out += '\n';
    out += "  sanitizer:      ";
    out += BuildInfo::sanitizer;
    out += '\n';
    out += "  compiler:       ";
    out += BuildInfo::compiler;
    out += '\n';
    out += "  stdlib:         ";
    out += BuildInfo::stdlib;
    out += '\n';
    out += "  vcpkg baseline: ";
    out += BuildInfo::vcpkgBaseline;
    out += '\n';
    /// Plugin listing is deferred to a follow-up (see issue #1640); listing the registered
    /// plugins requires restructuring the CMake plugin discovery / registry.
    out += "  plugins:        (not yet listed; see follow-up)";
    out += '\n';
    return out;
}

void printVersion(const std::string_view binaryName, std::ostream& out)
{
    out << formatVersion(binaryName);
}

}
