-- A SECOND valid TCP sink schema, deliberately different from basic.nesql's
-- single `value VARSIZED`: three columns of mixed types (INT32, VARSIZED,
-- FLOAT64). It proves an arbitrary CREATE SINK schema flows end-to-end through
-- the formatted (JSONL) sink — the framework generates typed rows from this
-- schema, renders them to JSONL records the sink writes, and parses the
-- capture per this schema for the rows-equal compare. No loader change needed.
-- (OUTPUT_FORMAT is descriptor-only here — see basic.nesql.)
CREATE SINK conntest_multi (id INT32 NOT NULL, label VARSIZED NOT NULL, ratio FLOAT64 NOT NULL) TYPE TCP SET (
    'localhost' AS `SINK`.socket_host,
    '9000'      AS `SINK`.socket_port,
    'JSON'      AS `SINK`.OUTPUT_FORMAT);
