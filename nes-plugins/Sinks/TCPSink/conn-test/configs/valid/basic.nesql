-- A valid TCP sink configuration.
--
-- `socket_host`, `socket_port`, and `output_format` are the load-bearing keys.
-- Config-key grammar matches ConfigParametersTCPSink in
-- nes-plugins/Sinks/TCPSink/TCPSink.hpp. The endpoint is a concrete literal —
-- binding never connects, which is why config validation needs no live relay.
--
-- OUTPUT_FORMAT is descriptor-only in conn-test: the harness runs no formatter
-- (in the real engine, formatting is lowered out of the descriptor and
-- query-compiled). TCPSink is a byte pipe; the runner puts JSONL on the wire
-- directly. The token must stay non-Native so the harness takes the
-- record-stream path (not the .nes path), and 'JSON' is the honest name for
-- what's on the wire.
CREATE SINK conntest_sink (value VARSIZED NOT NULL) TYPE TCP SET (
    'localhost' AS `SINK`.socket_host,
    '9000'      AS `SINK`.socket_port,
    'JSON'      AS `SINK`.OUTPUT_FORMAT);
