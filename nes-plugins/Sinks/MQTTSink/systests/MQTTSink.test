# name: MQTTSink/MQTTSink.test
# description: Feeds File+CSV source rows into the MQTT sink. SELECT ... INTO MQTT(...) is routed through the MQTT SinkCapture registrar (MQTTTestSubscriber.cpp), which rewrites the broker endpoint to the dispatcher-allocated port and drains the published messages back into the result file for the standard comparison. The mosquitto broker comes up via the requires directive.
# requires: mqtt

CREATE LOGICAL SOURCE input(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR input TYPE File;
ATTACH INLINE
1,1,12
1,2,23
1,3,34
1,4,45
1,5,56

SELECT id, value, timestamp FROM input INTO MQTT('mqtt_broker' AS `SINK`.server_uri, 'nebulastream/sink/MQTTSink' AS `SINK`.topic);
----
1 1 12
1 2 23
1 3 34
1 4 45
1 5 56
