-- A valid MQTT sink configuration.
--
-- `server_uri`, `topic`, and `output_format` are the load-bearing keys;
-- `qos` defaults to 1. Config-key grammar matches ConfigParametersMQTTSink in
-- nes-plugins/Sinks/MQTTSink/MQTTSink.hpp. The endpoint is a concrete literal —
-- binding never connects, which is why config validation needs no live broker.
CREATE SINK conntest_sink (value VARSIZED NOT NULL) TYPE MQTT SET (
    'tcp://localhost:1883' AS `SINK`.server_uri,
    'demo/topic'           AS `SINK`.topic,
    '1'                    AS `SINK`.qos,
    'CSV'                  AS `SINK`.OUTPUT_FORMAT);
