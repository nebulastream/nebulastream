# name: ODBCSink/ODBCSink.test
# description: Writes query output into a PostgreSQL table over ODBC. `SELECT ... INTO ODBC(...)` is routed through the ODBC SinkCapture registrar (ODBCSinkCapture.cpp), which rewrites the descriptor's db_host / db_port to the dispatcher-allocated endpoint and polls the target table back into the result file for the standard comparison. The `# requires: odbc` directive brings up the PostgreSQL container declared in systest-profile/compose.snippet.yaml; init-db.sql creates the empty `sink_output` table on first boot. The sink receives the default CSV-formatted output and INSERTs each row as quoted literals, which PostgreSQL coerces to the column types.
# requires: odbc

CREATE LOGICAL SOURCE input(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR input TYPE File;
ATTACH INLINE
1,1,12
1,2,23
1,3,34
1,4,45
1,5,56

SELECT id, value, timestamp FROM input INTO ODBC(
    'odbc_database' AS `SINK`.db_host,
    '5432' AS `SINK`.db_port,
    'nebulastream' AS `SINK`.database,
    'nes' AS `SINK`.username,
    'nes' AS `SINK`.password,
    'PostgreSQL Unicode' AS `SINK`.driver,
    'sink_output' AS `SINK`.`table`);
----
1 1 12
1 2 23
1 3 34
1 4 45
1 5 56
