# name: ODBCSink/ODBCSinkRuntime_NoSuchTable.test
# description: Runtime error -- the ODBC sink targets a table that does not exist. The descriptor binds cleanly (`no_such_table` is a syntactically valid table name) and the sink connects in start(); the failure surfaces at runtime on the first row, when ODBCSink::execute() issues `INSERT INTO no_such_table ...` and SQLExecDirect fails. execute() raises RunningRoutineFailure (4001). The SinkCapture registrar's poll thread also fails to read the missing table, but that error is swallowed by the poll loop's guard -- the surfaced error is the sink's. The PostgreSQL container comes up via `# requires: odbc`; init-db.sql creates `sink_output` but never `no_such_table`.
# requires: odbc
# groups: [Negative, Runtime]


CREATE LOGICAL SOURCE input(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR input TYPE File;
ATTACH INLINE
1,1,12
1,2,23
1,3,34
1,4,45
1,5,56

SELECT id, value, timestamp FROM input INTO ODBC(
    'odbc_database' AS `SINK`.db_host,
    '5432' AS `SINK`.db_port,
    'nebulastream' AS `SINK`.database,
    'nes' AS `SINK`.username,
    'nes' AS `SINK`.password,
    'PostgreSQL Unicode' AS `SINK`.driver,
    'no_such_table' AS `SINK`.`table`);
----
ERROR 4001
