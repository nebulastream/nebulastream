-- Invalid: the windowed poller binds exactly two `?` parameters (the
-- (watermark, now] bounds), but this query has only one. ODBCSource::validateAndFormat
-- rejects it at config time with INVALID_CONFIG_PARAMETER (1000), before any connect.
CREATE LOGICAL SOURCE conntest_rows (
    k INT64 NOT NULL,
    a INT32 NOT NULL,
    b INT64 NOT NULL,
    c FLOAT64 NOT NULL
);

CREATE PHYSICAL SOURCE FOR conntest_rows TYPE ODBC SET (
    'NATIVE'             AS INPUT_FORMATTER.`TYPE`,
    'localhost'          AS `SOURCE`.db_host,
    '5432'               AS `SOURCE`.db_port,
    'nebulastream'       AS `SOURCE`.database,
    'nes'                AS `SOURCE`.username,
    'nes'                AS `SOURCE`.password,
    'PostgreSQL Unicode' AS `SOURCE`.driver,
    'SELECT k, a, b, c FROM conntest_rows WHERE created_at > ? ORDER BY k DESC' AS `SOURCE`.query
);
