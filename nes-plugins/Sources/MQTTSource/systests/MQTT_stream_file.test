# name: MQTTSource/MQTT_stream_file.test
# description: Reads the 100K ysb1k fixture (1114 rows) through an MQTT broker — the FileData registrar streams the JSONL to a publisher that waits for the source to subscribe + signal "ready" on a control topic before sending, then writes "eos" on the same control topic when finished. The source EOS-es immediately on "eos"; no timeout, no retained messages, no broker queue tuning.
# requires: mqtt
CREATE LOGICAL SOURCE ysb1k(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL);

CREATE PHYSICAL SOURCE FOR ysb1k TYPE MQTT SET("CSV" AS INPUT_FORMATTER.`TYPE`, "mqtt_broker" AS `SOURCE`.serveruri, "test/ysb1k" AS `SOURCE`.topic, "100" AS `SOURCE`.flushintervalms);
ATTACH FILE small/stream.csv

SELECT * FROM ysb1k INTO File();
