# name: MQTTSource/MQTT.test
# description: Reads ATTACH-declared rows from an MQTT broker. The MQTT InlineData registrar spawns a publisher that subscribes to <topic>/_nes_control and waits for the source to publish "ready" there once it has subscribed to the data topic. The publisher then streams the rows non-retained on the data topic and writes a zero-byte payload as the EOS sentinel. The source treats that sentinel as end-of-stream.
# requires: mqtt
CREATE LOGICAL SOURCE mqtt_source(id INT32, value INT32, timestamp UINT64);

CREATE PHYSICAL SOURCE FOR mqtt_source TYPE MQTT SET("JSON" AS INPUT_FORMATTER.`TYPE`, "mqtt_broker" AS `SOURCE`.serveruri, "test/data" AS `SOURCE`.topic, "100" AS `SOURCE`.flushintervalms);
ATTACH INLINE
{"ID": 1, "VALUE": 2, "TIMESTAMP": 3}
{"ID": 1, "VALUE": 2, "TIMESTAMP": 3}
{"ID": 1, "VALUE": 2, "TIMESTAMP": 3}
{"ID": 1, "VALUE": 2, "TIMESTAMP": 3}
{"ID": 1, "VALUE": 2, "TIMESTAMP": 3}

SELECT id, value, timestamp FROM mqtt_source INTO File();
----
1 2 3
1 2 3
1 2 3
1 2 3
1 2 3
