-- A valid MQTT source configuration.
--
-- The config keys (`server_uri`, `topic`, `qos`) match ConfigParametersMQTTSource
-- in nes-plugins/Sources/MQTTSource/MQTTSource.hpp. `SOURCE` and `TYPE` are
-- reserved words, so the binder requires backticks. The broker endpoint lives in
-- `server_uri`. INPUT_FORMATTER.`TYPE` is mandatory (a physical source must name
-- a formatter).
-- The endpoint is a concrete literal — binding never connects.
--
-- INPUT_FORMATTER.`TYPE` is descriptor-only in conn-test: the harness runs no
-- formatter (in the real engine, formatting is lowered out of the descriptor and
-- query-compiled). MQTTSource is a byte pipe; the runner publishes JSONL and
-- parses the observed bytes back itself. 'JSON' is the honest name for the wire.
CREATE LOGICAL SOURCE smoke_input (data UINT8);

CREATE PHYSICAL SOURCE FOR smoke_input TYPE MQTT SET (
    'tcp://localhost:1883' AS `SOURCE`.server_uri,
    'demo/topic'           AS `SOURCE`.topic,
    -- Framework-managed: the runner rewrites client_id to a per-test token so each
    -- scenario gets its own MQTT session (the literal here is documentation only).
    'conntest-mqtt'        AS `SOURCE`.client_id,
    '1'                    AS `SOURCE`.qos,
    -- Idle end-of-stream budget: keep the source polling for ~2s (200ms × 10)
    -- before it declares EoS, so a just-published message has time to arrive
    -- over paho's network thread rather than the source giving up first.
    '200'                  AS `SOURCE`.flush_interval_ms,
    '10'                   AS `SOURCE`.max_flush_retries,
    'JSON'                 AS INPUT_FORMATTER.`TYPE`
);
