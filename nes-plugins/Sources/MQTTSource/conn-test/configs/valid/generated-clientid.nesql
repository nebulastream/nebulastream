-- basic.nesql WITHOUT `client_id`: the key is optional, and omitting it binds
-- clean via the GENERATE_CLIENT_ID_TOKEN default — the path every other source
-- config shadows by setting the key explicitly. (The token→UUID swap itself
-- happens at source construction, which a BIND-only scenario never reaches.)
--
-- Only the BIND-only `config_valid` glob picks this file up (the live
-- scenarios pin their configs by name). That is deliberate: the source
-- loader's config_overrides unconditionally rewrites `client_id` for per-test
-- session isolation, and apply_overrides raises on a key the config does not
-- carry — so this config must never reach a scenario that applies overrides.
CREATE LOGICAL SOURCE smoke_input (data UINT8);

CREATE PHYSICAL SOURCE FOR smoke_input TYPE MQTT SET (
    'tcp://localhost:1883' AS `SOURCE`.server_uri,
    'demo/topic'           AS `SOURCE`.topic,
    '1'                    AS `SOURCE`.qos,
    '200'                  AS `SOURCE`.flush_interval_ms,
    '10'                   AS `SOURCE`.max_flush_retries,
    'JSON'                 AS INPUT_FORMATTER.`TYPE`
);
