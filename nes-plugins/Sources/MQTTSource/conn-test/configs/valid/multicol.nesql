-- A valid multi-column MQTT source config — same byte-pipe path as basic.nesql,
-- but a mixed-type, multi-column schema (INT32 / VARSIZED / FLOAT64). It proves
-- the JSONL wire form and the typed read-back compare are schema-driven, not
-- hardwired to the single-UINT8 case, and gives the MQTT *source* byte path its
-- first VARSIZED + multi-column coverage (previously only the sink exercised it).
-- Only server_uri, topic, and client_id are rewritten by the loader; the keys
-- below are authored literally and identical to basic.nesql.
CREATE LOGICAL SOURCE multi_input (id INT32 NOT NULL, label VARSIZED NOT NULL, ratio FLOAT64 NOT NULL);

CREATE PHYSICAL SOURCE FOR multi_input TYPE MQTT SET (
    'tcp://localhost:1883' AS `SOURCE`.server_uri,
    'demo/topic'           AS `SOURCE`.topic,
    -- Framework-managed: rewritten to a per-test token for session isolation.
    'conntest-mqtt'        AS `SOURCE`.client_id,
    '1'                    AS `SOURCE`.qos,
    -- Idle end-of-stream budget (200ms × 10 ≈ 2s) — see basic.nesql.
    '200'                  AS `SOURCE`.flush_interval_ms,
    '10'                   AS `SOURCE`.max_flush_retries,
    'JSON'                 AS INPUT_FORMATTER.`TYPE`
);
