{
  "name": "nes-topology-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "vite build --base /topology-editor/ && cd dist && git init -b gh-pages && git add -A && git commit -m Deploy && git push -f https://github.com/ls-1801/topology-editor.git gh-pages && rm -rf .git"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "@monaco-editor/react": "^4.7.0",
    "@xyflow/react": "^12.10.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.474.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zundo": "^2.3.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "antlr-ng": "^1.0.10",
    "autoprefixer": "^10.4.0",
    "happy-dom": "^17.6.1",
    "jsdom": "^26.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
