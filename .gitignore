# Python virtual environment
venv
# uv workspace virtual environments (root /pyproject.toml). `.venv` is the
# default; `.venv-linux` / `.venv-darwin` are the per-OS envs the conn-test
# format gate uses (nes-conn-test/runner/check.sh). The root uv.lock is tracked.
/.venv/
/.venv-*/

# Rust target dir
target/

