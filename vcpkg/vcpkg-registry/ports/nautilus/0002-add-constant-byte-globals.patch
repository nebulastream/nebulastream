+/**
+ * @brief Embeds a host-known immutable byte blob into the generated code and returns a
+ * pointer val to it.
+ *
+ * A plain @c val<const char*>{p} can only cross the host->JIT boundary as an opaque
+ * @c inttoptr constant that LLVM must treat as an unknown, possibly-mutating, possibly-aliasing
+ * address -- so operations on it (a @c memcpy that writes the bytes to an output buffer, a
+ * @c memcmp of a lazily-parsed field against a literal) cannot be constant-folded. This
+ * primitive instead records the bytes in the trace so the compilation backend can materialize
+ * them as a module-level @c "private unnamed_addr constant [N x i8]" global; inlined code that
+ * memcpy's / memcmp's against the returned address then folds to immediates.
+ *
+ * Semantics per execution mode:
+ *  - compiled (MLIR/LLVM backend, the one NebulaStream uses): a deduplicated constant global,
+ *    address returned via @c llvm.mlir.addressof;
+ *  - compiled (other backends): degrades to a plain pointer constant at @p data (no folding),
+ *    identical to @c val<const char*>{data} today;
+ *  - interpreter: returns @p data directly.
+ *
+ * The bytes are copied into trace-owned storage during tracing, so @p data need only stay valid
+ * for the duration of this call. (For the non-folding pointer-constant fallback on the minor
+ * backends, the usual @c val pointer-constant lifetime caveat applies: @p data must outlive the
+ * executable.)
+ *
+ * @param data pointer to @p size bytes to embed.
+ * @param size number of bytes.
+ * @return val<const int8_t*> pointing at the embedded blob.
+ */
+inline val<const int8_t*> embedConstantBytes(const void* data, size_t size) {
+	const auto* hostPtr = static_cast<const int8_t*>(data);
+#ifdef ENABLE_TRACING
+	if (tracing::inTracer()) {
+		auto owned = std::make_shared<std::vector<int8_t>>(hostPtr, hostPtr + size);
+		ConstBytesLiteral literal {data, owned};
+		auto ref = tracing::traceConstantBytes(literal);
+		return val<const int8_t*>(hostPtr, ref);
+	}
+#endif
+	return val<const int8_t*>(hostPtr);
+}
+
 } // namespace nautilus
