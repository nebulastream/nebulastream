+TypedValueRef& ExceptionBasedTraceContext::traceConstantBytes(const ConstBytesLiteral& value) {
+	log::debug("Trace Constant Bytes");
+	auto op = Op::CONSTBYTES;
+	auto type = Type::ptr;
+	if (isFollowing()) {
+		return follow(op);
+	}
+	auto tag = recordSnapshot();
+	auto globalTabIter = state->executionTrace.globalTagMap.find(tag);
+	if (globalTabIter != state->executionTrace.globalTagMap.end()) {
+		auto& ref = globalTabIter->second;
+		auto& originalRef = state->executionTrace.getBlocks()[ref.blockIndex].operations[ref.operationIndex];
+		auto resultRef = state->executionTrace.addOperationWithResult(tag, op, type, {value});
+		state->executionTrace.addAssignmentOperation(tag, originalRef.resultRef, resultRef, resultRef.type);
+		return originalRef.resultRef;
+	} else {
+		return state->executionTrace.addOperationWithResult(tag, op, type, {value});
+	}
+}
