+/**
+ * @brief Payload of an embedded host-known immutable byte blob.
+ *
+ * Unlike a ConstantLiteral (a fixed-width scalar that can be emitted as an immediate),
+ * an arbitrary-length byte string cannot cross the host->JIT boundary as an immediate.
+ * A plain `val<const char*>` degrades to an opaque `inttoptr` constant that LLVM cannot
+ * dereference at compile time (it has no immutability/validity guarantee for host memory),
+ * so constant-folding of `memcpy`/`memcmp` against it is impossible.
+ *
+ * This payload carries the bytes themselves so a backend that supports it (the MLIR/LLVM
+ * backend) can materialize them as a module-level `private unnamed_addr constant [N x i8]`
+ * global and return the global's address. Inlined code that memcpy's/memcmp's against that
+ * global then folds. Backends that do not support it, and the interpreter, fall back to the
+ * raw host pointer -- identical to a plain pointer constant.
+ *
+ * @c bytes owns a private copy of the blob so it outlives tracing and compilation regardless
+ * of the caller's storage lifetime. @c hostPointer is the caller's original address, used by
+ * the pointer-constant fallback and the interpreter.
+ */
+struct ConstBytesLiteral {
+	const void* hostPointer = nullptr;
+	std::shared_ptr<const std::vector<int8_t>> bytes;
+};
