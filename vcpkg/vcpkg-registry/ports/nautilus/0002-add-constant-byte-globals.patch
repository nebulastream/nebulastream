+
+#pragma once
+
+#include "nautilus/compiler/ir/operations/ConstPtrOperation.hpp"
+#include <cstdint>
+#include <memory>
+#include <vector>
+
+namespace nautilus::compiler::ir {
+
+/**
+ * @brief IR node for an embedded host-known immutable byte blob.
+ *
+ * Deliberately derived from ConstPtrOperation so that it reuses OperationType::ConstPtrOp.
+ * Every existing backend dispatch already handles ConstPtrOp and lowers it via getValue()
+ * (the raw host pointer), which yields the correct -- but non-foldable -- pointer-constant
+ * fallback for this node without any per-backend change.
+ *
+ * The MLIR/LLVM backend downcasts (dynamic_cast) to this type inside its ConstPtrOperation
+ * handler: when it succeeds it materializes the bytes as a `private unnamed_addr constant
+ * [N x i8]` module global and returns the global's address, enabling LLVM to constant-fold
+ * inlined memcpy/memcmp against the blob.
+ */
+class ConstBytesOperation : public ConstPtrOperation {
+public:
+	ConstBytesOperation(OperationIdentifier identifier, const void* hostPointer,
+	                    std::shared_ptr<const std::vector<int8_t>> bytes);
+
+	~ConstBytesOperation() override = default;
+
+	/// The immutable byte blob to be embedded.
+	const std::vector<int8_t>& getBytes() const;
+
+private:
+	std::shared_ptr<const std::vector<int8_t>> bytes;
+};
+
+} // namespace nautilus::compiler::ir
