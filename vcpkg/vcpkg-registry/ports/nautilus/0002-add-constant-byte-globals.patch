diff --git a/nautilus/test/execution-tests/ConstBytesExecutionTest.cpp b/nautilus/test/execution-tests/ConstBytesExecutionTest.cpp
new file mode 100644
index 0000000..6b68543
--- /dev/null
+++ b/nautilus/test/execution-tests/ConstBytesExecutionTest.cpp
@@ -0,0 +1,164 @@
+
+#include "catch2/catch_test_macros.hpp"
+#include "nautilus/Engine.hpp"
+#include "nautilus/val_ptr.hpp"
+#include <catch2/catch_all.hpp>
+#include <cstdint>
+#include <filesystem>
+#include <fstream>
+#include <sstream>
+#include <string>
+
+// Tests for nautilus::embedConstantBytes: embedding a host-known immutable byte blob as a
+// module-level constant global so LLVM can constant-fold operations against it.
+//
+// Two things are validated:
+//  1. Correctness in BOTH interpreter mode (engine.Compilation=false, runs the traced C++
+//     directly on the host pointer) and compiled MLIR mode.
+//  2. That the MLIR/LLVM backend actually materializes the bytes as a constant global and
+//     folds reads of it -- inspected by dumping the generated (optimized) LLVM IR.
+
+namespace nautilus::engine {
+
+// The blob referenced by every test function. `static constexpr` so its address is stable
+// across the tracer's repeated executions of the function.
+static constexpr int8_t kBlob[4] = {10, 20, 30, 40};
+static constexpr int8_t kAZ[2] = {'a', 'z'};
+
+// Pure-constant computation over the embedded blob. After optimization every read of the
+// constant global folds, so `execute` should reduce to `ret i32 100`.
+val<int32_t> sumEmbeddedBytes() {
+	// Manually unrolled (distinct source locations) so the tracer records four separate reads
+	// rather than mistaking a host loop over one code location for a constant loop.
+	auto p = embedConstantBytes(kBlob, sizeof(kBlob));
+	val<int8_t> b0 = p[0];
+	val<int8_t> b1 = p[1];
+	val<int8_t> b2 = p[2];
+	val<int8_t> b3 = p[3];
+	val<int32_t> acc = static_cast<val<int32_t>>(b0);
+	acc = acc + static_cast<val<int32_t>>(b1);
+	acc = acc + static_cast<val<int32_t>>(b2);
+	acc = acc + static_cast<val<int32_t>>(b3);
+	return acc;
+}
+
+// Returns the embedded blob's address. Keeps the constant global live in the IR (it is
+// returned), so the dump is guaranteed to contain the materialized global.
+val<const int8_t*> embeddedAddress() {
+	return embedConstantBytes(kBlob, sizeof(kBlob));
+}
+
+// The `WHERE state = 'az'` shape: compare an input against an embedded literal. After
+// optimization the literal bytes become immediate operands of the icmps.
+val<bool> matchesAZ(val<const int8_t*> in) {
+	auto lit = embedConstantBytes(kAZ, sizeof(kAZ));
+	return in[0] == lit[0] && in[1] == lit[1];
+}
+
+static std::string readFile(const std::string& path) {
+	std::ifstream in(path);
+	std::stringstream ss;
+	ss << in.rdbuf();
+	return ss.str();
+}
+
+// Compiles `func` with the MLIR backend, dumps the generated (optimized) LLVM IR and returns it.
+template <typename Func>
+static std::string compileAndDumpIR(const std::string& name, Func func) {
+	std::string dumpPath = (std::filesystem::temp_directory_path() / ("nautilus-constbytes-" + name)).string();
+	std::filesystem::remove_all(dumpPath);
+	std::filesystem::create_directories(dumpPath);
+
+	engine::Options options;
+	options.setOption("engine.backend", "mlir");
+	options.setOption("engine.Compilation", true);
+	options.setOption("dump.after_llvm_generation", true);
+	options.setOption("dump.path", dumpPath);
+	options.setOption("engine.normalizeFunctionNames", true);
+
+	auto engine = engine::NautilusEngine(options);
+	auto function = engine.registerFunction(std::function {func});
+	auto file = function.getExecutable()->getGeneratedFile("after_llvm_generation");
+	REQUIRE(!file.empty());
+	std::string ir = readFile(std::string(file));
+	std::filesystem::remove_all(dumpPath);
+	return ir;
+}
+
+static void correctnessTests(engine::NautilusEngine& engine) {
+	SECTION("sumEmbeddedBytes") {
+		auto f = engine.registerFunction(sumEmbeddedBytes);
+		REQUIRE(f() == 100);
+	}
+	SECTION("embeddedAddress") {
+		auto f = engine.registerFunction(embeddedAddress);
+		const int8_t* p = f();
+		REQUIRE(p != nullptr);
+		REQUIRE(p[0] == 10);
+		REQUIRE(p[1] == 20);
+		REQUIRE(p[2] == 30);
+		REQUIRE(p[3] == 40);
+	}
+	SECTION("matchesAZ") {
+		auto f = engine.registerFunction(matchesAZ);
+		const int8_t az[2] = {'a', 'z'};
+		const int8_t ax[2] = {'a', 'x'};
+		REQUIRE(f(az) == true);
+		REQUIRE(f(ax) == false);
+	}
+}
+
+TEST_CASE("ConstBytes Interpreter Test") {
+	engine::Options options;
+	options.setOption("engine.Compilation", false);
+	auto engine = engine::NautilusEngine(options);
+	correctnessTests(engine);
+}
+
+#ifdef ENABLE_TRACING
+#ifdef ENABLE_MLIR_BACKEND
+TEST_CASE("ConstBytes Compiler Test") {
+	std::vector<std::string> traceModes = {"exceptionBasedTracing", "lazyTracing"};
+	for (auto& traceMode : traceModes) {
+		DYNAMIC_SECTION("mlir_" + traceMode) {
+			engine::Options options;
+			options.setOption("engine.backend", "mlir");
+			options.setOption("engine.traceMode", traceMode);
+			auto engine = engine::NautilusEngine(options);
+			correctnessTests(engine);
+		}
+	}
+}
+
+TEST_CASE("ConstBytes materializes a constant global") {
+	std::string ir = compileAndDumpIR("address", embeddedAddress);
+	INFO(ir);
+	// A private unnamed_addr constant byte array must appear (impossible with an opaque inttoptr).
+	REQUIRE(ir.find("nautilus_const_bytes_") != std::string::npos);
+	REQUIRE(ir.find("private unnamed_addr constant") != std::string::npos);
+	REQUIRE(ir.find("[4 x i8]") != std::string::npos);
+	// The blob bytes {10,20,30,40}: 10,20,30 render as hex escapes (40 is the printable '(').
+	// The exact byte values are additionally proven by the folded `ret i32 100` sum test below.
+	REQUIRE(ir.find("c\"\\0A\\14\\1E") != std::string::npos);
+}
+
+TEST_CASE("ConstBytes reads fold to immediates") {
+	std::string ir = compileAndDumpIR("sum", sumEmbeddedBytes);
+	INFO(ir);
+	// All four reads of the constant global fold: execute collapses to `ret i32 100`.
+	REQUIRE(ir.find("ret i32 100") != std::string::npos);
+}
+
+TEST_CASE("ConstBytes literal comparison folds to immediate icmps") {
+	std::string ir = compileAndDumpIR("cmp", std::function<val<bool>(val<const int8_t*>)> {matchesAZ});
+	INFO(ir);
+	// The embedded 'a'(97) and 'z'(122) become immediate operands of the comparisons, and the
+	// literal is NOT lowered as an opaque pointer constant.
+	REQUIRE(ir.find("inttoptr") == std::string::npos);
+	REQUIRE((ir.find(", 97") != std::string::npos || ir.find("97,") != std::string::npos));
+	REQUIRE((ir.find(", 122") != std::string::npos || ir.find("122,") != std::string::npos));
+}
+#endif
+#endif
+
+} // namespace nautilus::engine
