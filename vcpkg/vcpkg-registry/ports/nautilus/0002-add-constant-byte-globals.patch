+mlir::Value MLIRLoweringProvider::getOrCreateConstantBytesAddress(const std::vector<int8_t>& bytes) {
+	// Content-address the blob so two equal blobs share a single global (dedup).
+	std::string key(reinterpret_cast<const char*>(bytes.data()), bytes.size());
+	std::string name;
+	auto it = constantByteGlobals.find(key);
+	if (it != constantByteGlobals.end()) {
+		name = it->second;
+	} else {
+		auto i8Type = builder->getI8Type();
+		auto arrayType = mlir::LLVM::LLVMArrayType::get(i8Type, bytes.size());
+		auto dataAttr = mlir::StringAttr::get(context, llvm::StringRef(key.data(), key.size()));
+		name = "nautilus_const_bytes_" + std::to_string(constantByteGlobalCounter++);
+
+		// Insert the global at module scope; the InsertionGuard restores the current IP afterwards.
+		mlir::PatternRewriter::InsertionGuard insertGuard(*builder);
+		builder->restoreInsertionPoint(*globalInsertPoint);
+		auto global =
+		    builder->create<mlir::LLVM::GlobalOp>(getNameLoc("constBytes"), arrayType, /*isConstant=*/true,
+		                                          mlir::LLVM::Linkage::Private, name, dataAttr, /*alignment=*/1);
+		global.setUnnamedAddr(mlir::LLVM::UnnamedAddr::Global);
+		constantByteGlobals.emplace(std::move(key), name);
+	}
+	return builder->create<mlir::LLVM::AddressOfOp>(getNameLoc("constBytesAddr"),
+	                                                mlir::LLVM::LLVMPointerType::get(context), name);
+}
