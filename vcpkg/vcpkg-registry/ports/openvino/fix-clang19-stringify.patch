Subject: [PATCH] fix-clang19-stringify
---
Index: src/core/include/openvino/core/except.hpp
IDEA additional info:
Subsystem: com.intellij.openapi.diff.impl.patch.CharsetEP
<+>UTF-8
===================================================================
diff --git a/src/core/include/openvino/core/except.hpp b/src/core/include/openvino/core/except.hpp
--- a/src/core/include/openvino/core/except.hpp	(revision ac13440bdcb0a04e1fe9a6f7ee952b3263ce700d)
+++ b/src/core/include/openvino/core/except.hpp	(date 1778147366132)
@@ -48,10 +48,10 @@
     return stream.str();
 }
 
-template <class T,
-          typename std::enable_if<std::is_same<typename std::decay<T>::type, std::string>::value>::type* = nullptr>
-T& stringify(T&& arg) {
-    return arg;
+template <typename T,
+            typename std::enable_if<std::is_same<typename std::decay<T>::type, std::string>::value>::type* = nullptr>
+decltype(auto) stringify(T&& arg) {
+    return std::forward<T>(arg);
 }
 
 /// Base class for check failure exceptions.
Index: src/plugins/intel_cpu/src/utils/cpp/to_underlying.hpp
IDEA additional info:
Subsystem: com.intellij.openapi.diff.impl.patch.CharsetEP
<+>UTF-8
===================================================================
diff --git a/src/plugins/intel_cpu/src/utils/cpp/to_underlying.hpp b/src/plugins/intel_cpu/src/utils/cpp/to_underlying.hpp
--- a/src/plugins/intel_cpu/src/utils/cpp/to_underlying.hpp	(revision ac13440bdcb0a04e1fe9a6f7ee952b3263ce700d)
+++ b/src/plugins/intel_cpu/src/utils/cpp/to_underlying.hpp	(date 1778147366156)
@@ -7,13 +7,8 @@
 
 namespace ov::intel_cpu {
 
-#ifdef OPENVINO_CPP_VER_AT_LEAST_23
-using to_underlying = std::to_underlying;
-#else
-// implementation of C++23 std::to_underlying
 template <typename E>
 constexpr auto to_underlying(E e) noexcept {
     return static_cast<std::underlying_type_t<E>>(e);
 }
 }  // namespace ov::intel_cpu
-#endif
