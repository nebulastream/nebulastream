+	if (!input.is_open()) {
+		return false;
+	}
+
+	std::string versionLine;
+	if (!std::getline(input, versionLine)) {
+		return false;
+	}
+	if (versionLine != kDynamicPointerBindingVersion) {
+		return false;
+	}
+
+	std::unordered_map<std::string, uint64_t> loadedBindings;
+	std::string line;
+	while (std::getline(input, line)) {
+		if (line.empty()) {
+			continue;
+		}
+		const auto separatorPos = line.find('\t');
+		if (separatorPos == std::string::npos || line.find('\t', separatorPos + 1) != std::string::npos) {
+			return false;
+		}
+		const std::string_view lineView(line);
+		auto name = std::string(lineView.substr(0, separatorPos));
+		const auto pointerHex = lineView.substr(separatorPos + 1);
+		uint64_t pointerValue = 0;
+		if (name.empty() || !tryParseHexUint64(pointerHex, pointerValue) || pointerValue == 0) {
+			return false;
+		}
+		const auto [it, inserted] = loadedBindings.emplace(name, pointerValue);
+		if (!inserted && it->second != pointerValue) {
+			return false;
+		}
+	}
+
+	bindings = std::move(loadedBindings);
+	return true;
