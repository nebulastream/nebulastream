+void ExecutionTrace::registerDynamicPointer(uint64_t pointerValue, std::string name) {
+	if (pointerValue == 0) {
+		return;
+	}
+	if (const auto valueIt = dynamicPointerNamesByValue.find(pointerValue); valueIt != dynamicPointerNamesByValue.end()) {
+		if (valueIt->second != name) {
+			throw RuntimeException("Dynamic pointer value registered with conflicting names");
+		}
+		return;
+	}
+	if (const auto nameIt = dynamicPointerValuesByName.find(name); nameIt != dynamicPointerValuesByName.end()) {
+		if (nameIt->second != pointerValue) {
+			throw RuntimeException("Dynamic pointer name registered with conflicting pointer values");
+		}
+		return;
+	}
+	dynamicPointerValuesByName.emplace(name, pointerValue);
+	dynamicPointerNamesByValue.emplace(pointerValue, std::move(name));
+}
