"""conntest — the single entry point for the connectivity-test battery.

Thin shim: put this directory on sys.path so ``conntest_runner`` imports,
then dispatch to ``conntest_runner.cli.main``. All the logic lives in the
package; see ``conntest_runner/cli.py`` for the subcommands
(run / ci / coverage / debug / list / install-clion) and the host /
self-wrap execution model (docker-setup-v3 §5.2).

Runs on the *host* python (the orchestrator drives ``docker compose``; it
does not need the runner's third-party deps), so this file and
``cli.py`` stay compatible with the older python a developer's machine
might ship — pytest and ``conntest_runner.{discovery,protocol,harness}``
run inside the runner container instead.
"""

import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)), "src"))

from conntest_runner.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
