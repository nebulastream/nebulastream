# Test 11: VARSIZED string depseudonymization
#   Input: AES-256-CTR encrypted hex strings from Pseudonymize Test 11
#   Expected: original patient ID strings P001, P002, P003

CREATE LOGICAL SOURCE stream11(patient_id_pseudo VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR stream11 TYPE File;
ATTACH INLINE
530a988a127b178d8bd04e5e69632d6ff303f320
99f7971de5720f5ae9547767e0d20a2646ff302f
eefc834a1fa4681cab5b136cb0721f2f11cb313d

CREATE SINK sinkStream11(patient_id VARSIZED NOT NULL) TYPE File;

SELECT
    Depseudonymize(patient_id_pseudo) AS patient_id
FROM stream11 INTO sinkStream11;
----
P001
P002
P003


# Test 12: Null Handling
#   Verifies that NULL values are passed through completely untouched.
#   Mirrors Pseudonymize Test 12.

CREATE LOGICAL SOURCE stream12(patient_id_pseudo INT32);
CREATE PHYSICAL SOURCE FOR stream12 TYPE File;
ATTACH INLINE
154255457
<NULL>
1478919998

CREATE SINK sinkStream12(patient_id INT32) TYPE File;

SELECT
    Depseudonymize(patient_id_pseudo) AS patient_id
FROM stream12 INTO sinkStream12;
----
0
NULL
3


# Test 13: Error Handling (Unsupported Type)
#   Verifies that passing a FLOAT32 throws the expected runtime_error.
#   Mirrors Pseudonymize Test 13.

CREATE LOGICAL SOURCE stream13(patient_id_pseudo FLOAT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream13 TYPE File;
ATTACH INLINE
3.14

CREATE SINK sinkStream13(patient_id FLOAT32 NOT NULL) TYPE File;

SELECT
    Depseudonymize(patient_id_pseudo) AS patient_id
FROM stream13 INTO sinkStream13;
----
Error 2006
