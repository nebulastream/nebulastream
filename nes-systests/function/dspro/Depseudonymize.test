# name: function/dspro/Depseudonymize.test
# description: Tests for the Depseudonymize function using the Feistel cipher.
#              Inputs are pseudonymized values; expected outputs are the original patient IDs.
#              This is the inverse of Pseudonymize.test — every test here mirrors one there.
# groups: [Function, Depseudonymize]
#
# IMPORTANT — before running these tests, set the environment variable:
#   export PSEUDONYM_SECRET_KEY="my-secret-key"


# Test 1: Basic depseudonymization (INT32)
#   Input: the 4 pseudonymized INT32 values from Pseudonymize Test 1
#   Expected: the original patient IDs (0, 1, 2, 3)
#   Proves: Feistel decryption correctly inverts Feistel encryption for INT32.

CREATE LOGICAL SOURCE stream(patient_id_pseudo INT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
1478919998
154255457
161154599
29174422

CREATE SINK sinkStream(patient_id INT32 NOT NULL) TYPE File;

SELECT
    Depseudonymize(patient_id_pseudo) AS patient_id
FROM stream INTO sinkStream;
----
0
1
2
3


# Test 2: Determinism (INT32)
#   Runs the exact same depseudonymization twice.
#   Proves: same pseudonymized input + same key always recovers the same original ID.

CREATE LOGICAL SOURCE stream2(patient_id_pseudo INT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream2 TYPE File;
ATTACH INLINE
1478919998
154255457
161154599
29174422

CREATE SINK sinkStream2(patient_id INT32 NOT NULL) TYPE File;

SELECT
    Depseudonymize(patient_id_pseudo) AS patient_id
FROM stream2 INTO sinkStream2;
----
0
1
2
3


# Test 3: Edge case — single record (INT32)
#   Verifies depseudonymization works on a stream with exactly one record.

CREATE LOGICAL SOURCE stream3(patient_id_pseudo INT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream3 TYPE File;
ATTACH INLINE
154255457 

CREATE SINK sinkStream3(patient_id INT32 NOT NULL) TYPE File;

SELECT
    Depseudonymize(patient_id_pseudo) AS patient_id
FROM stream3 INTO sinkStream3;
----
0


# Test 4: Edge case — maximum INT32 value
#   Input: the pseudonymized form of INT32_MAX (2147483647)
#   Expected: 2147483647 is recovered exactly.

CREATE LOGICAL SOURCE stream4(patient_id_pseudo INT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream4 TYPE File;
ATTACH INLINE
1624223388

CREATE SINK sinkStream4(patient_id INT32 NOT NULL) TYPE File;

SELECT
    Depseudonymize(patient_id_pseudo) AS patient_id
FROM stream4 INTO sinkStream4;
----
2147483647


