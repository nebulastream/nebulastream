# Test 11: VARSIZED string pseudonymization
#   Verifies that string patient IDs (e.g. "P001") are transformed into
#   64-character lowercase hex pseudo-IDs using HMAC-SHA256.
#   Output is always a fixed-length VARSIZED string regardless of input length.
CREATE LOGICAL SOURCE stream12(patient_id VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR stream12 TYPE File;
ATTACH INLINE
P001
P002
P003

CREATE SINK sinkStream12(patient_id_pseudo VARSIZED NOT NULL) TYPE File;

SELECT
    Pseudonymize(patient_id) AS patient_id_pseudo
FROM stream12 INTO sinkStream12;
----
530a988a127b178d8bd04e5e69632d6ff303f320
99f7971de5720f5ae9547767e0d20a2646ff302f
eefc834a1fa4681cab5b136cb0721f2f11cb313d


# Test 12: Null Handling
#   Verifies that NULL values are passed through completely untouched.
#   This triggers the explicit 'if (inputValue.isNull()) return inputValue;' branch.
CREATE LOGICAL SOURCE stream13(patient_id INT32);
CREATE PHYSICAL SOURCE FOR stream13 TYPE File;
ATTACH INLINE
1
<NULL>
3

CREATE SINK sinkStream13(patient_id_pseudo INT32) TYPE File;

SELECT
    Pseudonymize(patient_id) AS patient_id_pseudo
FROM stream13 INTO sinkStream13;
----
1478919998
NULL
29174422


# Test 13: Error Handling (Unsupported Type)
#   Verifies that passing a FLOAT32 throws the expected runtime_error.
#   This executes the final 'else' branch in the customVisit statement.
CREATE LOGICAL SOURCE stream14(patient_id FLOAT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream14 TYPE File;
ATTACH INLINE
3.14

CREATE SINK sinkStream14(patient_id_pseudo FLOAT32 NOT NULL) TYPE File;

SELECT
    Pseudonymize(patient_id) AS patient_id_pseudo
FROM stream14 INTO sinkStream14;
----
Error 2006


# Test 14: The Ultimate Round-Trip (Pseudonymize -> Depseudonymize)
#   Verifies the core requirement for the final presentation.
#   Proves that encrypting and immediately decrypting an ID via Feistel/AES
#   returns the exact original value, proving perfect bijectivity and format preservation.
CREATE LOGICAL SOURCE stream15(patient_id INT32 NOT NULL, patient_name VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR stream15 TYPE File;
ATTACH INLINE
42, P001
100, P002
2147483647, P003

CREATE SINK sinkStream15(restored_id INT32 NOT NULL, restored_name VARSIZED NOT NULL) TYPE File;

SELECT
    Depseudonymize(Pseudonymize(patient_id)) AS restored_id,
    Depseudonymize(Pseudonymize(patient_name)) AS restored_name
FROM stream15 INTO sinkStream15;
----
42, P001
100, P002
2147483647, P003