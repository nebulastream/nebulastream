# name: function/dspro/Pseudonymize.test
# description: Tests for the Pseudonymize function using HMAC-SHA256 with a secret key loaded from the environment.
# groups: [Function, Pseudonymize]
#
# IMPORTANT — before running these tests, set the environment variable:
#   export PSEUDONYM_SECRET_KEY="my-secret-key"
#
# Test 1: Basic pseudonymization
#   Verifies that patient IDs are transformed into non-identity pseudo-IDs.
#   Input: 0, 1, 2, 3
#   Expected: deterministic HMAC-SHA256 outputs for key="my-secret-key"

CREATE LOGICAL SOURCE stream(patient_id INT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
0
1
2
3

CREATE SINK sinkStream(patient_id_pseudo INT32 NOT NULL) TYPE File;

SELECT
    Pseudonymize(patient_id) AS patient_id_pseudo
FROM stream INTO sinkStream;
----
1478919998
154255457
161154599
29174422


# Test 2: Determinism
#   Runs the exact same query a second time and expects identical output.
#   Proves: same input + same key always produces the same pseudo-ID.
#   This is critical for patient tracking across multiple data streams.

CREATE LOGICAL SOURCE stream2(patient_id INT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream2 TYPE File;
ATTACH INLINE
0
1
2
3

CREATE SINK sinkStream2(patient_id_pseudo INT32 NOT NULL) TYPE File;

SELECT
    Pseudonymize(patient_id) AS patient_id_pseudo
FROM stream2 INTO sinkStream2;
----
1478919998
154255457
161154599
29174422


# Test 3: Edge case — single record
#   Verifies the function works correctly with a stream of exactly one record.

CREATE LOGICAL SOURCE stream4(patient_id INT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream4 TYPE File;
ATTACH INLINE
0

CREATE SINK sinkStream4(patient_id_pseudo INT32 NOT NULL) TYPE File;

SELECT
    Pseudonymize(patient_id) AS patient_id_pseudo
FROM stream4 INTO sinkStream4;
----
154255457


# Test 4: Edge case — maximum INT32 value
#   Verifies the function handles the boundary value INT32_MAX (2147483647)
#   without overflow or undefined behaviour.

CREATE LOGICAL SOURCE stream5(patient_id INT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream5 TYPE File;
ATTACH INLINE
2147483647

CREATE SINK sinkStream5(patient_id_pseudo INT32 NOT NULL) TYPE File;

SELECT
    Pseudonymize(patient_id) AS patient_id_pseudo
FROM stream5 INTO sinkStream5;
----
1624223388


