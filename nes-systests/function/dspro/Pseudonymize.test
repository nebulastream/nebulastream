-8069197614224008833


# Test 7: INT8 Data Type Support
#   Verifies that the function correctly processes 1-byte integers (INT8).
#   This explicitly triggers the `is_same_v<ArgType, nautilus::val<int8_t>>` branch.
CREATE LOGICAL SOURCE stream8(patient_id INT8 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream8 TYPE File;
ATTACH INLINE
1
2
3

CREATE SINK sinkStream8(patient_id_pseudo INT8 NOT NULL) TYPE File;

SELECT
    Pseudonymize(patient_id) AS patient_id_pseudo
FROM stream8 INTO sinkStream8;
----
-37
-46
-63


# Test 8: INT8 Edge Case — Maximum Value
#   Verifies the function handles the boundary value for signed INT8 (127).
CREATE LOGICAL SOURCE stream9(patient_id INT8 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream9 TYPE File;
ATTACH INLINE
127

CREATE SINK sinkStream9(patient_id_pseudo INT8 NOT NULL) TYPE File;

SELECT
    Pseudonymize(patient_id) AS patient_id_pseudo
FROM stream9 INTO sinkStream9;
----
-84


