#   using the polymorphic template without causing a JIT-compiler type mismatch.
CREATE LOGICAL SOURCE stream6(patient_id INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream6 TYPE File;
ATTACH INLINE
0
1
2
3

CREATE SINK sinkStream6(patient_id_pseudo INT64 NOT NULL) TYPE File;

SELECT
    Pseudonymize(patient_id) AS patient_id_pseudo
FROM stream6 INTO sinkStream6;
