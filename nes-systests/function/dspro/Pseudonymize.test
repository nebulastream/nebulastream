# name: function/dspro/Pseudonymize.test
# description: Tests for the Pseudonymize function using HMAC-SHA256 with a secret key loaded from the environment.
# groups: [Function, Pseudonymize]
#
# IMPORTANT — before running these tests, set the environment variable:
#   export PSEUDONYM_SECRET_KEY="my-secret-key"
#
# Test 1: Basic pseudonymization
#   Verifies that patient IDs are transformed into non-identity pseudo-IDs.
#   Input: 0, 1, 2, 3
#   Expected: deterministic HMAC-SHA256 outputs for key="my-secret-key"

CREATE LOGICAL SOURCE stream(patient_id INT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
0
1
2
3

CREATE SINK sinkStream(patient_id_pseudo INT32 NOT NULL) TYPE File;

SELECT
    Pseudonymize(patient_id) AS patient_id_pseudo
FROM stream INTO sinkStream;
----
2031579173
1319590570
465916991
331865371


# Test 2: Determinism
#   Runs the exact same query a second time and expects identical output.
#   Proves: same input + same key always produces the same pseudo-ID.
#   This is critical for patient tracking across multiple data streams.

CREATE LOGICAL SOURCE stream2(patient_id INT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream2 TYPE File;
ATTACH INLINE
0
1
2
3

CREATE SINK sinkStream2(patient_id_pseudo INT32 NOT NULL) TYPE File;

SELECT
    Pseudonymize(patient_id) AS patient_id_pseudo
FROM stream2 INTO sinkStream2;
----
2031579173
1319590570
465916991
331865371


# Test 3: Key sensitivity
#   Uses a different key (other-secret-key) and expects completely different outputs
#   for the same input IDs. Proves the key is actually being used in the HMAC —
#   without this test, a plain SHA-256 (no key) would also pass tests 1 and 2.
#
#   To run this test, temporarily change the environment variable:
#     export PSEUDONYM_SECRET_KEY="other-secret-key"

#CREATE LOGICAL SOURCE stream3(patient_id INT32 NOT NULL);
#CREATE PHYSICAL SOURCE FOR stream3 TYPE File;
#ATTACH INLINE
#0
#1
#2
#3

#CREATE SINK sinkStream3(patient_id_pseudo INT32 NOT NULL) TYPE File;

#SELECT
#    Pseudonymize(patient_id) AS patient_id_pseudo
#FROM stream3 INTO sinkStream3;
#----
#1702986568
#1021456373
#681150670
#975472697


# Test 4: Edge case — single record
#   Verifies the function works correctly with a stream of exactly one record.

CREATE LOGICAL SOURCE stream4(patient_id INT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream4 TYPE File;
ATTACH INLINE
0

CREATE SINK sinkStream4(patient_id_pseudo INT32 NOT NULL) TYPE File;

SELECT
    Pseudonymize(patient_id) AS patient_id_pseudo
FROM stream4 INTO sinkStream4;
----
2031579173


# Test 5: Edge case — maximum INT32 value
#   Verifies the function handles the boundary value INT32_MAX (2147483647)
#   without overflow or undefined behaviour.

CREATE LOGICAL SOURCE stream5(patient_id INT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream5 TYPE File;
ATTACH INLINE
2147483647

CREATE SINK sinkStream5(patient_id_pseudo INT32 NOT NULL) TYPE File;

SELECT
    Pseudonymize(patient_id) AS patient_id_pseudo
FROM stream5 INTO sinkStream5;
----
1401463166



# Test 6: INT64 Data Type Support
#   Verifies that the function correctly identifies and processes INT64 inputs
#   using the polymorphic template without causing a JIT-compiler type mismatch.
CREATE LOGICAL SOURCE stream6(patient_id INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream6 TYPE File;
ATTACH INLINE
0
1
2
3

CREATE SINK sinkStream6(patient_id_pseudo INT64 NOT NULL) TYPE File;

SELECT
    Pseudonymize(patient_id) AS patient_id_pseudo
FROM stream6 INTO sinkStream6;
----
5879662185643602027
6351266960312834111
7878015036157417302
8896932896802744675


# Test 7: Edge case — maximum INT64 value
#   Verifies the function handles the massive 8-byte boundary value INT64_MAX
#   (9223372036854775807) natively.
CREATE LOGICAL SOURCE stream7(patient_id INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream7 TYPE File;
ATTACH INLINE
9223372036854775807

CREATE SINK sinkStream7(patient_id_pseudo INT64 NOT NULL) TYPE File;

SELECT
    Pseudonymize(patient_id) AS patient_id_pseudo
FROM stream7 INTO sinkStream7;
----
2830690117075404093