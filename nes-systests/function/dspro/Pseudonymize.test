# Test 10: INT16 Edge Case — Maximum Value
#   Verifies the function handles the boundary value for signed INT16 (32767).
CREATE LOGICAL SOURCE stream11(patient_id INT16 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream11 TYPE File;
ATTACH INLINE
32767

CREATE SINK sinkStream11(patient_id_pseudo INT16 NOT NULL) TYPE File;

SELECT
    Pseudonymize(patient_id) AS patient_id_pseudo
FROM stream11 INTO sinkStream11;
