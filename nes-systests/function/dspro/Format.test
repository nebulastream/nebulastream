# name: function/dspro/Format.test
# description: Skeleton tests for the Format function (returns the format string verbatim until students implement substitution).
# groups: [Function, Format]

CREATE LOGICAL SOURCE stream(value INT32 NOT NULL, other_value INT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
1,10
2,20
3,30

CREATE SINK sinkStream(formatted VARSIZED NOT NULL) TYPE File;

# TODO(student): once Format actually substitutes `{}` placeholders, replace the
#                expected rows below with the formatted output, e.g.:
#                  Value is: 1, which is larger than: 10
#                  Value is: 2, which is larger than: 20
#                  Value is: 3, which is larger than: 30
SELECT
    Format(VARSIZED("Value is: {}, which is larger than: {}"), value, other_value) AS formatted
FROM stream INTO sinkStream;
----
Value is: 1, which is larger than: 10
Value is: 2, which is larger than: 20
Value is: 3, which is larger than: 30

########################################
# VARSIZED source
########################################

CREATE LOGICAL SOURCE stringStream(
    value VARSIZED NOT NULL,
    other_value VARSIZED NOT NULL
);

CREATE PHYSICAL SOURCE FOR stringStream TYPE File;

ATTACH INLINE
one,ten
two,twenty
three,thirty

########################################
# INT32 source
########################################

CREATE LOGICAL SOURCE intStream(
    value INT32 NOT NULL,
    other_value INT32 NOT NULL
);

CREATE PHYSICAL SOURCE FOR intStream TYPE File;

ATTACH INLINE
1,10
2,20
3,30

########################################
# Test 0 placeholders
########################################

CREATE SINK sinkZero(formatted VARSIZED NOT NULL) TYPE File;

SELECT
    Format(VARSIZED("No placeholders")) AS formatted
FROM stringStream INTO sinkZero;
----
No placeholders
No placeholders
No placeholders

########################################
# Test 1 placeholder (VARSIZED)
########################################

CREATE SINK sinkOne(formatted VARSIZED NOT NULL) TYPE File;

SELECT
    Format(VARSIZED("Value is: {}"), value) AS formatted
FROM stringStream INTO sinkOne;
----
Value is: one
Value is: two
Value is: three

########################################
# Test 2 placeholders (VARSIZED)
########################################

CREATE SINK sinkTwo(formatted VARSIZED NOT NULL) TYPE File;

SELECT
    Format(
        VARSIZED("Value is: {}, which is larger than: {}"),
        value,
        other_value
    ) AS formatted
FROM stringStream INTO sinkTwo;
----
Value is: one, which is larger than: ten
Value is: two, which is larger than: twenty
Value is: three, which is larger than: thirty

########################################
# Test 2 placeholders (INT32)
########################################

CREATE SINK sinkInt(formatted VARSIZED NOT NULL) TYPE File;

SELECT
    Format(
        VARSIZED("Value is: {}, which is larger than: {}"),
        value,
        other_value
    ) AS formatted
FROM intStream INTO sinkInt;
----
Value is: 1, which is larger than: 10
Value is: 2, which is larger than: 20
Value is: 3, which is larger than: 30

########################################
# BOOL source
########################################

CREATE LOGICAL SOURCE boolStream(flag BOOLEAN NOT NULL);
CREATE PHYSICAL SOURCE FOR boolStream TYPE File;

ATTACH INLINE
true
false
true

CREATE SINK sinkBool(formatted VARSIZED NOT NULL) TYPE File;

SELECT
    Format(VARSIZED("flag={}"), flag) AS formatted
FROM boolStream INTO sinkBool;
----
flag=true
flag=false
flag=true

