########################################

CREATE LOGICAL SOURCE charStream(c CHAR NOT NULL);
CREATE PHYSICAL SOURCE FOR charStream TYPE File;

ATTACH INLINE
a
b
c

CREATE SINK sinkChar(formatted VARSIZED NOT NULL) TYPE File;

SELECT
    Format(VARSIZED("char={}"), c) AS formatted
FROM charStream INTO sinkChar;
----
char=a
char=b
char=c

########################################
# FLOAT source
########################################

CREATE LOGICAL SOURCE floatStream(temp FLOAT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR floatStream TYPE File;

ATTACH INLINE
1.5
2.25
3.75

CREATE SINK sinkFloat(formatted VARSIZED NOT NULL) TYPE File;

SELECT
    Format(VARSIZED("temp={}"), temp) AS formatted
FROM floatStream INTO sinkFloat;
