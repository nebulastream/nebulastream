# ERROR CASES

# different input data type than VARSIZED
CREATE LOGICAL SOURCE wrongInputDataTypeStream(value UINT64);
CREATE PHYSICAL SOURCE FOR wrongInputDataTypeStream TYPE File;
ATTACH INLINE
123

SELECT VARSIZEDTONUMERIC(value, FLOAT64) AS value_out FROM wrongInputDataTypeStream INTO FILE();
----
Error 2006


# non-numeric string
CREATE LOGICAL SOURCE nonNumericStream(value VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR nonNumericStream TYPE File;
ATTACH INLINE
abc

SELECT VARSIZEDTONUMERIC(value, INT32) AS value_out FROM nonNumericStream INTO FILE();
----
Error 4003


# overflow: value too large for INT8
CREATE LOGICAL SOURCE overflowStream(value VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR overflowStream TYPE File;
ATTACH INLINE
999

SELECT VARSIZEDTONUMERIC(value, INT8) AS value_out FROM overflowStream INTO FILE();
----
Error 4003
