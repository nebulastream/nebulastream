# name: VarSizedToNumeric conversion
# description: Checks if the conversion from VARSIZED strings to numeric target types works
# groups: [Function]

# SUCCESS CASES

# FLOAT64
CREATE LOGICAL SOURCE varSizedNumericFloat64Stream(value VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR varSizedNumericFloat64Stream TYPE File;
ATTACH INLINE
14.5
 14.5
14.5
1 234.56
12?3
-42.75
0
000123.4500
 ? 7 ? . ? 5 ?

SELECT VARSIZEDTONUMERIC(value, FLOAT64) AS value_out FROM varSizedNumericFloat64Stream INTO FILE();
----
14.5
14.5
14.5
1234.56
123
-42.75
0
123.45
7.5


# FLOAT32
CREATE LOGICAL SOURCE varSizedNumericFloat32Stream(value VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR varSizedNumericFloat32Stream TYPE File;
ATTACH INLINE
3.5
0
-7.25
1?2?.5

SELECT VARSIZEDTONUMERIC(value, FLOAT32) AS value_out FROM varSizedNumericFloat32Stream INTO FILE();
----
3.5
0
-7.25
12.5


