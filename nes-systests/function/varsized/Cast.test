# name: Cast conversion
# description: Checks if CASTTOTYPE works for VARSIZED-to-numeric and numeric-to-numeric conversions
# groups: [Function]

# VARSIZED TO NUMERIC CASES

# FLOAT64
CREATE LOGICAL SOURCE varSizedNumericFloat64Stream(value VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR varSizedNumericFloat64Stream TYPE File;
ATTACH INLINE
14.5
 14.5
14.5
1 234.56
12?3
-42.75
0
000123.4500
 ? 7 ? . ? 5 ?

SELECT CASTTOTYPE(value AS FLOAT64) AS value_out FROM varSizedNumericFloat64Stream INTO FILE();
----
14.5
14.5
14.5
1234.56
123
-42.75
0
123.45
7.5


# FLOAT32
CREATE LOGICAL SOURCE varSizedNumericFloat32Stream(value VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR varSizedNumericFloat32Stream TYPE File;
ATTACH INLINE
3.5
0
-7.25
1?2?.5

SELECT CASTTOTYPE(value AS FLOAT32) AS value_out FROM varSizedNumericFloat32Stream INTO FILE();
----
3.5
0
-7.25
12.5


# INT8
CREATE LOGICAL SOURCE varSizedNumericInt8Stream(value VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR varSizedNumericInt8Stream TYPE File;
ATTACH INLINE
42
-1
0
1?2?7
 0 0 5

SELECT CASTTOTYPE(value AS INT8) AS value_out FROM varSizedNumericInt8Stream INTO FILE();
----
42
-1
0
127
5


