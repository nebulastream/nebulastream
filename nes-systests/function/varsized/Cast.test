# NUMERIC TO NUMERIC CASES

# UINT64 to FLOAT64
CREATE LOGICAL SOURCE numericCastUint64Stream(value UINT64);
CREATE PHYSICAL SOURCE FOR numericCastUint64Stream TYPE File;
ATTACH INLINE
123
0
42

SELECT CASTTOTYPE(value AS FLOAT64) AS value_out FROM numericCastUint64Stream INTO FILE();
----
123
0
42


# INT32 to FLOAT64
CREATE LOGICAL SOURCE numericCastInt32Stream(value INT32);
CREATE PHYSICAL SOURCE FOR numericCastInt32Stream TYPE File;
ATTACH INLINE
-42
0
123

SELECT CASTTOTYPE(value AS FLOAT64) AS value_out FROM numericCastInt32Stream INTO FILE();
----
-42
0
123


# INT64 to INT32
CREATE LOGICAL SOURCE numericCastInt64ToInt32Stream(value INT64);
CREATE PHYSICAL SOURCE FOR numericCastInt64ToInt32Stream TYPE File;
ATTACH INLINE
42
-1
0

SELECT CASTTOTYPE(value AS INT32) AS value_out FROM numericCastInt64ToInt32Stream INTO FILE();
----
42
-1
0


# ERROR CASES

# non-numeric string
CREATE LOGICAL SOURCE nonNumericStream(value VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR nonNumericStream TYPE File;
ATTACH INLINE
abc

SELECT CASTTOTYPE(value AS INT32) AS value_out FROM nonNumericStream INTO FILE();
----
Error 4003


# overflow: value too large for INT8
CREATE LOGICAL SOURCE overflowStream(value VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR overflowStream TYPE File;
ATTACH INLINE
999

SELECT CASTTOTYPE(value AS INT8) AS value_out FROM overflowStream INTO FILE();
----
Error 4003
