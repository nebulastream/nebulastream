# name: function/CaseWhenLeakageQuery.test
# description: Incremental tests for CASE inside projections, aggregations, and a nested leakage query
# groups: [Function, FunctionCaseWhen, Aggregation, WindowOperators]

CREATE LOGICAL SOURCE waterMeterReadings(node_type UINT8 NOT NULL, demand_value FLOAT32 NOT NULL, ts UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR waterMeterReadings TYPE File;
ATTACH INLINE
1,10.5,1000
0,4.0,2000
1,5.0,3000
0,3.0,4000
1,-2.0,5000
0,0.0,6000

CREATE SINK split_sink(
    waterMeterReadings.node_type UINT8 NOT NULL,
    waterMeterReadings.demand_value FLOAT32 NOT NULL,
    injected_part FLOAT32 NOT NULL,
    absorbed_part FLOAT32 NOT NULL
) TYPE File;

CREATE SINK totals_sink(
    total_injected FLOAT32 NOT NULL,
    total_absorbed FLOAT32 NOT NULL
) TYPE File;

CREATE SINK leakage_sink(
    total_injected FLOAT32 NOT NULL,
    total_absorbed FLOAT32 NOT NULL,
    leakage_gap FLOAT32 NOT NULL
) TYPE File;

# 1. Basic CASE projection split by node type
SELECT
    node_type,
    demand_value,
    CASE
        WHEN node_type = UINT8(1) THEN demand_value
        ELSE FLOAT32(0.0)
    END AS injected_part,
    CASE
        WHEN node_type = UINT8(0) THEN demand_value
        ELSE FLOAT32(0.0)
    END AS absorbed_part
FROM waterMeterReadings
WHERE demand_value > FLOAT32(0.0)
INTO split_sink;
----
1,10.5,10.5,0
0,4,0,4
1,5,5,0
0,3,0,3

# 2. CASE inside SUM over a tumbling window
SELECT
    SUM(CASE WHEN node_type = UINT8(1) THEN demand_value ELSE FLOAT32(0.0) END) AS total_injected,
    SUM(CASE WHEN node_type = UINT8(0) THEN demand_value ELSE FLOAT32(0.0) END) AS total_absorbed
FROM waterMeterReadings
WHERE demand_value > FLOAT32(0.0)
WINDOW TUMBLING(ts, SIZE 30 SEC)
INTO totals_sink;
----
15.5,7

# 3. Full nested use-case query
SELECT
    total_injected,
    total_absorbed,
    total_injected - total_absorbed AS leakage_gap
FROM (
    SELECT
        SUM(CASE WHEN node_type = UINT8(1) THEN demand_value ELSE FLOAT32(0.0) END) AS total_injected,
        SUM(CASE WHEN node_type = UINT8(0) THEN demand_value ELSE FLOAT32(0.0) END) AS total_absorbed
    FROM waterMeterReadings
    WHERE demand_value > FLOAT32(0.0)
    WINDOW TUMBLING(ts, SIZE 30 SEC)
)
WHERE total_injected != total_absorbed
INTO leakage_sink;
----
15.5,7,8.5
