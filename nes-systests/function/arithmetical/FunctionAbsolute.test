# name: function/arithmetical/FunctionAbsolute.test
# description: Tests for the ABS() function following SQL result-type and overflow semantics
# groups: [Function, FunctionAbs]

# ABS() result types follow SQL semantics:
#  - signed integers are widened by one rank (INT8->INT16, INT16->INT32, INT32->INT64, INT64->INT64)
#  - unsigned integers and floats keep their type
#  - nullability propagates from input to output

CREATE LOGICAL SOURCE stream(i8 INT8 NOT NULL, i16 INT16 NOT NULL, i32 INT32 NOT NULL, i64 INT64 NOT NULL, u8 UINT8 NOT NULL, u16 UINT16 NOT NULL, u32 UINT32 NOT NULL, u64 UINT64 NOT NULL, f32 FLOAT32 NOT NULL, f64 FLOAT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
-42,-129,-32769,-2147483649,42,256,65536,4294967296,23.2,-42.45

# The result types are widened for signed integers; unsigned and float types are preserved.
CREATE SINK sinkStream(i8 INT16 NOT NULL, i16 INT32 NOT NULL, i32 INT64 NOT NULL, i64 INT64 NOT NULL, u8 UINT8 NOT NULL, u16 UINT16 NOT NULL, u32 UINT32 NOT NULL, u64 UINT64 NOT NULL, f32 FLOAT32 NOT NULL, f64 FLOAT64 NOT NULL) TYPE File;

SELECT
    ABS(i8) AS i8,
    ABS(i16) AS i16,
    ABS(i32) AS i32,
    ABS(i64) AS i64,

    ABS(u8) AS u8,
    ABS(u16) AS u16,
    ABS(u32) AS u32,
    ABS(u64) AS u64,

    ABS(f32) AS f32,
    ABS(f64) AS f64
FROM stream INTO sinkStream;
----
42,129,32769,2147483649,42,256,65536,4294967296,23.2,42.45

# Boundary case: the most-negative value of each widenable signed integer type.
# ABS(INT8 -128) = INT16 128, ABS(INT16 -32768) = INT32 32768, ABS(INT32 -2147483648) = INT64 2147483648.
CREATE LOGICAL SOURCE boundary(i8 INT8 NOT NULL, i16 INT16 NOT NULL, i32 INT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR boundary TYPE File;
ATTACH INLINE
-128,-32768,-2147483648

CREATE SINK boundarySink(i8 INT16 NOT NULL, i16 INT32 NOT NULL, i32 INT64 NOT NULL) TYPE File;

SELECT
    ABS(i8) AS i8,
    ABS(i16) AS i16,
    ABS(i32) AS i32
FROM boundary INTO boundarySink;
----
128,32768,2147483648

# Overflow case: INT64 cannot be widened, so ABS(INT64_MIN) must raise a runtime error (ArithmeticalError, 3013).
CREATE LOGICAL SOURCE overflow(i64 INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR overflow TYPE File;
ATTACH INLINE
-9223372036854775808

CREATE SINK overflowSink(i64 INT64 NOT NULL) TYPE File;

SELECT ABS(i64) AS i64 FROM overflow INTO overflowSink;
----
ERROR 3013

# Nullability propagation: a nullable input yields a nullable output, and NULL propagates to NULL.
CREATE LOGICAL SOURCE nullableStream(i8 INT8, u32 UINT32, f64 FLOAT64);
CREATE PHYSICAL SOURCE FOR nullableStream TYPE File;
ATTACH INLINE
-7,7,-7.5
,,

CREATE SINK nullableSink(i8 INT16, u32 UINT32, f64 FLOAT64) TYPE File;

SELECT
    ABS(i8) AS i8,
    ABS(u32) AS u32,
    ABS(f64) AS f64
FROM nullableStream INTO nullableSink;
----
7,7,7.5
NULL,NULL,NULL
