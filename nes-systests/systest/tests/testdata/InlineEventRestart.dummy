# name: inline/InlineEventRestart.test
# description: Inline event restart script for remote and local systest runs
# groups: [InlineEvent]

CREATE LOGICAL SOURCE stream(i64 INT64, ts UINT64);
CREATE PHYSICAL SOURCE FOR stream TYPE TCP;
ATTACH INLINE
10,0
<CRASH>
11,30
<RESTART>
12,60

CREATE SINK sink(stream.i64 INT64, stream.ts UINT64) TYPE File;

SELECT i64, ts FROM stream INTO sink;
----
12,60
