# name: inline/InlineEventMixed.test
# description: Mix of inline-event and regular queries without worker restarts
# groups: [InlineEvent]

CREATE LOGICAL SOURCE stream(i64 INT64, ts UINT64);
CREATE PHYSICAL SOURCE FOR stream TYPE TCP;
ATTACH INLINE
10,0
<DELAY 10>
11,30
12,60

CREATE LOGICAL SOURCE stream2(i64 INT64, ts UINT64);
CREATE PHYSICAL SOURCE FOR stream2 TYPE File;
ATTACH INLINE
1,100
2,200
3,300

CREATE SINK sinkEvent(stream.i64 INT64, stream.ts UINT64) TYPE File;
CREATE SINK sinkRegular(stream2.i64 INT64, stream2.ts UINT64) TYPE File;

SELECT i64, ts FROM stream INTO sinkEvent;
----
10,0
11,30
12,60

SELECT i64, ts FROM stream2 INTO sinkRegular;
----
1,100
2,200
3,300
