# name: formatter/SimdEiselParsers.test
# description: end-to-end coverage for the hand-rolled simdjson integer (Simd*) and fast_float (EiselFloat*) parsers
# groups: [Formatter]

# Integer columns parsed with the Simd* parsers (hand-rolled simdjson digit scanner, no from_chars).
CREATE LOGICAL SOURCE intSource(i8 INT8 NOT NULL, i16 INT16 NOT NULL, i32 INT32 NOT NULL, i64 INT64 NOT NULL, u8 UINT8 NOT NULL, u16 UINT16 NOT NULL, u32 UINT32 NOT NULL, u64 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR intSource TYPE File SET("CSV" AS `INPUT_FORMATTER`.`TYPE`, "SimdINT8" AS `INPUT_FORMATTER`.INT8_PARSER, "SimdINT16" AS `INPUT_FORMATTER`.INT16_PARSER, "SimdINT32" AS `INPUT_FORMATTER`.INT32_PARSER, "SimdINT64" AS `INPUT_FORMATTER`.INT64_PARSER, "SimdUINT8" AS `INPUT_FORMATTER`.UINT8_PARSER, "SimdUINT16" AS `INPUT_FORMATTER`.UINT16_PARSER, "SimdUINT32" AS `INPUT_FORMATTER`.UINT32_PARSER, "SimdUINT64" AS `INPUT_FORMATTER`.UINT64_PARSER);
ATTACH INLINE
-128,-32768,-2147483648,-9223372036854775808,0,0,0,0
127,32767,2147483647,9223372036854775807,255,65535,4294967295,18446744073709551615
+1,+1,+1,+1,1,1,1,1
007,0007,00007,000007,007,0007,00007,000007

# Float columns parsed with the EiselFloat* parsers (hand-rolled Eisel-Lemire, no from_chars).
CREATE LOGICAL SOURCE floatSource(f32 FLOAT32 NOT NULL, f64 FLOAT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR floatSource TYPE File SET("CSV" AS `INPUT_FORMATTER`.`TYPE`, "EiselFloatF32" AS `INPUT_FORMATTER`.F32_PARSER, "EiselFloatF64" AS `INPUT_FORMATTER`.F64_PARSER);
ATTACH INLINE
42.42,65.1515151527
9.0,99.999999999
-0.5,0.25

# Description: the Simd* parsers handle signed/unsigned min and max, a leading '+', and leading zeros.
SELECT * FROM intSource INTO File('CSV' as `SINK`.OUTPUT_FORMAT);
----
-128,-32768,-2147483648,-9223372036854775808,0,0,0,0
127,32767,2147483647,9223372036854775807,255,65535,4294967295,18446744073709551615
1,1,1,1,1,1,1,1
7,7,7,7,7,7,7,7

# Description: the EiselFloat* parsers round-trip fractional, multi-digit and exact-binary values.
SELECT * FROM floatSource INTO File('CSV' as `SINK`.OUTPUT_FORMAT);
----
42.42,65.1515151527
9.0,99.999999999
-0.5,0.25
