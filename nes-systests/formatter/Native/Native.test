CREATE LOGICAL SOURCE oneToFiveString(KEY UINT32 NOT NULL, STRING VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR oneToFiveString TYPE File SET("SystemNative" AS INPUT_FORMATTER.`TYPE`, '12' AS INPUT_FORMATTER.`STRING_LENGTH`);
ATTACH FILE small/string1To5.nes

SELECT KEY, STRING FROM oneToFiveString INTO File();
----
1,hi
2,my
3,name
4,is
5,slim shady

CREATE LOGICAL SOURCE nexmarkPerson100K(id INT32 NOT NULL, name VARSIZED NOT NULL, email_address VARSIZED NOT NULL, credit_card VARSIZED NOT NULL, city VARSIZED NOT NULL, state VARSIZED NOT NULL, timestamp UINT64 NOT NULL, extra VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR nexmarkPerson100K TYPE File SET("SystemNative" AS INPUT_FORMATTER.`TYPE`, '16,32,32,16,4,256' AS INPUT_FORMATTER.`STRING_LENGTH`);
ATTACH FILE small/nexmark/person_100K.nes

SELECT * FROM nexmarkPerson100K INTO Checksum();
----
470 9972292

