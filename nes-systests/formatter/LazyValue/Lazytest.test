# name: LazyTest.test
# description: Tests for lazy parser

CREATE LOGICAL SOURCE stream(id UINT64, value UINT32, timestamp UINT16, a INT8, b INT8);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
1,3,1000,9,8
12,2,1001,9,9
12,2,1001,8,9

CREATE LOGICAL SOURCE stringStream(textual VARSIZED, valid BOOLEAN);
CREATE PHYSICAL SOURCE FOR stringStream TYPE File;
ATTACH INLINE
this,true
definitely,false
a,true
string,false

SELECT * FROM stringStream WHERE textual == valid INTO FILE();
----
this,true
a,true

SELECT * FROM stringStream WHERE textual == BOOLEAN(1) INTO FILE();
----
this,true
definitely,false
a,true
string,false

# Should not parse a single value as lazy equals is implemented for numerics
SELECT * FROM stream WHERE a == b INTO FILE();
----
12,2,1001,9,9

# Not implemented, should parse a
SELECT * FROM stream WHERE a == INT8(9) INTO FILE();
----
1,3,1000,9,8
12,2,1001,9,9

SELECT * FROM stream WHERE a != b INTO FILE();
----
1,3,1000,9,8
12,2,1001,8,9

# Not implemented, parse a
SELECT * FROM stream WHERE a != INT8(9) INTO FILE();
----
12,2,1001,8,9

SELECT * FROM stream WHERE a < b INTO FILE();
----
12,2,1001,8,9

SELECT * FROM stream WHERE a <= b INTO FILE();
----
12,2,1001,8,9
12,2,1001,9,9

SELECT * FROM stream WHERE a > b INTO FILE();
----
1,3,1000,9,8

SELECT * FROM stream WHERE a >= b INTO FILE();
----
1,3,1000,9,8
12,2,1001,9,9








