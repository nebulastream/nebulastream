# name: LazyTest.test
# description: Tests for lazy parser

CREATE LOGICAL SOURCE stream(id UINT64, value UINT32, timestamp UINT16, a INT8, b INT8);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
1,3,1000,9,9
12,2,1001,9,9

CREATE LOGICAL SOURCE stringStream(textual VARSIZED, valid BOOLEAN);
CREATE PHYSICAL SOURCE FOR stringStream TYPE File;
ATTACH INLINE
this,true
definetly,false
a,true
string,false




SELECT id, value, a, b FROM stream WHERE id == UINT64(1) INTO FILE();
----
1,3,9,9

SELECT (id + UINT64(1)) AS newid, value, a, b FROM stream WHERE id == UINT64(1) AND (id + UINT64(1)) == UINT64(2) INTO FILE();
----
2,3,9,9

SELECT (id + UINT64(1)) AS newid, value, a, b FROM stream WHERE id + id == UINT64(2) INTO FILE();
----
2,3,9,9

SELECT (id + id) AS newid, value, a, b FROM stream WHERE id + id == UINT64(2) INTO FILE();
----
2,3,9,9

SELECT (id == UINT64(1)) AS boolval, value, a, b FROM stream WHERE id + id == UINT64(2) INTO FILE();
----
1,3,9,9

SELECT ((id + id) == UINT64(2)) AS boolval, value, a, b FROM stream WHERE id + id == UINT64(2) INTO FILE();
----
1,3,9,9

SELECT * FROM stringStream WHERE textual == valid INTO FILE();
----
this,true
a,true

SELECT * FROM stringStream WHERE textual == BOOLEAN(1) INTO FILE();
----
this,true
definetly,false
a,true
string,false









