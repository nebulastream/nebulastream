# name: HL7.test
# description: tests the minimal HL7 ORU_LTE input formatter
# groups: [Formatter, HL7]

# Schema flattens the ORU_LTE message into one column per top-level HL7 field
# (MSH, PID, PV1, ORC, OBR, OBX, NTE), 19 columns total. Sub-components ('^')
# and sub-sub-components ('&') are not split and land verbatim in the value.
CREATE LOGICAL SOURCE hl7Stream(
    msh_1 VARSIZED NOT NULL,
    msh_2 VARSIZED NOT NULL,
    msh_3 VARSIZED NOT NULL,
    msh_4 VARSIZED NOT NULL,
    msh_5 VARSIZED NOT NULL,
    msh_6 VARSIZED NOT NULL,
    msh_7 VARSIZED NOT NULL,
    pid_1 VARSIZED NOT NULL,
    pid_2 VARSIZED NOT NULL,
    pv1_1 VARSIZED NOT NULL,
    pv1_2 VARSIZED NOT NULL,
    orc_1 VARSIZED NOT NULL,
    orc_2 VARSIZED NOT NULL,
    obr_1 VARSIZED NOT NULL,
    obr_2 VARSIZED NOT NULL,
    obx_1 UINT64 NOT NULL,
    obx_2 VARSIZED NOT NULL,
    nte_1 UINT64 NOT NULL,
    nte_2 VARSIZED NOT NULL
);
CREATE PHYSICAL SOURCE FOR hl7Stream TYPE File SET("HL7" AS INPUT_FORMATTER.`TYPE`);
ATTACH INLINE
MSH|^~\&|sendA|recvA|20260417|ORU^LTE^ORU_LTE|m1
PID|p1|alice
PV1|v1|locA
ORC|NW|ord1
OBR|o1|test1
OBX|1|val1
NTE|10|note1
MSH|^~\&|sendB|recvB|20260418|ORU^LTE^ORU_LTE|m2
PID|p2|bob
PV1|v2|locB
ORC|NW|ord2
OBR|o2|test2
OBX|2|val2
NTE|20|note2
MSH|^~\&|sendC|recvC|20260419|ORU^LTE^ORU_LTE|m3
PID|p3|carol
PV1|v3|locC
ORC|NW|ord3
OBR|o3|test3
OBX|3|val3
NTE|30|note3
MSH

CREATE SINK obxSink(hl7Stream.obx_1 UINT64 NOT NULL, hl7Stream.obx_2 VARSIZED NOT NULL) TYPE File;
CREATE SINK patientSink(hl7Stream.pid_2 VARSIZED NOT NULL) TYPE File;
CREATE SINK mshTypeSink(hl7Stream.msh_1 VARSIZED NOT NULL, hl7Stream.msh_2 VARSIZED NOT NULL, hl7Stream.msh_6 VARSIZED NOT NULL) TYPE File;
CREATE SINK filteredSink(hl7Stream.pid_2 VARSIZED NOT NULL, hl7Stream.obx_1 UINT64 NOT NULL) TYPE File;

# Project a single field (patient name from PID.2)
SELECT pid_2 FROM hl7Stream INTO patientSink;
----
alice
bob
carol

# Project MSH.1 (the field separator itself) and MSH.2 (encoding chars) to
# verify the two special fixed-layout fields are indexed correctly, plus
# MSH.6 to verify sub-component delimiters ('^') are preserved verbatim.
SELECT msh_1, msh_2, msh_6 FROM hl7Stream INTO mshTypeSink;
----
|,^~\&,ORU^LTE^ORU_LTE
|,^~\&,ORU^LTE^ORU_LTE
|,^~\&,ORU^LTE^ORU_LTE

# Project a numeric OBX field to verify parsing of a non-string data type.
SELECT obx_1, obx_2 FROM hl7Stream INTO obxSink;
----
1,val1
2,val2
3,val3

# Filter by a numeric OBX.1 field, exercising type parsing on the filter side.
SELECT pid_2, obx_1 FROM hl7Stream WHERE obx_1 >= UINT64(2) INTO filteredSink;
----
bob,2
carol,3

# Multi-buffer test: the 100K-byte file is split across several 4KB buffers, so
# messages regularly cross buffer boundaries and are reassembled through the
# framework's spanning-tuple path. The file is generated by
# testdata/small/hl7/gen_oru_lte.py and ends with a '\nMSH' sentinel so the
# trailing content of the final buffer is empty (parser requirement).
CREATE LOGICAL SOURCE hl7Stream100K(
    msh_1 VARSIZED NOT NULL,
    msh_2 VARSIZED NOT NULL,
    msh_3 VARSIZED NOT NULL,
    msh_4 VARSIZED NOT NULL,
    msh_5 VARSIZED NOT NULL,
    msh_6 VARSIZED NOT NULL,
    msh_7 VARSIZED NOT NULL,
    pid_1 VARSIZED NOT NULL,
    pid_2 VARSIZED NOT NULL,
    pv1_1 VARSIZED NOT NULL,
    pv1_2 VARSIZED NOT NULL,
    orc_1 VARSIZED NOT NULL,
    orc_2 VARSIZED NOT NULL,
    obr_1 VARSIZED NOT NULL,
    obr_2 VARSIZED NOT NULL,
    obx_1 UINT64 NOT NULL,
    obx_2 VARSIZED NOT NULL,
    nte_1 UINT64 NOT NULL,
    nte_2 VARSIZED NOT NULL
);
CREATE PHYSICAL SOURCE FOR hl7Stream100K TYPE BlockingFile SET("HL7" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE small/hl7/oru_lte_100K.hl7

# Row count must be 652 (see gen_oru_lte.py). The second number is the
# checksum of the produced records and is inserted after the first run.
SELECT * FROM hl7Stream100K INTO Checksum();
----
652 7224320

# Projecting a single VARSIZED column and checksumming exercises field
# parsing across buffer boundaries without changing the row count.
SELECT pid_2 FROM hl7Stream100K INTO Checksum();
----
652 347539

# Projecting the numeric OBX.1 column verifies integer parsing across buffers.
SELECT obx_1 FROM hl7Stream100K INTO Checksum();
----
652 105170

# Large multi-buffer test: 1 GB file (5,924,349 messages) stressing the
# spanning-tuple machinery at scale. File generated by
# testdata/small/hl7/gen_oru_lte.py with target_bytes=1073741824 and ends
# with a '\nMSH' sentinel. All messages are now recovered â€” including those
# whose '\nMSH' delimiter split across a buffer boundary â€” thanks to the
# SpanningTupleMayContainMultipleRecords trait that opts HL7 into the
# multi-record leading/trailing spanning-tuple loop.
CREATE LOGICAL SOURCE hl7Stream1GB(
    msh_1 VARSIZED NOT NULL,
    msh_2 VARSIZED NOT NULL,
    msh_3 VARSIZED NOT NULL,
    msh_4 VARSIZED NOT NULL,
    msh_5 VARSIZED NOT NULL,
    msh_6 VARSIZED NOT NULL,
    msh_7 VARSIZED NOT NULL,
    pid_1 VARSIZED NOT NULL,
    pid_2 VARSIZED NOT NULL,
    pv1_1 VARSIZED NOT NULL,
    pv1_2 VARSIZED NOT NULL,
    orc_1 VARSIZED NOT NULL,
    orc_2 VARSIZED NOT NULL,
    obr_1 VARSIZED NOT NULL,
    obr_2 VARSIZED NOT NULL,
    obx_1 UINT64 NOT NULL,
    obx_2 VARSIZED NOT NULL,
    nte_1 UINT64 NOT NULL,
    nte_2 VARSIZED NOT NULL
);
CREATE PHYSICAL SOURCE FOR hl7Stream1GB TYPE BlockingFile SET("HL7" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/hl7/oru_lte_1GB.hl7

SELECT * FROM hl7Stream1GB INTO Checksum();
----
5924349 74312953814

SELECT pid_2 FROM hl7Stream1GB INTO Checksum();
----
5924349 3158418367

SELECT obx_1 FROM hl7Stream1GB INTO Checksum();
----
5924349 961047139
