# name: NexmarkTest.test
# description: tests general input formatter behavior
# groups: [Formatter, JSON]

CREATE LOGICAL SOURCE person(ID INT32, NAME VARSIZED, EMAIL_ADDRESS VARSIZED, CREDIT_CARD VARSIZED, CITY VARSIZED, STATE VARSIZED, TIMESTAMP UINT64, EXTRA VARSIZED);
CREATE PHYSICAL SOURCE FOR person TYPE File SET("JSON" AS PARSER.`TYPE`);
ATTACH FILE large/nexmark/person_840MB.json

CREATE LOGICAL SOURCE jsonStream(KEY UINT64, VALUE UINT64, NAME VARSIZED);
CREATE PHYSICAL SOURCE FOR jsonStream TYPE File SET("JSON" AS PARSER.`TYPE`);
ATTACH INLINE
{"KEY":1, "VALUE":1, "NAME":"john"}
{"KEY":1, "VALUE":2, "NAME":"max"}

CREATE SINK keySink(jsonStream.key UINT64) TYPE File;


SELECT EXTRA FROM person INTO Checksum();
----
4000000 59270335564






