# name: projection/Projection.test
# description: Simple map tests with an add function and NULL values in JSON output
# groups: [Projection,JSON]

CREATE LOGICAL SOURCE stream(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL, flag BOOLEAN NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
1,1,1000,true
2,1,1001,true
3,1,1002,true
4,2,2000,true
5,19,19000,false
6,20,20000,false
7,21,21000,false

CREATE LOGICAL SOURCE streamWithNull(id UINT64 NOT NULL, value UINT64, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR streamWithNull TYPE File;
ATTACH INLINE
1,1,1000
2,1,1001
3,,1002
4,2,2000
5,,19000
6,20,20000
7,21,21000

CREATE LOGICAL SOURCE multiBuffer(field_1 BOOLEAN NOT NULL, field_2 INT8 NOT NULL, field_4 INT16 NOT NULL, field_5 INT32 NOT NULL, field_6 INT64 NOT NULL, field_7 UINT8 NOT NULL, field_8 UINT16 NOT NULL, field_9 UINT32 NOT NULL, field_10 UINT64 NOT NULL, field_11 FLOAT32 NOT NULL, field_12 FLOAT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR multiBuffer TYPE File;
ATTACH INLINE
true,-128,-32768,-2147483648,-9223372036854775808,255,65535,4294967295,18446744073709551615,-340282346638528859811704183484516925440.0,-.0
false,127,32767,2147483647,9223372036854775807,0,0,0,0,340282346638528859811704183484516925440.0,.0

SELECT id FROM stream INTO File('JSON' as "SINK".OUTPUT_FORMAT);
----
{"ID":1}
{"ID":2}
{"ID":3}
{"ID":4}
{"ID":5}
{"ID":6}
{"ID":7}

SELECT * FROM stream INTO File('JSON' as "SINK".OUTPUT_FORMAT);
----
{"ID":1,"VALUE":1,"TIMESTAMP":1000,"FLAG":true}
{"ID":2,"VALUE":1,"TIMESTAMP":1001,"FLAG":true}
{"ID":3,"VALUE":1,"TIMESTAMP":1002,"FLAG":true}
{"ID":4,"VALUE":2,"TIMESTAMP":2000,"FLAG":true}
{"ID":5,"VALUE":19,"TIMESTAMP":19000,"FLAG":false}
{"ID":6,"VALUE":20,"TIMESTAMP":20000,"FLAG":false}
{"ID":7,"VALUE":21,"TIMESTAMP":21000,"FLAG":false}

SELECT * FROM multiBuffer INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"MULTIBUFFER$FIELD_1":true,"MULTIBUFFER$FIELD_2":-128,"MULTIBUFFER$FIELD_4":-32768,"MULTIBUFFER$FIELD_5":-2147483648,"MULTIBUFFER$FIELD_6":-9223372036854775808,"MULTIBUFFER$FIELD_7":255,"MULTIBUFFER$FIELD_8":65535,"MULTIBUFFER$FIELD_9":4294967295,"MULTIBUFFER$FIELD_10":18446744073709551615,"MULTIBUFFER$FIELD_11":-340282346638528859811704183484516925440.0,"MULTIBUFFER$FIELD_12":-.0}
{"MULTIBUFFER$FIELD_1":false,"MULTIBUFFER$FIELD_2":127,"MULTIBUFFER$FIELD_4":32767,"MULTIBUFFER$FIELD_5":2147483647,"MULTIBUFFER$FIELD_6":9223372036854775807,"MULTIBUFFER$FIELD_7":0,"MULTIBUFFER$FIELD_8":0,"MULTIBUFFER$FIELD_9":0,"MULTIBUFFER$FIELD_10":0,"MULTIBUFFER$FIELD_11":340282346638528859811704183484516925440.0,"MULTIBUFFER$FIELD_12":.0}

SELECT * FROM streamWithNull INTO File('JSON' as "SINK".OUTPUT_FORMAT);
----
{"ID":1,"VALUE":1,"TIMESTAMP":1000}
{"ID":2,"VALUE":1,"TIMESTAMP":1001}
{"ID":3,"VALUE":NULL,"TIMESTAMP":1002}
{"ID":4,"VALUE":2,"TIMESTAMP":2000}
{"ID":5,"VALUE":NULL,"TIMESTAMP":19000}
{"ID":6,"VALUE":20,"TIMESTAMP":20000}
{"ID":7,"VALUE":21,"TIMESTAMP":21000}
