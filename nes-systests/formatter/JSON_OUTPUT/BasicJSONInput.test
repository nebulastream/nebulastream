# name: projection/Projection.test
# description: Simple map tests with an add function and NULL values in JSON output
# groups: [Projection,JSON]

CREATE LOGICAL SOURCE stream(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL, flag BOOLEAN NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
1,1,1000,true
2,1,1001,true
3,1,1002,true
4,2,2000,true
5,19,19000,false
6,20,20000,false
7,21,21000,false

CREATE LOGICAL SOURCE streamWithNull(id UINT64 NOT NULL, value UINT64, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR streamWithNull TYPE File;
ATTACH INLINE
1,1,1000
2,1,1001
3,,1002
4,2,2000
5,,19000
6,20,20000
7,21,21000

SELECT id FROM stream INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"STREAM$ID":1}
{"STREAM$ID":2}
{"STREAM$ID":3}
{"STREAM$ID":4}
{"STREAM$ID":5}
{"STREAM$ID":6}
{"STREAM$ID":7}

SELECT * FROM stream INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"STREAM$ID":1,"STREAM$VALUE":1,"STREAM$TIMESTAMP":1000,"STREAM$FLAG":true}
{"STREAM$ID":2,"STREAM$VALUE":1,"STREAM$TIMESTAMP":1001,"STREAM$FLAG":true}
{"STREAM$ID":3,"STREAM$VALUE":1,"STREAM$TIMESTAMP":1002,"STREAM$FLAG":true}
{"STREAM$ID":4,"STREAM$VALUE":2,"STREAM$TIMESTAMP":2000,"STREAM$FLAG":true}
{"STREAM$ID":5,"STREAM$VALUE":19,"STREAM$TIMESTAMP":19000,"STREAM$FLAG":false}
{"STREAM$ID":6,"STREAM$VALUE":20,"STREAM$TIMESTAMP":20000,"STREAM$FLAG":false}
{"STREAM$ID":7,"STREAM$VALUE":21,"STREAM$TIMESTAMP":21000,"STREAM$FLAG":false}

SELECT * FROM streamWithNull INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"STREAMWITHNULL$ID":1,"STREAMWITHNULL$VALUE":1,"STREAMWITHNULL$TIMESTAMP":1000}
{"STREAMWITHNULL$ID":2,"STREAMWITHNULL$VALUE":1,"STREAMWITHNULL$TIMESTAMP":1001}
{"STREAMWITHNULL$ID":3,"STREAMWITHNULL$VALUE":NULL,"STREAMWITHNULL$TIMESTAMP":1002}
{"STREAMWITHNULL$ID":4,"STREAMWITHNULL$VALUE":2,"STREAMWITHNULL$TIMESTAMP":2000}
{"STREAMWITHNULL$ID":5,"STREAMWITHNULL$VALUE":NULL,"STREAMWITHNULL$TIMESTAMP":19000}
{"STREAMWITHNULL$ID":6,"STREAMWITHNULL$VALUE":20,"STREAMWITHNULL$TIMESTAMP":20000}
{"STREAMWITHNULL$ID":7,"STREAMWITHNULL$VALUE":21,"STREAMWITHNULL$TIMESTAMP":21000}
