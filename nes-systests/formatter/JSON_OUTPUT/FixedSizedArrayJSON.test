# name: FixedSizedArrayJSON.test
# description: Round-trips a fixed-size array column from JSON input through the NestedJSON parser, the FIXEDSIZED indirect-storage path, and the JSON output formatter.
# groups: [Formatter, JSON]

CREATE LOGICAL SOURCE thermalFrames(`timestamp` UINT64 NOT NULL, `camera_id` UINT32 NOT NULL, `image` UINT16 ARRAY[16] NOT NULL);
CREATE PHYSICAL SOURCE FOR thermalFrames TYPE File SET('NestedJSON' AS `PARSER`.`TYPE`);
ATTACH INLINE
{"timestamp": 1714060800000, "camera_id": 1, "image": [30100, 30180, 30220, 30150, 30210, 41900, 52400, 30260, 30230, 53100, 65535, 30290, 30170, 30240, 30205, 30130]}
{"timestamp": 1714060800040, "camera_id": 1, "image": [30120, 30200, 30240, 30160, 30230, 42150, 52900, 30270, 30250, 53600, 65535, 30310, 30190, 30260, 30225, 30150]}

SELECT * FROM thermalFrames INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"THERMALFRAMES$timestamp":1714060800000,"THERMALFRAMES$camera_id":1,"THERMALFRAMES$image":[30100,30180,30220,30150,30210,41900,52400,30260,30230,53100,65535,30290,30170,30240,30205,30130]}
{"THERMALFRAMES$timestamp":1714060800040,"THERMALFRAMES$camera_id":1,"THERMALFRAMES$image":[30120,30200,30240,30160,30230,42150,52900,30270,30250,53600,65535,30310,30190,30260,30225,30150]}

## Smaller arrays of different element types — verifies the per-elementType
## dispatch in JSONOutputFormatter::writeFixedSizedAsJsonArray.
## NOTE: FLOAT64 elements only round-trip values that are exact in IEEE-754
## binary; inexact doubles like 3.14 currently lose precision through the
## RawValueParser FIXEDSIZED trace path (3.14 -> 3.139999). All values here
## are exact (1.5, -2.25, 0.0, -0.0).
CREATE LOGICAL SOURCE mixedArrays(`id` UINT64 NOT NULL, `floats` FLOAT64 ARRAY[3] NOT NULL, `signed` INT16 ARRAY[2] NOT NULL);
CREATE PHYSICAL SOURCE FOR mixedArrays TYPE File SET('NestedJSON' AS `PARSER`.`TYPE`);
ATTACH INLINE
{"id": 1, "floats": [1.5, -2.25, 0.0], "signed": [-1, 32767]}
{"id": 2, "floats": [0.5, 0.0, -0.0], "signed": [-32768, 0]}

SELECT * FROM mixedArrays INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"MIXEDARRAYS$id":1,"MIXEDARRAYS$floats":[1.5,-2.25,0.0],"MIXEDARRAYS$signed":[-1,32767]}
{"MIXEDARRAYS$id":2,"MIXEDARRAYS$floats":[0.5,0.0,-0.0],"MIXEDARRAYS$signed":[-32768,0]}
