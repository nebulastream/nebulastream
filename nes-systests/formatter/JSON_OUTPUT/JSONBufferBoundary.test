# name: formatter/JSON_OUTPUT/JSONBufferBoundary.test
# description: JSON whole-record fast path (JSONOutputFormatter::tryWriteRecordAllPassthrough) must emit
# byte-exact output when records straddle the output-buffer boundary. A tiny operator_buffer_size makes
# most records approach the boundary, so records that no longer fit the whole-record reservation take the
# per-field boundary/spill fallback -- the path the fit-check reservation must route them to. All-integer
# NOT NULL fields keep the JSON a raw passthrough of the input digits, so the expected output is exact.
# Guards the reservation + fallback routing (the fix that added glueTotal to the fit-check): a regression
# that mis-sizes the reservation or breaks the fallback would corrupt the output here. NOTE the original
# refcount-corruption crash was silent-in-output and only reproduced by the worker at scale (31M rows,
# real file source) with operator_buffer_size == the pool buffer size; the embedded systest backend does
# not churn pool buffers the same way, so this test gates correctness/routing, not that specific crash.
# groups: [Formatter,JSON]

# 256-byte output buffers put most records at/over the whole-record fit-check boundary.
GlobalConfiguration worker.default_query_execution.operator_buffer_size: [256]

CREATE LOGICAL SOURCE bufbnd(ts UINT64 NOT NULL, a INT32 NOT NULL, b INT64 NOT NULL, c UINT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR bufbnd TYPE File;
