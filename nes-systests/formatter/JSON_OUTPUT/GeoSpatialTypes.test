# name: GeoSpatialTypes.test
# description: Exercises the GeoSpatial DataType plugins (Point, Line, Circle).
# groups: [Formatter, JSON, Geospatial]

CREATE LOGICAL SOURCE geo(x1 FLOAT64 NOT NULL, y1 FLOAT64 NOT NULL, x2 FLOAT64 NOT NULL, y2 FLOAT64 NOT NULL, r FLOAT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR geo TYPE File;
ATTACH INLINE
1.0,2.0,10.0,20.0,5.0
3.0,4.0,30.0,40.0,1.5
0.0,0.0,-1.0,-2.0,7.25

# Show a Point built from two FLOAT64 columns.
SELECT Point(x1, y1) AS p FROM geo INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"P":{"x":1.0,"y":2.0}}
{"P":{"x":3.0,"y":4.0}}
{"P":{"x":0.0,"y":0.0}}

# Show a Line Ax + By + C = 0 built from two columns and a literal.
SELECT Line(x1, y1, FLOAT64(1.0)) AS l FROM geo INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"L":{"A":1.0,"B":2.0,"C":1.0}}
{"L":{"A":3.0,"B":4.0,"C":1.0}}
{"L":{"A":0.0,"B":0.0,"C":1.0}}

# Show a Circle type consisting built 3 columns. Circle itself contains another plugin datatype, point, as first field type.
SELECT Circle(Point(x1, y1), r) AS c FROM geo INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"C":{"center":{"x":1.0,"y":2.0},"radius":5.0}}
{"C":{"center":{"x":3.0,"y":4.0},"radius":1.5}}
{"C":{"center":{"x":0.0,"y":0.0},"radius":7.25}}

# Point + Point dispatches to the Add_Point_Point PhysicalFunction (pairwise field add: x+x, y+y)
SELECT Point(x1, y1) + Point(x2, y2) AS addedpoint FROM geo INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"ADDEDPOINT":{"x":11.0,"y":22.0}}
{"ADDEDPOINT":{"x":33.0,"y":44.0}}
{"ADDEDPOINT":{"x":-1.0,"y":-2.0}}

# circle_area(Circle) dispatches to CircleAreaPhysicalFunction, which reads the `radius` field out of the (nested) Circle STRUCT and returns pi * r^2 as FLOAT64.
SELECT circle_area(Circle(Point(x1, y1), r)) AS area FROM geo INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"AREA":78.539816}
{"AREA":7.068583}
{"AREA":165.129964}

# circle_circumference(Circle) dispatches to CircleCircumferencePhysicalFunction, which reads the `radius` field out of the (nested) Circle STRUCT and returns 2 * pi * r as FLOAT64.
SELECT circle_circumference(Circle(Point(x1, y1), r)) AS circumference FROM geo INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"CIRCUMFERENCE":31.415927}
{"CIRCUMFERENCE":9.424778}
{"CIRCUMFERENCE":45.553093}

# point_circle_contains(Point, Circle) dispatches to PointCircleContainsPhysicalFunction, which returns a BOOLEAN: true if the point lies within (distance to center <= radius) the circle.
SELECT point_circle_contains(Point(x2, y2), Circle(Point(x1, y1), r)) AS contained FROM geo INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"CONTAINED":false}
{"CONTAINED":false}
{"CONTAINED":true}

# A point at the circle's own center is always contained (distance 0 <= radius).
SELECT point_circle_contains(Point(x1, y1), Circle(Point(x1, y1), r)) AS contained FROM geo INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"CONTAINED":true}
{"CONTAINED":true}
{"CONTAINED":true}

# point_line_contains(Point, Line) dispatches to PointLineContainsPhysicalFunction, which
# returns a BOOLEAN: true iff A*x + B*y + C == 0 for the candidate point against the line.
# The line is built as Line(x1, y1, 1.0), so A=x1, B=y1, C=1.0.
# The candidate point is the literal (1, -1):
#   row 1: 1*1 + 2*(-1) + 1 = 0           -> true
#   row 2: 3*1 + 4*(-1) + 1 = 0           -> true
#   row 3: 0*1 + 0*(-1) + 1 = 1           -> false (degenerate line, never satisfied)
SELECT point_line_contains(Point(FLOAT64(1.0), FLOAT64(-1.0)), Line(x1, y1, FLOAT64(1.0))) AS onLine FROM geo INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"ONLINE":true}
{"ONLINE":true}
{"ONLINE":false}

