# name: JoinedReadingStruct.test
# description: Builds a custom STRUCT (`Reading`) from member data sourced across two physically different sensor streams. The thermometer stream is a minimal 3-column reading; the hygrometer stream carries extra metadata (battery, uptime) that is irrelevant to the constructed struct. A windowed event-time JOIN aligns records by sensor/device id, and the type-constructor `Reading(celsius, humidity_pct)` pulls just the relevant subset of each stream's fields into the nominal Reading struct. The constructed value flows through the JSON output formatter as a regular STRUCT.
# groups: [Formatter, JSON, Join]

# Thermometer: a minimal sensor stream. Only `celsius` ever contributes to a
# Reading; `sensor_id` is the join key and `ts` drives the window.
CREATE LOGICAL SOURCE thermometer(sensor_id UINT64 NOT NULL, celsius FLOAT64 NOT NULL, ts UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR thermometer TYPE File;
ATTACH INLINE
1,23.5,100
2,24.0,200
3,25.5,300

SELECT Reading(celsius, FLOAT64(60.5)) AS reading FROM thermometer WHERE Reading(celsius, FLOAT64(60.5)) = Reading(FLOAT64(23.5), FLOAT64(60.5)) INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"READING":{"temperature":23.5,"humidity":60.5}}

SELECT Reading(celsius, FLOAT64(60.5)) AS reading FROM thermometer WHERE Reading(celsius, FLOAT64(60.5)) > Reading(FLOAT64(23.5), FLOAT64(60.5)) INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"READING":{"temperature":24.0,"humidity":60.5}}
{"READING":{"temperature":25.5,"humidity":60.5}}
