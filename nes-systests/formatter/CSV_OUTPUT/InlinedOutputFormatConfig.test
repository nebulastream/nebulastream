# name: OutputFormatConfig.test
# description: tests the output formatter configuration
# groups: [Formatter, CSV]

CREATE LOGICAL SOURCE csvSource(textdata VARSIZED);

CREATE PHYSICAL SOURCE FOR csvSource TYPE File SET('CSV' AS "INPUT_FORMATTER"."TYPE");
ATTACH INLINE
This
is
a
test
quoted "string"

SELECT * FROM csvSource INTO File('CSV' as "SINK".OUTPUT_FORMAT, TRUE as "INPUT_FORMATTER".QUOTE_STRINGS);
----
"This"
"is"
"a"
"test"
"quoted ""string"""

SELECT * FROM csvSource INTO File('CSV' as "SINK".OUTPUT_FORMAT, FALSE as "INPUT_FORMATTER".QUOTE_STRINGS);
----
This
is
a
test
quoted "string"
