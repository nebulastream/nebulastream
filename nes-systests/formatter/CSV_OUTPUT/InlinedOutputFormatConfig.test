# name: OutputFormatConfig.test
# description: tests the output formatter configuration
# groups: [Formatter, CSV]

CREATE LOGICAL SOURCE csvSource(textdata VARSIZED);
CREATE LOGICAL SOURCE floatSource(val1 FLOAT32, val2 FLOAT64);

CREATE PHYSICAL SOURCE FOR csvSource TYPE File SET("CSV" AS `PARSER`.`TYPE`);
ATTACH INLINE
This
is
a
test
quoted "string"

CREATE PHYSICAL SOURCE FOR floatSource TYPE File SET("CSV" AS `PARSER`.`TYPE`);
ATTACH INLINE
42.42,65.1515151527
9.0,99.999999999

SELECT * FROM csvSource INTO File('CSV' as `SINK`.OUTPUT_FORMAT, TRUE as `PARSER`.QUOTE_STRINGS);
----
"This"
"is"
"a"
"test"
"quoted ""string"""

SELECT * FROM csvSource INTO File('CSV' as `SINK`.OUTPUT_FORMAT, FALSE as `PARSER`.QUOTE_STRINGS);
----
This
is
a
test
quoted "string"

SELECT * FROM floatSource INTO File('CSV' as `SINK`.OUTPUT_FORMAT, 'ZMIJF32' as `PARSER`.F32_PARSER, 'ZMIJF64' as `PARSER`.F64_PARSER);
----
42.42,65.1515151527
9.0,99.999999999
