# name: OutputFormatConfig.test
# description: tests the output formatter configuration
# groups: [Formatter, CSV]

CREATE LOGICAL SOURCE csvSource(textdata VARSIZED);
CREATE LOGICAL SOURCE floatSource(val1 FLOAT32, val2 FLOAT64);

CREATE PHYSICAL SOURCE FOR csvSource TYPE File SET("CSV" AS `INPUT_FORMATTER`.`TYPE`);
ATTACH INLINE
This
is
a
test
quoted "string"

CREATE PHYSICAL SOURCE FOR floatSource TYPE File SET("CSV" AS `INPUT_FORMATTER`.`TYPE`, "FastFloatF32" AS `INPUT_FORMATTER`.F32_PARSER,  "FastFloatF64" AS `INPUT_FORMATTER`.F64_PARSER);
ATTACH INLINE
42.42,65.1515151527
9.0,99.999999999

SELECT * FROM csvSource INTO File('CSV' as `SINK`.OUTPUT_FORMAT, TRUE as `OUTPUT_FORMATTER`.QUOTE_STRINGS);
----
"This"
"is"
"a"
"test"
"quoted ""string"""

SELECT * FROM csvSource INTO File('CSV' as `SINK`.OUTPUT_FORMAT, FALSE as `OUTPUT_FORMATTER`.QUOTE_STRINGS);
----
This
is
a
test
quoted "string"

SELECT * FROM floatSource INTO File('CSV' as `SINK`.OUTPUT_FORMAT, 'ZMIJF32' as `OUTPUT_FORMATTER`.F32_PARSER, 'ZMIJF64' as `OUTPUT_FORMATTER`.F64_PARSER);
----
42.42,65.1515151527
9.0,99.999999999

# Examples for uncompiled output formatter:
# Explicitly set OUTPUT_FORMAT to NATIVE
SELECT * from floatSource INTO File('NATIVE' as `SINK`.OUTPUT_FORMAT, 'CSV' as `SINK`.LEGACY_OUTPUT_FORMAT);
----
42.42,65.1515151527
9.0,99.999999999

# Checksum reflects the ZMIJ shortest-form float output the legacy CSVFormat now emits (byte-identical to
# the compiled ZMIJ output parser, e.g. 4.242e+01) -- was 1433 for the old lossy formatFloat serializer.
SELECT * from floatSource INTO CHECKSUM('NATIVE' as `SINK`.OUTPUT_FORMAT, 'CSV' as `SINK`.LEGACY_OUTPUT_FORMAT);
----
2 2717

