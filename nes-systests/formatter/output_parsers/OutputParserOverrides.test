# name: output_parsers/OutputParserOverrides.test
# description: Tests the output_parsers config parameter to adjust the output parser types for specific datatypes
# groups: [Formatter]

GlobalConfiguration worker.default_query_execution.operator_buffer_size: [4096]

CREATE LOGICAL SOURCE multiBuffer(field_1 BOOLEAN NOT NULL, field_2 INT8 NOT NULL, field_4 INT16 NOT NULL, field_5 INT32 NOT NULL, field_6 INT64 NOT NULL, field_7 UINT8 NOT NULL, field_8 UINT16 NOT NULL, field_9 UINT32 NOT NULL, field_10 UINT64 NOT NULL, field_11 FLOAT32 NOT NULL, field_12 FLOAT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR multiBuffer TYPE File;
ATTACH INLINE
true,-128,-32768,-2147483648,-9223372036854775808,255,65535,4294967295,18446744073709551615,-340282346638528859811704183484516925440.0,-.0
false,127,32767,2147483647,9223372036854775807,0,0,0,0,340282346638528859811704183484516925440.0,.0

# Description: Check that the formatter supports all basic types.
# Sets: true/false for bool, lower/uppercase for char and min/max values for integers/floats
SELECT * FROM multiBuffer INTO FILE('BOOLEAN:DefaultBOOL,INT8:DefaultINT8,INT16:DefaultINT16,INT32:DefaultINT32,INT64:DefaultINT64,UINT8:DefaultUINT8,UINT16:DefaultUINT16,UINT32:DefaultUINT32,UINT64:DefaultUINT64,FLOAT32:DefaultF32,FLOAT64:DefaultF64' as "OUTPUT_FORMATTER".OUTPUT_PARSERS);
----
true,-128,-32768,-2147483648,-9223372036854775808,255,65535,4294967295,18446744073709551615,-340282346638528859811704183484516925440.0,-.0
false,127,32767,2147483647,9223372036854775807,0,0,0,0,340282346638528859811704183484516925440.0,.0
