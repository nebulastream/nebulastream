# name: differential/HighAnionGapEquivalence.test
# description: Differential equivalence between the stateful HighAnionGap UDF and
#              the SQL pivot-and-threshold replacement. Both sides project the
#              set of patient_ids whose lab-value combination crosses the
#              high-anion-gap threshold under the given input. The UDF emits a
#              non-deterministic alert string with wall-clock timestamps; this
#              test sidesteps that by projecting only the triggering patient ID,
#              which is deterministic and what the SQL replacement actually
#              needs to match. Triggering set under the input: {1002, 1008, 1009}.
#
# Threshold (matches HighAnionGapPhysicalFunction.hpp:113 and the SQL replacement):
#   ph < 7.3 AND abec < -3.0 AND (natrium - chlorid - hco3) > 12
#
# State caveat: the UDF's StaticSharedDiffState is process-global; only the
# first side of the differential pair calls it, so state pollution can't affect
# the SQL side.
# groups: [Differential, retrospective-study, NullHandling, WindowOperators]

CREATE LOGICAL SOURCE odbc_source_35(
    LabVal_ID INT32 NOT NULL,
    mlife_PID INT32 NOT NULL,
    mlife_FallNr INT32 NOT NULL,
    Zeitpunkt UINT64 NOT NULL,
    GruppenNr INT32 NOT NULL,
    Gruppe VARSIZED,
    Bez VARSIZED,
    Wert VARSIZED,
    Einheit VARSIZED,
    Wertebereich VARSIZED,
    SampleNr VARSIZED,
    TSFail UINT64 NOT NULL,
    TSLog UINT64 NOT NULL,
    Lab_ID INT32 NOT NULL
);

# Same patient scenarios as HighAnionGapSql.test:
#   1002, 1008, 1009 trigger; 1003 (pH≥7.3), 1004 (HCO3 missing),
#   1005 (boundary pH), 1006 (boundary abec), 1007 (boundary anion gap) don't.
CREATE PHYSICAL SOURCE FOR odbc_source_35 TYPE File;
ATTACH INLINE
1,1002,1,1000,2,Blutgase arteriell,PH,5.0,mg/dL,0.6-1.2,S002,1705308300,1705311000,102
2,1002,1,1000,2,Blutgase arteriell,ABEc,-10.0,mg/dL,0.6-1.2,S002,1705308300,1705311000,102
3,1002,1,1000,2,Blutgase arteriell,NATRIUM(BG),20.0,mg/dL,0.6-1.2,S002,1705308300,1705311000,102
