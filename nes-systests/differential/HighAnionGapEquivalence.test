38,1009,8,6000,2,Blutgase arteriell,CHLORID(BG),105.0,mg/dL,0.6-1.2,S002,1705308300,1705311000,102
39,1009,8,6000,2,Blutgase arteriell,HCO3,18.0,mg/dL,0.6-1.2,S002,1705308300,1705311000,102

CREATE SINK patientSink(patient_id INT32 NOT NULL) TYPE File;

# Side A: stateful UDF. The UDF accumulates per-patient state from MLIFE_PID,
# BEZ, ZEITPUNKT, TSFAIL, TSLOG read directly out of the record (side-channel,
# not via the function argument). Returns a non-empty alert string only on the
# row that completes the 5-measurement set with timestamps aligned and the
# threshold met. Project mlife_PID for those rows.
SELECT mlife_PID AS patient_id
FROM odbc_source_35
WHERE Gruppe == VARSIZED("Blutgase arteriell")
  AND (Bez == VARSIZED("PH") OR Bez == VARSIZED("ABEc") OR Bez == VARSIZED("NATRIUM(BG)") OR Bez == VARSIZED("CHLORID(BG)") OR Bez == VARSIZED("HCO3"))
  AND HighAnionGap(VarSizedToDouble(Wert)) != VARSIZED("")
INTO patientSink;
====
# Side B: SQL pivot-and-threshold replacement, identical to HighAnionGapSql.test
# but projecting only patient_id so the result shapes line up with side A.
SELECT patient_id FROM (
    SELECT
        mlife_PID AS patient_id,
        MAX(value_or_null(Bez == VARSIZED("PH"),          VarSizedToDouble(Wert))) AS ph,
        MAX(value_or_null(Bez == VARSIZED("ABEc"),        VarSizedToDouble(Wert))) AS abec,
        MAX(value_or_null(Bez == VARSIZED("NATRIUM(BG)"), VarSizedToDouble(Wert))) AS natrium,
        MAX(value_or_null(Bez == VARSIZED("CHLORID(BG)"), VarSizedToDouble(Wert))) AS chlorid,
        MAX(value_or_null(Bez == VARSIZED("HCO3"),        VarSizedToDouble(Wert))) AS hco3
    FROM odbc_source_35
    WHERE Gruppe == VARSIZED("Blutgase arteriell")
    GROUP BY mlife_PID
    WINDOW TUMBLING(Zeitpunkt, SIZE 1 MS)
)
WHERE ph < FLOAT64(7.3)
  AND FLOAT64(0) - abec > FLOAT64(3.0)
  AND natrium - chlorid - hco3 > FLOAT64(12)
INTO patientSink;
