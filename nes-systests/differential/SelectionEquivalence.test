# name: differential/SelectionEquivalence.test
# description: Ensure differential queries agree for logically equivalent selections
# groups: [Differential, Selection]

CREATE LOGICAL SOURCE stream(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE Generator SET(
    1 AS "SOURCE".SEED,
    'ALL' as "SOURCE".STOP_GENERATOR_WHEN_SEQUENCE_FINISHES,
    'SEQUENCE UINT64 1 2001 10, SEQUENCE UINT64 0 1200 6, SEQUENCE UINT64 0 1000000 5000' AS "SOURCE".GENERATOR_SCHEMA
);

CREATE SINK selectionSink(out_id UINT64 NOT NULL, out_value UINT64 NOT NULL, out_timestamp UINT64 NOT NULL) TYPE File;

SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp FROM stream WHERE value >= 10 INTO selectionSink;
====
SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp FROM stream WHERE NOT (value < 10) INTO selectionSink;

SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE value >= 10 AND value <= 100
INTO selectionSink;
====
SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE NOT (value < 10 OR value > 100)
INTO selectionSink;

SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE value <= 20 OR value >= 80
INTO selectionSink;
====
SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE NOT (value > 20 AND value < 80)
INTO selectionSink;

SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE value != 42
INTO selectionSink;
====
SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE value < 42 OR value > 42
INTO selectionSink;

SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE value >= 10 AND (id >= 1000 OR timestamp >= 1000000000)
INTO selectionSink;
====
SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE (value >= 10 AND id >= 1000)
   OR (value >= 10 AND timestamp >= 1000000000)
INTO selectionSink;

SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE (value >= 10 AND value <= 50)
  AND (id >= 100 OR timestamp >= 1000000)
INTO selectionSink;
====
SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE NOT (
    (value < 10 OR value > 50)
    OR (id < 100 AND timestamp < 1000000)
)
INTO selectionSink;

SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE value >= 90 OR (id >= 5 AND timestamp >= 100)
INTO selectionSink;
====
SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE (value >= 90 OR id >= 5)
  AND (value >= 90 OR timestamp >= 100)
INTO selectionSink;

SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE value >= 10
INTO selectionSink;
====
SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE (value >= 10 AND id >= 100)
   OR (value >= 10 AND NOT (id >= 100))
INTO selectionSink;

SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE value <= 50
INTO selectionSink;
====
SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE value <= 50 OR (value <= 50 AND id >= 1)
INTO selectionSink;

SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE (value >= 10 AND id >= 100)
   OR (value < 10 AND timestamp >= 1000)
INTO selectionSink;
====
SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE (value >= 10 AND id >= 100)
   OR (value < 10 AND timestamp >= 1000)
   OR (id >= 100 AND timestamp >= 1000)
INTO selectionSink;

SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE id <= timestamp
INTO selectionSink;
====
SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE NOT (id > timestamp)
INTO selectionSink;

SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE id != value
INTO selectionSink;
====
SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE id < value OR id > value
INTO selectionSink;


SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE (value >= 100 AND value <= 200)
   OR (id >= 1000 AND id <= 2000)
   OR (timestamp >= 10000 AND timestamp <= 20000)
INTO selectionSink;
====
SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE NOT (
    (value < 100 OR value > 200) AND
    (id < 1000 OR id > 2000) AND
    (timestamp < 10000 OR timestamp > 20000)
)
INTO selectionSink;

SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE value < 10 AND value >= 10
INTO selectionSink;
====
SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE id != id
INTO selectionSink;

SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE id = id
INTO selectionSink;
====
SELECT id AS out_id, value AS out_value, timestamp AS out_timestamp
FROM stream
WHERE value >= 0
INTO selectionSink;
