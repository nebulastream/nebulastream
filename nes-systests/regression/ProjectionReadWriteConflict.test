CREATE LOGICAL SOURCE stream(a INT64 NOT NULL, b INT64 NOT NULL, ts INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
10,100,1
20,200,2

CREATE SINK twoFieldSink(a INT64 NOT NULL, b INT64 NOT NULL, total INT64 NOT NULL, ts INT64 NOT NULL) TYPE File;

SELECT a + INT64(1) AS a, b + INT64(1) AS b, a + b AS total, ts FROM (
    SELECT a, b, ts FROM stream
) INTO twoFieldSink;
----
11,101,110,1
21,201,220,2

CREATE SINK swapSink2(a INT64 NOT NULL, b INT64 NOT NULL, diff INT64 NOT NULL, ts INT64 NOT NULL) TYPE File;

SELECT b AS a, a AS b, a - b AS diff, ts FROM stream INTO swapSink2;
----
100,10,-90,1
200,20,-180,2
