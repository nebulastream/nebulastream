# name: formatter/SequentialUncompiledOldCSVWithComma.test
# description: OldCSV quote-aware scan (allow_commas_in_strings=true) — delimiters inside double quotes are data
# groups: [Formatter]

CREATE LOGICAL SOURCE stream(text VARSIZED NOT NULL, text2 VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE BlockingFile SET( "SequentialUncompiledOldCSV" AS INPUT_FORMATTER.`TYPE`, "SEQUENTIAL" AS INPUT_FORMATTER.`THREADING_MODE`, "true" AS INPUT_FORMATTER.`ALLOW_COMMAS_IN_STRINGS`);
ATTACH FILE small/comma.csv

CREATE SINK file_sink(stream.text VARSIZED NOT NULL, stream.text2 VARSIZED NOT NULL) TYPE File;

SELECT * FROM stream INTO file_sink;
----
"a","1,2,3"
",","4,5,6"
"b","7,,8"
"c",""
"d",","
"e","18,,19"
"f","20,21,22,23,24"
"g","27,,28,29"

SELECT * FROM stream WHERE text2 == VARSIZED('","') INTO file_sink;
----
"d",","

SELECT * FROM stream WHERE text2 != VARSIZED('","') INTO file_sink;
----
"a","1,2,3"
",","4,5,6"
"b","7,,8"
"c",""
"e","18,,19"
"f","20,21,22,23,24"
"g","27,,28,29"
