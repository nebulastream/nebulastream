# name: benchmark/YahooStreamingBenchmark_10k_huge_mixed.test
# description: Mixed workload: lightweight filter + heavy aggregation running concurrently to create load imbalance
# groups: [benchmark, huge, Aggregation, Filter]

# Source for the lightweight filter query
CREATE LOGICAL SOURCE ysb_light(user_id UINT64 NOT NULL, page_id UINT64 NOT NULL, campaign_id UINT64 NOT NULL, ad_type UINT64 NOT NULL, event_type UINT64 NOT NULL, current_ms UINT64 NOT NULL, ip UINT64 NOT NULL, d1 UINT64 NOT NULL, d2 UINT64 NOT NULL, d3 UINT32 NOT NULL, d4 UINT16 NOT NULL);
CREATE PHYSICAL SOURCE FOR ysb_light TYPE File;
ATTACH FILE huge/ysb/ysb_10k_data_50000000.csv

# Source for the heavy aggregation query
CREATE LOGICAL SOURCE ysb_heavy(user_id UINT64 NOT NULL, page_id UINT64 NOT NULL, campaign_id UINT64 NOT NULL, ad_type UINT64 NOT NULL, event_type UINT64 NOT NULL, current_ms UINT64 NOT NULL, ip UINT64 NOT NULL, d1 UINT64 NOT NULL, d2 UINT64 NOT NULL, d3 UINT32 NOT NULL, d4 UINT16 NOT NULL);
CREATE PHYSICAL SOURCE FOR ysb_heavy TYPE File;
ATTACH FILE huge/ysb/ysb_10k_data_50000000.csv

# Sinks
CREATE SINK lightChecksum(ysb_light.user_id UINT64 NOT NULL, ysb_light.page_id UINT64 NOT NULL, ysb_light.campaign_id UINT64 NOT NULL, ysb_light.ad_type UINT64 NOT NULL, ysb_light.event_type UINT64 NOT NULL, ysb_light.current_ms UINT64 NOT NULL, ysb_light.ip UINT64 NOT NULL, ysb_light.d1 UINT64 NOT NULL, ysb_light.d2 UINT64 NOT NULL, ysb_light.d3 UINT32 NOT NULL, ysb_light.d4 UINT16 NOT NULL) TYPE Checksum;
CREATE SINK heavyChecksum(ysb_heavy.start UINT64 NOT NULL, ysb_heavy.end UINT64 NOT NULL, ysb_heavy.campaign_id UINT64 NOT NULL, ysb_heavy.sum_user_id UINT64 NOT NULL) TYPE Checksum;

# Query 1: Lightweight filter — fast, produces no successor tasks
SELECT *
FROM ysb_light
WHERE event_type < UINT64(1)
INTO lightChecksum;
----
0 0

# Query 2: Heavy aggregation with 10ms window — slow, produces ~5M successor tasks
SELECT
    start,
    end,
    campaign_id,
    SUM(user_id) AS sum_user_id
FROM ysb_heavy
WHERE event_type < UINT64(1)
GROUP BY campaign_id
WINDOW TUMBLING(current_ms, SIZE 10 MS)
INTO heavyChecksum;
----
0 0
