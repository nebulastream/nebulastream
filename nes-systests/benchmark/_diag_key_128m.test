# name: benchmark/_diag_key_128m.test
# description: throwaway — SELECT key (1-field projection, fnattr DCE) on the 128 MiB 5xUINT64 file,
#              SIMDCSV. Apples-to-apples 1-thread baseline vs the formatter-scaling benchmark (same data).
# groups: [Formatter, benchmark, large]
CREATE LOGICAL SOURCE csv5(creationTS UINT64 NOT NULL, key UINT64 NOT NULL, v1 UINT64 NOT NULL, v2 UINT64 NOT NULL, v3 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR csv5 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/formatter/bench_5xUINT64_128m.csv

CREATE SINK d_key(csv5.key UINT64 NOT NULL) TYPE Void;

SELECT key FROM csv5 INTO d_key;
----
