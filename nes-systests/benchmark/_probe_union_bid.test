# Union producer x worker grid on bid_6GB: P File sources (slices summing to full file) UNION'd,
# SELECT auctionId -> Checksum. io_threads=P. q1=P1 q2=P2 q3=P3 q4=P4.

CREATE LOGICAL SOURCE u1s1(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR u1s1 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/bid_6GB.csv

CREATE SINK u1_chk(u1s1.auctionId INT32 NOT NULL) TYPE Checksum;

# q1 -- P=1
SELECT auctionId FROM u1s1 INTO u1_chk;
----

CREATE LOGICAL SOURCE u2s1(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR u2s1 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_0_of_2.csv

CREATE LOGICAL SOURCE u2s2(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR u2s2 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_1_of_2.csv

CREATE SINK u2_chk(auctionId INT32 NOT NULL) TYPE Checksum;

# q2 -- P=2
SELECT auctionId FROM u2s1 UNION SELECT auctionId FROM u2s2 INTO u2_chk;
----

CREATE LOGICAL SOURCE u3s1(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR u3s1 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_0_of_3.csv

CREATE LOGICAL SOURCE u3s2(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR u3s2 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_1_of_3.csv

CREATE LOGICAL SOURCE u3s3(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR u3s3 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_2_of_3.csv

CREATE SINK u3_chk(auctionId INT32 NOT NULL) TYPE Checksum;

# q3 -- P=3
SELECT auctionId FROM u3s1 UNION SELECT auctionId FROM u3s2 UNION SELECT auctionId FROM u3s3 INTO u3_chk;
----

CREATE LOGICAL SOURCE u4s1(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR u4s1 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_0_of_4.csv

CREATE LOGICAL SOURCE u4s2(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR u4s2 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_1_of_4.csv

CREATE LOGICAL SOURCE u4s3(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR u4s3 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_2_of_4.csv

CREATE LOGICAL SOURCE u4s4(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR u4s4 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_3_of_4.csv

CREATE SINK u4_chk(auctionId INT32 NOT NULL) TYPE Checksum;

# q4 -- P=4
SELECT auctionId FROM u4s1 UNION SELECT auctionId FROM u4s2 UNION SELECT auctionId FROM u4s3 UNION SELECT auctionId FROM u4s4 INTO u4_chk;
----
