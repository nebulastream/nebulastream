# InMemory BLOB-mode UNION high-producer scan (NO NES_INMEM_PREFILL): normal getBufferBlocking+memcpy path.
# Does the honest InMem path plateau ~16, or keep climbing? io_threads=P, W=16. q1=P4 q2=P6 q3=P8.

CREATE LOGICAL SOURCE n4s0(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR n4s0 TYPE InMemory SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_0_of_4.csv

CREATE LOGICAL SOURCE n4s1(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR n4s1 TYPE InMemory SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_1_of_4.csv

CREATE LOGICAL SOURCE n4s2(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR n4s2 TYPE InMemory SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_2_of_4.csv

CREATE LOGICAL SOURCE n4s3(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR n4s3 TYPE InMemory SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_3_of_4.csv

CREATE SINK n4_chk(auctionId INT32 NOT NULL) TYPE Checksum;

# q1 -- P=4
SELECT auctionId FROM n4s0 UNION SELECT auctionId FROM n4s1 UNION SELECT auctionId FROM n4s2 UNION SELECT auctionId FROM n4s3 INTO n4_chk;
----

