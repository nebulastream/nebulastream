# name: benchmark/FormatterUnion_N1.test
# description: Phase-0 producer-bottleneck probe. 1 File source(s) UNION'd, projecting key
#              into a Void sink, run under NES_DISABLE_EMIT with number_of_io_threads=N so each
#              source gets its own producer thread. GENERATED by run_union_bench.py.
#              Formatter: SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`, "TracedUINT64" AS INPUT_FORMATTER.`UINT64_PARSER`)
# groups: [Formatter, benchmark, large]

CREATE LOGICAL SOURCE s1(creationTS UINT64 NOT NULL, key UINT64 NOT NULL, v1 UINT64 NOT NULL, v2 UINT64 NOT NULL, v3 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR s1 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`, "TracedUINT64" AS INPUT_FORMATTER.`UINT64_PARSER`);
ATTACH FILE large/formatter/bench_5xUINT64_5g.csv

CREATE SINK u_void(s1.key UINT64 NOT NULL) TYPE Void;

SELECT key FROM s1
INTO u_void;
----
