# P=8 async File union over bid_6GB 8-way slices, SELECT auctionId -> Checksum. io_threads=8.
# Probe for the async-File DRAM/CPU ceiling (NES_FILE_REPEAT=N for a steady window).
CREATE LOGICAL SOURCE f8s0(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR f8s0 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_0_of_8.csv
CREATE LOGICAL SOURCE f8s1(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR f8s1 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_1_of_8.csv
CREATE LOGICAL SOURCE f8s2(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR f8s2 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_2_of_8.csv
CREATE LOGICAL SOURCE f8s3(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR f8s3 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_3_of_8.csv
CREATE LOGICAL SOURCE f8s4(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR f8s4 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_4_of_8.csv
CREATE LOGICAL SOURCE f8s5(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR f8s5 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_5_of_8.csv
CREATE LOGICAL SOURCE f8s6(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR f8s6 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_6_of_8.csv
CREATE LOGICAL SOURCE f8s7(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR f8s7 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_7_of_8.csv
CREATE SINK f8_chk(auctionId INT32 NOT NULL) TYPE Checksum;
SELECT auctionId FROM f8s0 UNION SELECT auctionId FROM f8s1 UNION SELECT auctionId FROM f8s2 UNION SELECT auctionId FROM f8s3 UNION SELECT auctionId FROM f8s4 UNION SELECT auctionId FROM f8s5 UNION SELECT auctionId FROM f8s6 UNION SELECT auctionId FROM f8s7 INTO f8_chk;
----
