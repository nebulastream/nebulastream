# name: benchmark/FormatterInMemory.test
# description: InMemory source (loads the whole file into RAM in its ctor, then produces from RAM so
#              the read is EXCLUDED from the systest -b window). Q1 = checksum correctness gate: must
#              equal the known File/SIMDCSV result, proving byte-identical delivery. Q2 = projVoid for
#              throughput runs (run with -b + NES_DISABLE_EMIT=1, sweep worker threads).
# groups: [Formatter, benchmark, large]

CREATE LOGICAL SOURCE mem5(creationTS UINT64 NOT NULL, key UINT64 NOT NULL, v1 UINT64 NOT NULL, v2 UINT64 NOT NULL, v3 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR mem5 TYPE InMemory SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`, "TracedUINT64" AS INPUT_FORMATTER.`UINT64_PARSER`);
ATTACH FILE large/formatter/bench_5xUINT64_5g.csv

CREATE LOGICAL SOURCE mem5s(creationTS UINT64 NOT NULL, key UINT64 NOT NULL, v1 UINT64 NOT NULL, v2 UINT64 NOT NULL, v3 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR mem5s TYPE InMemory SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`, "TracedUINT64" AS INPUT_FORMATTER.`UINT64_PARSER`);
ATTACH FILE large/formatter/bench_5xUINT64_512m.csv

# Varsized key: read column 2 as raw bytes (no integer parse) -> CSV output is a byte passthrough (no to_string)
CREATE LOGICAL SOURCE mem5v(creationTS UINT64 NOT NULL, key VARSIZED NOT NULL, v1 UINT64 NOT NULL, v2 UINT64 NOT NULL, v3 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR mem5v TYPE InMemory SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`, "TracedUINT64" AS INPUT_FORMATTER.`UINT64_PARSER`);
ATTACH FILE large/formatter/bench_5xUINT64_5g.csv

CREATE SINK mem5_projChk(mem5.key UINT64 NOT NULL) TYPE Checksum;
CREATE SINK mem5_projVoid(mem5.key UINT64 NOT NULL) TYPE Void;
CREATE SINK mem5s_projVoid(mem5s.key UINT64 NOT NULL) TYPE Void;
CREATE SINK mem5v_projChk(mem5v.key VARSIZED NOT NULL) TYPE Checksum;
CREATE SINK mem5v_projVoid(mem5v.key VARSIZED NOT NULL) TYPE Void;

# Q1 -- correctness: must match the known File/SIMDCSV checksum (FormatterThroughput.test Q2)
SELECT key FROM mem5 INTO mem5_projChk;
----
143128260, 15104504004

# Q2 -- throughput (Void sink; run under -b + NES_DISABLE_EMIT=1)
SELECT key FROM mem5 INTO mem5_projVoid;
----

# Q3 -- 512MB throughput variant (fast load; for quick A/B sweeps)
SELECT key FROM mem5s INTO mem5s_projVoid;
----

# Q4 -- Varsized key -> Checksum (parse elided; output is byte passthrough)
SELECT key FROM mem5v INTO mem5v_projChk;
----

# Q5 -- Varsized key -> Void (parse elided; no output format)
SELECT key FROM mem5v INTO mem5v_projVoid;
----

# Lazy-typed UINT64 elision: key stays UINT64 (NOT varsized), but lazy_uint_overloads=true makes the
# formatter emit a deferred (ptr,size) LazyValueRepresentation instead of parsing. A pure projection
# passthrough then writes the raw CSV bytes straight to the CSV output (no to_string), through the same
# byte-copy fast path as the varsized trick -- but without declaring the column VARSIZED, so there is no
# input-side child-buffer round-trip. Output bytes are byte-identical to the parsed path (canonical ints),
# so the checksum must still match Q1.
CREATE LOGICAL SOURCE mem5L(creationTS UINT64 NOT NULL, key UINT64 NOT NULL, v1 UINT64 NOT NULL, v2 UINT64 NOT NULL, v3 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR mem5L TYPE InMemory SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`, "TracedUINT64" AS INPUT_FORMATTER.`UINT64_PARSER`, "true" AS INPUT_FORMATTER.`LAZY_UINT_OVERLOADS`);
ATTACH FILE large/formatter/bench_5xUINT64_5g.csv

CREATE SINK mem5L_projChk(mem5L.key UINT64 NOT NULL) TYPE Checksum;
CREATE SINK mem5L_projVoid(mem5L.key UINT64 NOT NULL) TYPE Void;

# Q6 -- lazy-typed UINT64 -> Checksum: parse elided, raw-byte CSV output. Correctness must match Q1.
SELECT key FROM mem5L INTO mem5L_projChk;
----
143128260, 15104504004

# Q7 -- lazy-typed UINT64 -> Void (parse elided; no output format)
SELECT key FROM mem5L INTO mem5L_projVoid;
----

# SELECT * : all 5 UINT64 fields elided -> full-row raw-byte passthrough (index all + copy all out,
# no parse, no to_string). This is the maximal-elision case (5 fields vs 1) -- on a typed-parse branch
# it would pay 5 parses + 5 to_string per row.
CREATE SINK mem5_allChk(mem5.creationTS UINT64 NOT NULL, mem5.key UINT64 NOT NULL, mem5.v1 UINT64 NOT NULL, mem5.v2 UINT64 NOT NULL, mem5.v3 UINT64 NOT NULL) TYPE Checksum;
CREATE SINK mem5_allVoid(mem5.creationTS UINT64 NOT NULL, mem5.key UINT64 NOT NULL, mem5.v1 UINT64 NOT NULL, mem5.v2 UINT64 NOT NULL, mem5.v3 UINT64 NOT NULL) TYPE Void;

# Q8 -- SELECT * -> Checksum (all 5 fields elided, full-row byte passthrough)
SELECT * FROM mem5 INTO mem5_allChk;
----

# Q9 -- SELECT * -> Void (index all 5, no output format)
SELECT * FROM mem5 INTO mem5_allVoid;
----

# Computed (non-lazy) UINT64 columns: each sum is materialized by the kernel, so none is a lazy passthrough
# and the CSV sink must serialize all five through DefaultUINT64OutputParser (the integer output parser).
# Projecting five computed columns makes integer output serialization the dominant per-row cost (the integer
# analogue of Q1's float-compute path), so the std::to_chars-vs-to_string A/B is not diluted by input parse.
CREATE SINK mem5_sumChk(s1 UINT64 NOT NULL, s2 UINT64 NOT NULL, s3 UINT64 NOT NULL, s4 UINT64 NOT NULL, s5 UINT64 NOT NULL) TYPE Checksum;

# Q10 -- five computed UINT64 columns -> Checksum: integer-output-serialization bound
SELECT key + v1 AS s1, key + v2 AS s2, key + v3 AS s3, v1 + v2 AS s4, v1 + v3 AS s5 FROM mem5 INTO mem5_sumChk;
----

# Computed (non-lazy) FLOAT64 columns: each product is materialized by the kernel and serialized through
# DefaultF64OutputParser (formatFloatFixed6). Five computed float columns make float output serialization the
# dominant per-row cost -- the float analogue of Q10, for the parseF64 direct-write A/B.
CREATE SINK mem5_fmulChk(f1 FLOAT64 NOT NULL, f2 FLOAT64 NOT NULL, f3 FLOAT64 NOT NULL, f4 FLOAT64 NOT NULL, f5 FLOAT64 NOT NULL) TYPE Checksum;

# Q11 -- five computed FLOAT64 columns -> Checksum: float-output-serialization bound
SELECT key * FLOAT64(1.5) AS f1, v1 * FLOAT64(1.5) AS f2, v2 * FLOAT64(1.5) AS f3, v3 * FLOAT64(1.5) AS f4, creationTS * FLOAT64(1.5) AS f5 FROM mem5 INTO mem5_fmulChk;
----
