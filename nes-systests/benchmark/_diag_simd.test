# name: benchmark/_diag_simd.test
# description: throwaway — SIMDCSV variant of the _diag proj query, to A/B the SIMD indexer vs the scalar CSV indexer.
# groups: [Formatter, benchmark, large]
CREATE LOGICAL SOURCE csv5(creationTS UINT64 NOT NULL, key UINT64 NOT NULL, v1 UINT64 NOT NULL, v2 UINT64 NOT NULL, v3 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR csv5 TYPE File SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/formatter/bench_5xUINT64_5g.csv

CREATE SINK d_proj(csv5.key UINT64 NOT NULL) TYPE Void;

# projVoid through the SIMD indexer: scan+index all, parse key for every row, emit ALL ~143M rows.
SELECT key FROM csv5 INTO d_proj;
----
