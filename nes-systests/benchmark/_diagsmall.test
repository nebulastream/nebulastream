# name: benchmark/_diagsmall.test
# description: throwaway — count parses-per-row for a single-field projection (10 rows -> 10 or 50 parses?)
# groups: [Formatter, benchmark]
CREATE LOGICAL SOURCE csv5s(creationTS UINT64 NOT NULL, key UINT64 NOT NULL, v1 UINT64 NOT NULL, v2 UINT64 NOT NULL, v3 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR csv5s TYPE File SET("CSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH INLINE
