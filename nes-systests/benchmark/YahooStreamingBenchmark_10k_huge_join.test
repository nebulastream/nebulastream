# name: benchmark/YahooStreamingBenchmark_10k_huge_join.test
# description: YahooStreamingBenchmark 10k campaign_ids, 50M tuples, join on campaign_id with 1s window (multi-pipeline)
# groups: [benchmark, huge, Join]

CREATE LOGICAL SOURCE ysb_left(user_id UINT64 NOT NULL, page_id UINT64 NOT NULL, campaign_id UINT64 NOT NULL, ad_type UINT64 NOT NULL, event_type UINT64 NOT NULL, current_ms UINT64 NOT NULL, ip UINT64 NOT NULL, d1 UINT64 NOT NULL, d2 UINT64 NOT NULL, d3 UINT32 NOT NULL, d4 UINT16 NOT NULL);
CREATE PHYSICAL SOURCE FOR ysb_left TYPE File;
ATTACH FILE huge/ysb/ysb_10k_data_50000000.csv

CREATE LOGICAL SOURCE ysb_right(user_id UINT64 NOT NULL, page_id UINT64 NOT NULL, campaign_id UINT64 NOT NULL, ad_type UINT64 NOT NULL, event_type UINT64 NOT NULL, current_ms UINT64 NOT NULL, ip UINT64 NOT NULL, d1 UINT64 NOT NULL, d2 UINT64 NOT NULL, d3 UINT32 NOT NULL, d4 UINT16 NOT NULL);
CREATE PHYSICAL SOURCE FOR ysb_right TYPE File;
ATTACH FILE huge/ysb/ysb_10k_data_50000000.csv

CREATE SINK joinChecksum(left_cidright_cid.start UINT64 NOT NULL, left_cidright_cid.end UINT64 NOT NULL, left_cid UINT64 NOT NULL, left_uid UINT64 NOT NULL, ysb_left.current_ms UINT64 NOT NULL, right_cid UINT64 NOT NULL, right_uid UINT64 NOT NULL, ysb_right.current_ms UINT64 NOT NULL) TYPE Checksum;

SELECT *
FROM (SELECT campaign_id AS left_cid, user_id AS left_uid, current_ms FROM ysb_left)
INNER JOIN
    (SELECT campaign_id AS right_cid, user_id AS right_uid, current_ms FROM ysb_right)
ON left_cid = right_cid WINDOW TUMBLING (current_ms, SIZE 1 SEC) INTO joinChecksum;
----
0 0
