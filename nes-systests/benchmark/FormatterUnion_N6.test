# name: benchmark/FormatterUnion_N6.test
# description: Phase-0 producer-bottleneck probe. 6 File source(s) UNION'd, projecting key
#              into a Void sink, run under NES_DISABLE_EMIT with number_of_io_threads=N so each
#              source gets its own producer thread. GENERATED by run_union_bench.py.
# groups: [Formatter, benchmark, large]

CREATE LOGICAL SOURCE s1(creationTS UINT64 NOT NULL, key UINT64 NOT NULL, v1 UINT64 NOT NULL, v2 UINT64 NOT NULL, v3 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR s1 TYPE File SET("CSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/formatter/slices/n6/slice_0_of_6.csv

CREATE LOGICAL SOURCE s2(creationTS UINT64 NOT NULL, key UINT64 NOT NULL, v1 UINT64 NOT NULL, v2 UINT64 NOT NULL, v3 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR s2 TYPE File SET("CSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/formatter/slices/n6/slice_1_of_6.csv

CREATE LOGICAL SOURCE s3(creationTS UINT64 NOT NULL, key UINT64 NOT NULL, v1 UINT64 NOT NULL, v2 UINT64 NOT NULL, v3 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR s3 TYPE File SET("CSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/formatter/slices/n6/slice_2_of_6.csv

CREATE LOGICAL SOURCE s4(creationTS UINT64 NOT NULL, key UINT64 NOT NULL, v1 UINT64 NOT NULL, v2 UINT64 NOT NULL, v3 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR s4 TYPE File SET("CSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/formatter/slices/n6/slice_3_of_6.csv

CREATE LOGICAL SOURCE s5(creationTS UINT64 NOT NULL, key UINT64 NOT NULL, v1 UINT64 NOT NULL, v2 UINT64 NOT NULL, v3 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR s5 TYPE File SET("CSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/formatter/slices/n6/slice_4_of_6.csv

CREATE LOGICAL SOURCE s6(creationTS UINT64 NOT NULL, key UINT64 NOT NULL, v1 UINT64 NOT NULL, v2 UINT64 NOT NULL, v3 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR s6 TYPE File SET("CSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/formatter/slices/n6/slice_5_of_6.csv

CREATE SINK u_void(key UINT64 NOT NULL) TYPE Void;

SELECT key FROM s1
UNION
SELECT key FROM s2
UNION
SELECT key FROM s3
UNION
SELECT key FROM s4
UNION
SELECT key FROM s5
UNION
SELECT key FROM s6
INTO u_void;
