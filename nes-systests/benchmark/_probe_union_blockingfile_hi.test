# BlockingFile UNION high-producer scan to find the plateau. SIMDCSV->Checksum, io_threads=P, W=16.
# q1=P6 q2=P8 q3=P12 q4=P16. Slices: slice_i_of_P.csv. Run --repeat N, post-plateau mean.

CREATE LOGICAL SOURCE h6s0(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR h6s0 TYPE BlockingFile SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_0_of_6.csv

CREATE LOGICAL SOURCE h6s1(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR h6s1 TYPE BlockingFile SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_1_of_6.csv

CREATE LOGICAL SOURCE h6s2(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR h6s2 TYPE BlockingFile SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_2_of_6.csv

CREATE LOGICAL SOURCE h6s3(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR h6s3 TYPE BlockingFile SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_3_of_6.csv

CREATE LOGICAL SOURCE h6s4(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR h6s4 TYPE BlockingFile SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_4_of_6.csv

CREATE LOGICAL SOURCE h6s5(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price INT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR h6s5 TYPE BlockingFile SET("SIMDCSV" AS INPUT_FORMATTER.`TYPE`);
ATTACH FILE large/nexmark/uslices/slice_5_of_6.csv

CREATE SINK h6_chk(auctionId INT32 NOT NULL) TYPE Checksum;

# q1 -- P=6
SELECT auctionId FROM h6s0 UNION SELECT auctionId FROM h6s1 UNION SELECT auctionId FROM h6s2 UNION SELECT auctionId FROM h6s3 UNION SELECT auctionId FROM h6s4 UNION SELECT auctionId FROM h6s5 INTO h6_chk;
----

