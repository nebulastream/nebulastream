CREATE SINK alertSink(alert VARSIZED) TYPE File;

# value_or_null(predicate, value) → value when the predicate is true, NULL otherwise.
# MAX over the window drops the NULLs (skip-null aggregation), leaving the one
# matching value per Bez. The middle SELECT then applies the threshold predicate.
# The outer SELECT renders the alert string with FMT, mimicking the UDF's text.
# Numeric values render via std::to_chars shortest round-trip — integral values
# like 5.0 emit as "5", consistent with the UDF's output.
# FLOAT64(0) - abec > FLOAT64(3.0) is the workaround for negative-literal parsing
# (see docs/bugs/negative_float_constant.md / nebulastream issue #1572).
SELECT FMT(
    VARSIZED("High anion gap detected for patient {}. Reason: if( ( PH({}) < 7.3) AND (Base Excess({}) < -3.0) AND (Sodium({}) - Chloride({}) - Bicarbonate({}) > 12))"),
    patient_id, ph, abec, natrium, chlorid, hco3
) AS alert
FROM (
    SELECT patient_id, ph, abec, natrium, chlorid, hco3
    FROM (
        SELECT
            mlife_PID AS patient_id,
            MAX(value_or_null(Bez == VARSIZED("PH"),          VarSizedToDouble(Wert))) AS ph,
            MAX(value_or_null(Bez == VARSIZED("ABEc"),        VarSizedToDouble(Wert))) AS abec,
            MAX(value_or_null(Bez == VARSIZED("NATRIUM(BG)"), VarSizedToDouble(Wert))) AS natrium,
            MAX(value_or_null(Bez == VARSIZED("CHLORID(BG)"), VarSizedToDouble(Wert))) AS chlorid,
            MAX(value_or_null(Bez == VARSIZED("HCO3"),        VarSizedToDouble(Wert))) AS hco3
        FROM odbc_source_35
        WHERE Gruppe == VARSIZED("Blutgase arteriell")
        GROUP BY mlife_PID
        WINDOW TUMBLING(Zeitpunkt, SIZE 1 MS)
    )
    WHERE ph < FLOAT64(7.3)
      AND FLOAT64(0) - abec > FLOAT64(3.0)
      AND natrium - chlorid - hco3 > FLOAT64(12)
)
INTO alertSink;
----
High anion gap detected for patient 1002. Reason: if( ( PH(5) < 7.3) AND (Base Excess(-10) < -3.0) AND (Sodium(20) - Chloride(2) - Bicarbonate(2) > 12))
High anion gap detected for patient 1008. Reason: if( ( PH(7.1) < 7.3) AND (Base Excess(-4) < -3.0) AND (Sodium(145) - Chloride(105) - Bicarbonate(20) > 12))
High anion gap detected for patient 1009. Reason: if( ( PH(7.29) < 7.3) AND (Base Excess(-3.1) < -3.0) AND (Sodium(150) - Chloride(105) - Bicarbonate(18) > 12))
