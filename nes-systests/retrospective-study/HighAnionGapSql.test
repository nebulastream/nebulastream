CREATE SINK alertSink(window_start UINT64 NOT NULL, window_end UINT64 NOT NULL, patient_id INT32 NOT NULL, ph FLOAT64, abec FLOAT64, natrium FLOAT64, chlorid FLOAT64, hco3 FLOAT64) TYPE File;

# value_or_null(predicate, value) → value when the predicate is true, NULL otherwise.
# MAX over the window drops the NULLs (skip-null aggregation), leaving the one
# matching value per Bez. The outer SELECT then applies the threshold predicate.
# FLOAT64(0) - abec > FLOAT64(3.0) is the workaround for negative-literal parsing
# (see docs/bugs/negative_float_constant.md / nebulastream issue #1572).
SELECT window_start, window_end, patient_id, ph, abec, natrium, chlorid, hco3
FROM (
    SELECT
        start AS window_start,
        end AS window_end,
        mlife_PID AS patient_id,
        MAX(value_or_null(Bez == VARSIZED("PH"),          VarSizedToDouble(Wert))) AS ph,
        MAX(value_or_null(Bez == VARSIZED("ABEc"),        VarSizedToDouble(Wert))) AS abec,
        MAX(value_or_null(Bez == VARSIZED("NATRIUM(BG)"), VarSizedToDouble(Wert))) AS natrium,
        MAX(value_or_null(Bez == VARSIZED("CHLORID(BG)"), VarSizedToDouble(Wert))) AS chlorid,
        MAX(value_or_null(Bez == VARSIZED("HCO3"),        VarSizedToDouble(Wert))) AS hco3
    FROM odbc_source_35
    WHERE Gruppe == VARSIZED("Blutgase arteriell")
    GROUP BY mlife_PID
    WINDOW TUMBLING(Zeitpunkt, SIZE 1 MS)
)
WHERE ph < FLOAT64(7.3)
  AND FLOAT64(0) - abec > FLOAT64(3.0)
  AND natrium - chlorid - hco3 > FLOAT64(12)
INTO alertSink;
----
1000,1001,1002,5.0,-10.0,20.0,2.0,2.0
5000,5001,1008,7.1,-4.0,145.0,105.0,20.0
6000,6001,1009,7.29,-3.1,150.0,105.0,18.0
