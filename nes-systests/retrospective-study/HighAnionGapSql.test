# name: retrospective-study/HighAnionGapSql.test
# description: SQL replacement of the stateful HighAnionGap UDF using value_or_null
#              over a 1ms tumbling window — pivots the per-Bez rows into per-event
#              columns, then applies the threshold predicate. Mimics
#              nes-plugins/Functions/HighAnionGap/HighAnionGapPhysicalFunction.hpp:
#                ph < 7.3 AND abec < -3.0 AND (natrium - chlorid - hco3) > 12
#
# The expected patient set was cross-checked against the original stateful
# HighAnionGap UDF by running it on the same data and projecting mlife_PID
# from rows whose alert string was non-empty: {1002, 1008, 1009}.
# groups: [retrospective-study, NullHandling, WindowOperators]

CREATE LOGICAL SOURCE odbc_source_35(
    LabVal_ID INT32 NOT NULL,
    mlife_PID INT32 NOT NULL,
    mlife_FallNr INT32 NOT NULL,
    Zeitpunkt UINT64 NOT NULL,
    GruppenNr INT32 NOT NULL,
    Gruppe VARSIZED,
    Bez VARSIZED,
    Wert VARSIZED,
    Einheit VARSIZED,
    Wertebereich VARSIZED,
    SampleNr VARSIZED,
    TSFail UINT64 NOT NULL,
    TSLog UINT64 NOT NULL,
    Lab_ID INT32 NOT NULL
);

# Patient scenarios — each patient's 5 measurements share one Zeitpunkt so they
# fall into a single 1ms tumbling-window slice:
#   1002 (ts=1000): pH=5.0,  abec=-10,  na=20,  cl=2,   hco3=2   → 16>12, all fire — TRIGGER
#   1003 (ts=1000): pH=7.4   — pH not <7.3                          — no trigger
#   1004 (ts=1000): only 4 measurements (HCO3 missing)              — MAX→NULL filtered out
#   1005 (ts=2000): pH=7.3   — boundary, NOT <7.3                   — no trigger
#   1006 (ts=3000): abec=-3.0 — boundary, NOT <-3.0                 — no trigger
#   1007 (ts=4000): na-cl-hco3 = 130-100-18 = 12, NOT >12           — no trigger
#   1008 (ts=5000): pH=7.1, abec=-4, na=145, cl=105, hco3=20 → 20>12 — TRIGGER
#   1009 (ts=6000): pH=7.29, abec=-3.1, na=150, cl=105, hco3=18 → 27>12 — TRIGGER
CREATE PHYSICAL SOURCE FOR odbc_source_35 TYPE File;
ATTACH INLINE
