# name: selection/Selection_Equals.test
# description: Simple selection tests
# groups: [Selection]

CREATE LOGICAL SOURCE odbc_source(LabVal_ID INT32, mlife_FallNr INT32, Zeitpunkt UINT64, GruppenNr INT32, Gruppe VARSIZED, Bez VARSIZED, Wert VARSIZED, Einheit VARSIZED, Wertebereich VARSIZED, SampleNr VARSIZED, TSFail UINT64, TSLog UINT64, Lab_ID INT32);

#CREATE PHYSICAL SOURCE FOR stream TYPE File;
CREATE PHYSICAL SOURCE FOR odbc_source TYPE File;
ATTACH INLINE
1,1002,1705310100,2,Blutgas,Kreatinin,1.0,mg/dL,0.6-1.2,S002,1705308300,1705311000,102
2,1002,1705310100,2,Blutgas,Kreatinin,1.5,mg/dL,0.6-1.2,S002,1705308300,1705311000,102
3,1002,1705310100,2,Blutgas,Kreatinin,2.0,mg/dL,0.6-1.2,S002,1705308300,1705311000,102
4,1002,2310110100,2,Blutgas,Kreatinin,2.5,mg/dL,0.6-1.2,S002,1705308300,1705311000,102

SELECT * FROM (
    SELECT Baseline2xDiff(VarSizedToDouble(Wert)) as alarm
    FROM odbc_source
    WHERE Bez == VARSIZED("Kreatinin")
    )
WHERE alarm != VARSIZED("")
INTO File();
----
Acute kidney injury detected for patient 1002. Reason: serum_Kreatinin value of 2 is (more than) twice as large as baseline value of 1. Timestamps(Creation: 15.01.2024 09:15 MLIFE(Clone) insertion: 15.01.2024 08:45 System Ingestion: 15.01.2024 09:30 Alarm: 17.03.2026 09:53)
Acute kidney injury detected for patient 1002. Reason: serum_Kreatinin value of 2.5 is (more than) twice as large as baseline value of 1. Timestamps(Creation: 15.01.2024 09:15 MLIFE(Clone) insertion: 15.01.2024 08:45 System Ingestion: 15.01.2024 09:30 Alarm: 17.03.2026 09:53) Note: Values were measure more than one week apart.

# fails, because Alarm: <timestamp> mismatches