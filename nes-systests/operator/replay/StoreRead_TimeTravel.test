# name: operator/store-read/StoreRead_TimeTravel.test
# description: Store stream to binary via REPLAYABLE and read back via TIME_TRAVEL_READ
# groups: [Store, Read]
GlobalConfiguration worker.default_query_execution.execution_mode: INTERPRETER
GlobalConfiguration worker.default_query_optimization.enable_recording_selection: true

CREATE LOGICAL SOURCE stream(id UINT64, value UINT64, timestamp UINT64);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
1,1,1000
2,1,1001
3,1,1002
4,2,2000

CREATE SINK sinkStore(stream.id UINT64, stream.value UINT64, stream.timestamp UINT64) TYPE File;
CREATE SINK sinkRead(id UINT64, value UINT64, timestamp UINT64) TYPE File;

# 1: store rows to binary file and also write to a sink for comparison
SELECT id, value, timestamp FROM stream INTO sinkStore REPLAYABLE;
----
1,1,1000
2,1,1001
3,1,1002
4,2,2000

# 2: read them back via TIME_TRAVEL_READ and verify
SELECT id, value, timestamp FROM TIME_TRAVEL_READ INTO sinkRead;
----
1,1,1000
2,1,1001
3,1,1002
4,2,2000
