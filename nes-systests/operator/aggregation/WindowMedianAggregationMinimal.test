# name: window/WindowAggregationDifferentDataTypes.test
# description: Test window aggregations over different data types
# groups: [Aggregation, WindowOperators, CompilationIntensive] TODO #1272
GlobalConfiguration worker.query_engine.number_of_worker_threads: [1]

CREATE LOGICAL SOURCE stream(i8 INT8 NOT NULL,  ts UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
1,100
2,150
0,250

CREATE SINK sinkStreamOne(stream.start UINT64 NOT NULL, stream.end UINT64 NOT NULL, stream.i8_out FLOAT64 NOT NULL)  TYPE File;

SELECT start, end, MEDIAN(i8) as i8_out
FROM stream WINDOW SLIDING(ts, size 100 ms, advance by 100 ms) INTO sinkStreamOne;
----
100,200,1.5
200,300,0
