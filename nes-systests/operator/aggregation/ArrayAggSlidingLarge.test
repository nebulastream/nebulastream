# name: operator/aggregation/ArrayAggSlidingLarge.test
# description: ARRAY_AGG keeps 10,000 file-backed values in timestamp order across 100 overlapping sliding windows
# groups: [Aggregation, WindowOperators]

# The attached input has exactly one value per millisecond with monotonically increasing timestamps.
CREATE LOGICAL SOURCE orderedValues(value UINT16 NOT NULL, ts UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR orderedValues TYPE File;
ATTACH FILE small/array_agg_ordered_20k.csv

CREATE SINK orderedValuesSink(start UINT64 NOT NULL, end UINT64 NOT NULL, values VARSIZED NOT NULL) TYPE File;

# A 101-ms advance produces 100 full windows followed by partial trailing windows. Keep only the full windows; each
# base64 value checks every little-endian UINT16 in sequence, so the result fails if ARRAY_AGG drops, duplicates, or reorders a value.
SELECT start, end, values
FROM (
    SELECT start, end, TO_BASE64(ARRAY_AGG(value)) AS values
    FROM orderedValues
    WINDOW SLIDING(ts, SIZE 10000 MS, ADVANCE BY 101 MS)
)
WHERE end <= 20000
INTO orderedValuesSink;
