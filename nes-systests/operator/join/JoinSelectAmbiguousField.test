# name: join/JoinSelectAmbiguousField.test
# description: Test that table.column syntax disambiguates fields with the same name from different join sides (#1494)
# groups: [WindowOperators, Join, CompilationIntensive]

# Source definitions — both sources share a 'timestamp' field
CREATE LOGICAL SOURCE stream(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH FILE small/stream.csv

CREATE LOGICAL SOURCE stream2(id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream2 TYPE File;
ATTACH FILE small/stream2.csv

CREATE SINK sinkQualifiedTimestamps(stream.id UINT64 NOT NULL, stream.timestamp UINT64 NOT NULL, stream2.timestamp UINT64 NOT NULL) TYPE File;

# Query 1 — Use table.column syntax to select the ambiguous 'timestamp' from each join side
SELECT id, stream.timestamp, stream2.timestamp FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id = id2 WINDOW TUMBLING (timestamp, size 1 sec) INTO sinkQualifiedTimestamps;
