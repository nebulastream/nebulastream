# name: join/RightOuterIntervalJoin.test
# description: RIGHT OUTER interightVal join — every right tuple is emitted; a right tuple with no left partner inside the interightVal gets NULL-filled left fields. Inputs span three interightVal windows (~1000/2000/3000 ms, width 3) and produce ten output rows. Matched rows are emitted by the left-anchored pass; unmatched right tuples are null-filled by the right-anchored pass at end-of-stream, so matches precede null-fills. Projects the join keys/values to keep the expected output deterministic.
# groups: [WindowOperators, Join, IntervalJoin, OuterJoin]

CREATE LOGICAL SOURCE rightOuterLeft(id1 UINT64 NOT NULL, value1 UINT64 NOT NULL, timestampLeft UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR rightOuterLeft TYPE File;
ATTACH INLINE
1,10,1000
2,20,2000

CREATE LOGICAL SOURCE rightOuterRight(id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestampRight UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR rightOuterRight TYPE File;
ATTACH INLINE
1,100,1000
1,101,1002
3,300,1001
2,200,2000
2,201,2003
4,400,2002
5,500,3000
5,501,3001
6,600,3002
7,700,3003

CREATE SINK rightOuterSink(leftId UINT64, leftVal UINT64, rightId UINT64 NOT NULL, rightVal UINT64 NOT NULL) TYPE File;

# Future bounds [0 ms, 3 ms] across three windows. id2=1 matches left id1=1 twice; id2=2 matches left id1=2
# twice; the remaining six right tuples (keys 3,4,5,5,6,7) have no left partner inside the interightVal and are
# NULL-filled. Ten rows total — four matches followed by six null-fills.
SELECT id1 AS leftId, value1 AS leftVal, id2 AS rightId, value2 AS rightVal
FROM (SELECT * FROM rightOuterLeft) RIGHT OUTER JOIN (SELECT * FROM rightOuterRight)
ON id1 = id2 INTERVAL (timestampLeft, timestampRight, lower 0 ms, upper 3 ms)
INTO rightOuterSink;
----
1,10,1,100
1,10,1,101
2,20,2,200
2,20,2,201
NULL,NULL,3,300
NULL,NULL,4,400
NULL,NULL,5,500
NULL,NULL,5,501
NULL,NULL,6,600
NULL,NULL,7,700
