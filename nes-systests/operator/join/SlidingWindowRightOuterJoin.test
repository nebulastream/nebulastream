# name: join/SlidingWindowRightOuterJoin.test
# description: Test RIGHT OUTER JOIN with sliding windows — cross-slice matches must not produce duplicate rows
# groups: [WindowOperators, Join, OuterJoin, SlidingWindow]

# Source definitions
# Left stream: id=1 in slice 1 (t=500), id=2 in slice 1 (t=1500), id=3 in slice 2 (t=2500)
# Right stream: id2=1 in slice 2 (t=2500) — cross-slice match; id2=4 has no left match
# Window W1=[0,4000): id=1 matches id2=1 (cross-slice); id2=4 is unmatched right
# Window W2=[2000,6000): both id2=1 and id2=4 are unmatched (left id=3 has no right match)
# Without Plan 01 fix: N-squared probe calls produce duplicate matched or unmatched rows
CREATE LOGICAL SOURCE stream(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
1,10,500
2,20,1500
3,30,2500

CREATE LOGICAL SOURCE stream2(id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream2 TYPE File;
ATTACH INLINE
1,100,2500
4,400,3500

CREATE SINK sink(streamstream2.start UINT64 NOT NULL, streamstream2.end UINT64 NOT NULL, stream.id UINT64, stream.value UINT64, stream.timestamp UINT64, stream2.id2 UINT64 NOT NULL, stream2.value2 UINT64 NOT NULL, stream2.timestamp UINT64 NOT NULL) TYPE File;

SELECT *
FROM (SELECT * FROM stream) RIGHT OUTER JOIN (SELECT * FROM stream2)
ON (id = id2)
WINDOW SLIDING (timestamp, size 4 sec, advance by 2 sec)
INTO sink;
----
0,4000,1,10,500,1,100,2500
0,4000,NULL,NULL,NULL,4,400,3500
2000,6000,NULL,NULL,NULL,1,100,2500
2000,6000,NULL,NULL,NULL,4,400,3500
