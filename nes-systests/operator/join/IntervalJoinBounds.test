# PrivateTest2: future bounds [0 ms, 3 ms] with right tuples interleaved before/after left; join key f2.
SELECT * FROM (SELECT * FROM p2Left) INNER JOIN (SELECT * FROM p2Right) ON f2_left = f2_right INTERVAL (timestamp, lower 0 ms, upper 3 ms) INTO p2Sink;
