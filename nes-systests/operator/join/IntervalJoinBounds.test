# PrivateTest3: past bounds [-4 ms, -1 ms]; join key f2.
SELECT * FROM (SELECT * FROM p3Left) INNER JOIN (SELECT * FROM p3Right) ON f2_left = f2_right INTERVAL (timestamp, lower -4 ms, upper -1 ms) INTO p3Sink;
