CREATE SINK p1Sink(start UINT64 NOT NULL, end UINT64 NOT NULL, f1_left UINT64 NOT NULL, f2_left UINT64 NOT NULL, timestamp UINT64 NOT NULL, f1_right UINT64 NOT NULL, f2_right UINT64 NOT NULL, timestamp UINT64 NOT NULL) TYPE File;

# PrivateTest1: future bounds [0 ms, 3 ms], left tuples arrive before their right partners; join key f2.
SELECT * FROM (SELECT * FROM p1Left) INNER JOIN (SELECT * FROM p1Right) ON f2_left = f2_right INTERVAL (timestamp, lower 0 ms, upper 3 ms) INTO p1Sink;
----
3 6 50 10 4 1004 10 4
3 6 50 10 4 1005 10 5
3 6 50 10 4 1006 10 6
3 6 50 10 4 1007 10 7
6 9 50 10 6 1006 10 6
6 9 50 10 6 1007 10 7
6 9 50 10 6 1008 10 8
6 9 50 10 6 1009 10 9

