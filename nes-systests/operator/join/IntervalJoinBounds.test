# name: join/IntervalJoinBounds.test
# description: Interval-join bound variations — future-only, past-only, mixed, and closed (exclusive) bounds. Merges the former single-query IntervalJoin{FutureOnly,PastOnly,MixedBounds,ExclusiveBound} tests and adds the canonical private-repo StreamIntervalJoinExecution cases (Test 1-4), each with its own input streams.
# groups: [WindowOperators, IntervalJoin]

CREATE LOGICAL SOURCE futLeft(id1 UINT64 NOT NULL, value1 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR futLeft TYPE File;
ATTACH FILE small/intervaljoin_future_only_left.csv

CREATE LOGICAL SOURCE futRight(id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR futRight TYPE File;
ATTACH FILE small/intervaljoin_future_only_right.csv

CREATE SINK futSink(start UINT64 NOT NULL, end UINT64 NOT NULL, id1 UINT64 NOT NULL, value1 UINT64 NOT NULL, timestamp UINT64 NOT NULL, id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestamp UINT64 NOT NULL) TYPE File;

# FutureOnly: right.ts must fall in [left.ts + 0 ms, left.ts + 3 ms].
SELECT * FROM (SELECT * FROM futLeft) INNER JOIN (SELECT * FROM futRight) ON id1 = id2 INTERVAL (timestamp, lower 0 ms, upper 3 ms) INTO futSink;
----
999 1002 1 10 1000 1 100 1000
999 1002 1 10 1000 1 200 1001
999 1002 2 20 1001 2 300 1002
1008 1011 1 30 1010 1 400 1011
1998 2001 2 40 2000 2 500 2003

CREATE LOGICAL SOURCE pastLeft(id1 UINT64 NOT NULL, value1 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR pastLeft TYPE File;
ATTACH FILE small/intervaljoin_past_only_left.csv

CREATE LOGICAL SOURCE pastRight(id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR pastRight TYPE File;
ATTACH FILE small/intervaljoin_past_only_right.csv

CREATE SINK pastSink(start UINT64 NOT NULL, end UINT64 NOT NULL, id1 UINT64 NOT NULL, value1 UINT64 NOT NULL, timestamp UINT64 NOT NULL, id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestamp UINT64 NOT NULL) TYPE File;

# PastOnly: right.ts must fall in [left.ts - 4 ms, left.ts - 1 ms] (negative offsets).
SELECT * FROM (SELECT * FROM pastLeft) INNER JOIN (SELECT * FROM pastRight) ON id1 = id2 INTERVAL (timestamp, lower -4 ms, upper -1 ms) INTO pastSink;
----
1005 1008 1 10 1005 1 100 1002
1005 1008 1 10 1005 1 200 1003
1008 1011 2 20 1010 2 300 1007
1020 1023 1 30 1020 1 400 1018
1998 2001 2 40 2000 2 500 1999

CREATE LOGICAL SOURCE mixLeft(id1 UINT64 NOT NULL, value1 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR mixLeft TYPE File;
ATTACH FILE small/intervaljoin_mixed_bounds_left.csv

CREATE LOGICAL SOURCE mixRight(id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR mixRight TYPE File;
ATTACH FILE small/intervaljoin_mixed_bounds_right.csv

CREATE SINK mixSink(start UINT64 NOT NULL, end UINT64 NOT NULL, id1 UINT64 NOT NULL, value1 UINT64 NOT NULL, timestamp UINT64 NOT NULL, id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestamp UINT64 NOT NULL) TYPE File;

# MixedBounds: right.ts must fall in [left.ts - 6 ms, left.ts + 2 ms] (W = 8), spanning past and future.
SELECT * FROM (SELECT * FROM mixLeft) INNER JOIN (SELECT * FROM mixRight) ON id1 = id2 INTERVAL (timestamp, lower -6 ms, upper 2 ms) INTO mixSink;
----
1000 1008 1 10 1000 1 100 994
1000 1008 1 10 1000 1 200 1002
1000 1008 2 20 1003 2 300 997
1000 1008 2 20 1003 2 400 1005
1008 1016 1 30 1015 1 500 1017
1016 1024 2 40 1018 2 600 1012

CREATE LOGICAL SOURCE exclLeft(id1 UINT64 NOT NULL, value1 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR exclLeft TYPE File;
ATTACH FILE small/intervaljoin_exclusive_bound_left.csv

CREATE LOGICAL SOURCE exclRight(id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR exclRight TYPE File;
ATTACH FILE small/intervaljoin_exclusive_bound_right.csv

CREATE SINK exclSink(start UINT64 NOT NULL, end UINT64 NOT NULL, id1 UINT64 NOT NULL, value1 UINT64 NOT NULL, timestamp UINT64 NOT NULL, id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestamp UINT64 NOT NULL) TYPE File;

# ExclusiveBound: closed bounds [0 ms, 3 ms] — right tuples exactly at left.ts+0 and left.ts+3 must match.
SELECT * FROM (SELECT * FROM exclLeft) INNER JOIN (SELECT * FROM exclRight) ON id1 = id2 INTERVAL (timestamp, lower 0 ms, upper 3 ms) INTO exclSink;
----
999 1002 1 10 1000 1 100 1000
999 1002 1 10 1000 1 200 1003
1008 1011 1 20 1010 1 300 1010
1008 1011 1 20 1010 1 400 1013

CREATE LOGICAL SOURCE p1Left(f1_left UINT64 NOT NULL, f2_left UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR p1Left TYPE File;
ATTACH INLINE
50,10,4
50,10,6
50,11,9

