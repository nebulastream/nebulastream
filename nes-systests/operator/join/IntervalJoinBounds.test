# PrivateTest4: mixed bounds [-6 ms, 2 ms] with asymmetric schemas (right carries an extra field f3_right); join key f2.
SELECT * FROM (SELECT * FROM p4Left) INNER JOIN (SELECT * FROM p4Right) ON f2_left = f2_right INTERVAL (timestamp, lower -6 ms, upper 2 ms) INTO p4Sink;
