# name: join/RightOuterJoin.test
# description: Test RIGHT OUTER JOIN — all right tuples emitted; unmatched right tuples have NULL-filled left fields
# groups: [WindowOperators, Join, OuterJoin]
# Expected output generated by: https://gist.github.com/ls-1801/0bd0883cf3154d4f78037521221bb7eb

CREATE LOGICAL SOURCE stream(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH FILE small/outer_join_left.csv

CREATE LOGICAL SOURCE stream2(id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream2 TYPE File;
ATTACH FILE small/outer_join_right.csv

CREATE SINK sink(streamstream2.start UINT64 NOT NULL, streamstream2.end UINT64 NOT NULL, stream.id UINT64, stream.value UINT64, stream.timestamp UINT64, stream2.id2 UINT64 NOT NULL, stream2.value2 UINT64 NOT NULL, stream2.timestamp UINT64 NOT NULL) TYPE Checksum;

# Query 1 — Large tumbling window (10 sec)
SELECT *
FROM (SELECT * FROM stream) RIGHT OUTER JOIN (SELECT * FROM stream2)
ON (id = id2)
WINDOW TUMBLING (timestamp, size 10 sec)
INTO sink;
----
21860 46038141

# Query 2 — Small tumbling window (1 sec)
SELECT *
FROM (SELECT * FROM stream) RIGHT OUTER JOIN (SELECT * FROM stream2)
ON (id = id2)
WINDOW TUMBLING (timestamp, size 1 sec)
INTO sink;
----
10241 23737614
