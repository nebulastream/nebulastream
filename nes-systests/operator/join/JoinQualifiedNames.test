# description: Test table.column qualified name syntax in joins (#474)
# groups: [WindowOperators, Join]

# Source definitions
CREATE LOGICAL SOURCE stream(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH FILE small/stream.csv

CREATE LOGICAL SOURCE stream2(id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream2 TYPE File;
ATTACH FILE small/stream2.csv

CREATE SINK qualifiedJoinSink(streamstream2.start UINT64 NOT NULL, streamstream2.end UINT64 NOT NULL, stream.id UINT64 NOT NULL, stream.value UINT64 NOT NULL, stream.timestamp UINT64 NOT NULL, stream2.id2 UINT64 NOT NULL, stream2.value2 UINT64 NOT NULL, stream2.timestamp UINT64 NOT NULL) TYPE File;

# Query 1 — Qualified names in ON clause: stream.id = stream2.id2
# Should produce same results as the unqualified variant.
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON (stream.id = stream2.id2) WINDOW TUMBLING (timestamp, size 1 sec) INTO qualifiedJoinSink;
----
2000 3000 1 2 2000 1 2 2010
2000 3000 11 2 2001 11 2 2301
3000 4000 1 3 3000 1 3 3009
3000 4000 1 3 3000 1 3 3201
3000 4000 11 3 3001 11 3 3001
3000 4000 1 3 3003 1 3 3009
3000 4000 1 3 3003 1 3 3201
3000 4000 1 3 3200 1 3 3009
3000 4000 1 3 3200 1 3 3201
