20000 21000 1 20 20000 1 20 20000

# Query 2 — Qualified names in both ON and SELECT clause
CREATE SINK selectedFieldsSink(stream.id UINT64 NOT NULL, stream2.id2 UINT64 NOT NULL, stream.value UINT64 NOT NULL) TYPE File;

SELECT stream.id, stream2.id2, stream.value FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON (stream.id = stream2.id2) WINDOW TUMBLING (timestamp, size 1 sec) INTO selectedFieldsSink;
