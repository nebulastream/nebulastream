# Query 3 — Qualified names in ON with multiple keys
CREATE SINK multiKeySink(streamstream2.start UINT64 NOT NULL, streamstream2.end UINT64 NOT NULL, stream.id UINT64 NOT NULL, stream.value UINT64 NOT NULL, stream.timestamp UINT64 NOT NULL, stream2.id2 UINT64 NOT NULL, stream2.value2 UINT64 NOT NULL, stream2.timestamp UINT64 NOT NULL)  TYPE File;

SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON (stream.id = stream2.id2 AND stream.value = stream2.value2) WINDOW TUMBLING (timestamp, size 1 sec) INTO multiKeySink;
