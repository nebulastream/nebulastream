# name: join/LeftOuterInterightValJoin.test
# description: LEFT OUTER interightVal join — every left tuple is emitted; a left tuple with no right partner inside its interightVal [lower, upper] gets NULL-filled right fields. Inputs span three interightVal windows (~1000/2000/3000 ms, width 3) and produce ten output rows. Queries project the join keys/values (dropping window start/end and the per-side event timestamps) to keep the expected output deterministic.
# groups: [WindowOperators, InterightValJoin, OuterJoin]

CREATE LOGICAL SOURCE leftOuterLeft(id1 UINT64 NOT NULL, value1 UINT64 NOT NULL, timestampLeft UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR leftOuterLeft TYPE File;
ATTACH INLINE
1,10,1000
2,20,1000
3,30,1000
4,40,2000
5,50,2000
6,60,2000
7,70,3000
8,80,3000

CREATE LOGICAL SOURCE leftOuterRight(id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestampRight UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR leftOuterRight TYPE File;
ATTACH INLINE
1,100,1000
1,101,1002
2,200,1001
4,400,2000
4,401,2002
5,500,2001
7,700,3001

CREATE SINK leftOuterSink(leftId UINT64 NOT NULL, leftVal UINT64 NOT NULL, rightId UINT64, rightVal UINT64) TYPE File;

# Future bounds [0 ms, 3 ms] across three windows. id1=1 and id1=4 each match two right tuples; id1=2 and
# id1=5 and id1=7 each match one; id1=3, id1=6, id1=8 have no partner and are NULL-filled. Ten rows total.
SELECT id1 AS leftId, value1 AS leftVal, id2 AS rightId, value2 AS rightVal
FROM (SELECT * FROM leftOuterLeft) LEFT OUTER JOIN (SELECT * FROM leftOuterRight)
ON id1 = id2 INTERVAL (timestampLeft, timestampRight, lower 0 ms, upper 3 ms)
INTO leftOuterSink;
----
1,10,1,100
1,10,1,101
2,20,2,200
3,30,NULL,NULL
4,40,4,400
4,40,4,401
5,50,5,500
6,60,NULL,NULL
7,70,7,700
8,80,NULL,NULL
