# name: join/IntervalJoinNegative.test
# description: Interval-join negative cases — degenerate/inverted bounds are rejected at SQL/logical-operator construction. Merged from IntervalJoinPointPredicate and the private-repo exact-match (lower == upper) case, which NebulaStream rejects.
# groups: [WindowOperators, IntervalJoin, Parser]

CREATE LOGICAL SOURCE negLeft(id1 UINT64 NOT NULL, value1 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR negLeft TYPE File;
ATTACH FILE small/intervaljoin_future_only_left.csv

CREATE LOGICAL SOURCE negRight(id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR negRight TYPE File;
ATTACH FILE small/intervaljoin_future_only_right.csv

CREATE SINK negSink(negLeftnegRight.start UINT64 NOT NULL, negLeftnegRight.end UINT64 NOT NULL, negLeft.id1 UINT64 NOT NULL, negLeft.value1 UINT64 NOT NULL, negLeft.timestamp UINT64 NOT NULL, negRight.id2 UINT64 NOT NULL, negRight.value2 UINT64 NOT NULL, negRight.timestamp UINT64 NOT NULL) TYPE File;

# PointPredicate: a point predicate [0 ms, 0 ms] must be rejected (W = U - L = 0 is degenerate).
SELECT * FROM (SELECT * FROM negLeft) INNER JOIN (SELECT * FROM negRight) ON id1 = id2 INTERVAL (timestamp, lower 0 ms, upper 0 ms) INTO negSink;
----
ERROR 2000

# InvertedBounds: inverted bounds [3 ms, 1 ms] must be rejected (lowerBound > upperBound).
SELECT * FROM (SELECT * FROM negLeft) INNER JOIN (SELECT * FROM negRight) ON id1 = id2 INTERVAL (timestamp, lower 3 ms, upper 1 ms) INTO negSink;
----
ERROR 2000

CREATE LOGICAL SOURCE pt5Left(id1 UINT64 NOT NULL, value1 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR pt5Left TYPE File;
ATTACH INLINE
50,10,4
50,10,6
50,11,9

CREATE LOGICAL SOURCE pt5Right(id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR pt5Right TYPE File;
ATTACH INLINE
1000,10,0
1001,10,1
1002,10,2
1003,10,3
1004,10,4
1005,10,5
1006,10,6
1007,10,7
1008,10,8
1009,10,9

CREATE SINK pt5Sink(pt5Leftpt5Right.start UINT64 NOT NULL, pt5Leftpt5Right.end UINT64 NOT NULL, pt5Left.id1 UINT64 NOT NULL, pt5Left.value1 UINT64 NOT NULL, pt5Left.timestamp UINT64 NOT NULL, pt5Right.id2 UINT64 NOT NULL, pt5Right.value2 UINT64 NOT NULL, pt5Right.timestamp UINT64 NOT NULL) TYPE File;

# PrivateTest5: the private repo's exact-timestamp-match interval join uses lower == upper == 0 ms; NebulaStream rejects this degenerate point predicate.
SELECT * FROM (SELECT * FROM pt5Left) INNER JOIN (SELECT * FROM pt5Right) ON id1 = id2 INTERVAL (timestamp, lower 0 ms, upper 0 ms) INTO pt5Sink;
----
ERROR 2000
