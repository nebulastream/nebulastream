0 1000 1 2 3 4 5 6 7 8 9.0 10.0 100 8 8 8 8 8 8 8 8 8.0 8.0 507
0 1000 1 2 3 4 5 6 7 8 9.0 10.0 100 9 9 9 9 9 9 9 9 9.0 9.0 508
0 1000 1 2 3 4 5 6 7 8 9.0 10.0 100 10 10 10 10 10 10 10 10 10.0 10.0 509

# Query 11 - i8_s1 < i16_s2, tumbling 2 sec
# Tests: INT8 < INT16, wider tumbling window groups same records into [0,2000)
SELECT * FROM (SELECT * FROM stream1) INNER JOIN (SELECT * FROM stream2) ON i8_s1 < i16_s2 WINDOW TUMBLING (ts, size 2 sec) INTO sinkStream1Stream2;
----
0 2000 1 2 3 4 5 6 7 8 9.0 10.0 100 2 2 2 2 2 2 2 2 2.0 2.0 501
0 2000 1 2 3 4 5 6 7 8 9.0 10.0 100 3 3 3 3 3 3 3 3 3.0 3.0 502
0 2000 1 2 3 4 5 6 7 8 9.0 10.0 100 4 4 4 4 4 4 4 4 4.0 4.0 503
0 2000 1 2 3 4 5 6 7 8 9.0 10.0 100 5 5 5 5 5 5 5 5 5.0 5.0 504
0 2000 1 2 3 4 5 6 7 8 9.0 10.0 100 6 6 6 6 6 6 6 6 6.0 6.0 505
0 2000 1 2 3 4 5 6 7 8 9.0 10.0 100 7 7 7 7 7 7 7 7 7.0 7.0 506
0 2000 1 2 3 4 5 6 7 8 9.0 10.0 100 8 8 8 8 8 8 8 8 8.0 8.0 507
0 2000 1 2 3 4 5 6 7 8 9.0 10.0 100 9 9 9 9 9 9 9 9 9.0 9.0 508
0 2000 1 2 3 4 5 6 7 8 9.0 10.0 100 10 10 10 10 10 10 10 10 10.0 10.0 509

# Query 12 - f32_s1 < f64_s2, tumbling 2 sec
# Tests: FLOAT32 < FLOAT64 with wider tumbling window
SELECT * FROM (SELECT * FROM stream1) INNER JOIN (SELECT * FROM stream2) ON f32_s1 < f64_s2 WINDOW TUMBLING (ts, size 2 sec) INTO sinkStream1Stream2;
----
0 2000 1 2 3 4 5 6 7 8 9.0 10.0 100 10 10 10 10 10 10 10 10 10.0 10.0 509

# Query 13 - i8_s1 < i16_s2, tumbling 500 ms
# Tests: INT8 < INT16, 500ms window: stream1 (ts=100) and stream2 (ts=500–509) land in different buckets → no output
SELECT * FROM (SELECT * FROM stream1) INNER JOIN (SELECT * FROM stream2) ON i8_s1 < i16_s2 WINDOW TUMBLING (ts, size 500 ms) INTO sinkStream1Stream2;
----

# Query 14 - u32_s1 > f64_s2, tumbling 500 ms
# Tests: UINT32 > FLOAT64, 500ms window: confirms empty result for cross-type pred when records don't share a window
SELECT * FROM (SELECT * FROM stream1) INNER JOIN (SELECT * FROM stream2) ON u32_s1 > f64_s2 WINDOW TUMBLING (ts, size 500 ms) INTO sinkStream1Stream2;
----

# Query 15 - i8_s1 < i16_s2, sliding 1000ms/500ms
# Tests: INT8 < INT16 with sliding window — same predicate as Q1; verifies sliding window handles cross-type pred
SELECT * FROM (SELECT * FROM stream1) INNER JOIN (SELECT * FROM stream2) ON i8_s1 < i16_s2 WINDOW SLIDING (ts, size 1 sec, advance by 500 ms) INTO sinkStream1Stream2;
----
0 1000 1 2 3 4 5 6 7 8 9.0 10.0 100 2 2 2 2 2 2 2 2 2.0 2.0 501
0 1000 1 2 3 4 5 6 7 8 9.0 10.0 100 3 3 3 3 3 3 3 3 3.0 3.0 502
0 1000 1 2 3 4 5 6 7 8 9.0 10.0 100 4 4 4 4 4 4 4 4 4.0 4.0 503
0 1000 1 2 3 4 5 6 7 8 9.0 10.0 100 5 5 5 5 5 5 5 5 5.0 5.0 504
0 1000 1 2 3 4 5 6 7 8 9.0 10.0 100 6 6 6 6 6 6 6 6 6.0 6.0 505
0 1000 1 2 3 4 5 6 7 8 9.0 10.0 100 7 7 7 7 7 7 7 7 7.0 7.0 506
0 1000 1 2 3 4 5 6 7 8 9.0 10.0 100 8 8 8 8 8 8 8 8 8.0 8.0 507
0 1000 1 2 3 4 5 6 7 8 9.0 10.0 100 9 9 9 9 9 9 9 9 9.0 9.0 508
0 1000 1 2 3 4 5 6 7 8 9.0 10.0 100 10 10 10 10 10 10 10 10 10.0 10.0 509

# Query 16 - u64_s1 < f32_s2, sliding 1000ms/500ms
# Tests: UINT64 < FLOAT32 with sliding window — integer-to-float predicate in sliding context
SELECT * FROM (SELECT * FROM stream1) INNER JOIN (SELECT * FROM stream2) ON u64_s1 < f32_s2 WINDOW SLIDING (ts, size 1 sec, advance by 500 ms) INTO sinkStream1Stream2;
----
0 1000 1 2 3 4 5 6 7 8 9.0 10.0 100 9 9 9 9 9 9 9 9 9.0 9.0 508
0 1000 1 2 3 4 5 6 7 8 9.0 10.0 100 10 10 10 10 10 10 10 10 10.0 10.0 509

# Query 17 - f32_s1 < f64_s2, sliding 1000ms/500ms
# Tests: FLOAT32 < FLOAT64 with sliding window — float-to-float predicate in sliding context
SELECT * FROM (SELECT * FROM stream1) INNER JOIN (SELECT * FROM stream2) ON f32_s1 < f64_s2 WINDOW SLIDING (ts, size 1 sec, advance by 500 ms) INTO sinkStream1Stream2;
----
0 1000 1 2 3 4 5 6 7 8 9.0 10.0 100 10 10 10 10 10 10 10 10 10.0 10.0 509

# Query 18 - i8_s1 != i8_s2, tumbling 1 sec
# Tests: not-equals on INT8: the single stream2 row where i8_s2 equals stream1's i8_s1 (value 1) is excluded; all other rows are emitted
SELECT * FROM (SELECT * FROM stream1) INNER JOIN (SELECT * FROM stream2) ON i8_s1 != i8_s2 WINDOW TUMBLING (ts, size 1 sec) INTO sinkStream1Stream2;
----
0 1000 1 2 3 4 5 6 7 8 9.0 10.0 100 2 2 2 2 2 2 2 2 2.0 2.0 501
