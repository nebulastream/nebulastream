# name: formatter/JSON/Mixed_JSONChecksum.test
# description: JSON input formatter queries using Checksum sinks (requires both JSONInputFormatter and ChecksumSink plugins)
# groups: [Formatter, JSON]

CREATE LOGICAL SOURCE MissingKeyFronJSONStream(key UINT64 NOT NULL, value UINT64 NOT NULL, name VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR MissingKeyFronJSONStream TYPE File SET("JSON" AS INPUT_FORMATTER.`TYPE`);
ATTACH INLINE
{"KEY":1, "VALUE":1, "NAME":"john"}
{"KEY":1, "VALUE":2 }

SELECT * FROM MissingKeyFronJSONStream INTO Checksum();
----
ERROR 2004
