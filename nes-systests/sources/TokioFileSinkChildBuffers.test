# name: sources/TokioFileSinkChildBuffers.test
# description: Tests TokioFileSink with child buffers -- CSV output formatter produces multi-segment buffers when formatted rows exceed buffer size. Verifies that the Rust BufferIterator correctly iterates main + child buffer segments.
# groups: [Sources, TokioSource, TokioFileSink]

# Small buffer forces the CSV output formatter to spill into child buffers.
# Each CSV row is ~144 bytes (8 fields of 17-digit numbers + commas + newline).
# 60 rows x 144 bytes = ~8640 bytes, well over the 4096-byte buffer limit.
GlobalConfiguration worker.default_query_execution.operator_buffer_size: [4096]

CREATE LOGICAL SOURCE multiBuffer(field_1 UINT64 NOT NULL, field_2 UINT64 NOT NULL, field_3 UINT64 NOT NULL, field_4 UINT64 NOT NULL, field_5 UINT64 NOT NULL, field_6 UINT64 NOT NULL, field_7 UINT64 NOT NULL, field_8 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR multiBuffer TYPE File;
