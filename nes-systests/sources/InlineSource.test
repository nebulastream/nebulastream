# name: sources/InlineSource.test
# description: Creating sources inline
# groups: [Sources]



CREATE SINK file_output(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL) TYPE File;

SELECT ID, VALUE, TIMESTAMP
FROM File(
	'small/stream8.csv' AS `SOURCE`.FILE_PATH,
	'CSV' AS INPUT_FORMATTER.`TYPE`,
	SCHEMA(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL) AS `SOURCE`.`SCHEMA`)
INTO file_output;
----
1,1,12
1,2,23
1,3,34
1,4,45
1,5,56


CREATE LOGICAL SOURCE input(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR input TYPE File;
ATTACH FILE small/stream8.csv


SELECT input.ID AS ID, input.VALUE AS VALUE, input.TIMESTAMP AS TIMESTAMP
FROM input
INTO file_output;
====
SELECT ID, VALUE, TIMESTAMP
FROM File(
	'small/stream8.csv' AS `SOURCE`.FILE_PATH,
	'CSV' AS INPUT_FORMATTER.`TYPE`,
	SCHEMA(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL) AS `SOURCE`.`SCHEMA`)
INTO file_output;

SELECT ID, VALUE, TIMESTAMP
FROM File(
	'small/stream8.csv' AS `SOURCE`.FILE_PATH,
	'IDontExist' AS `SOURCE`.`HOST`,
	'CSV' AS INPUT_FORMATTER.`TYPE`,
	SCHEMA(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL) AS `SOURCE`.`SCHEMA`)
INTO file_output;
