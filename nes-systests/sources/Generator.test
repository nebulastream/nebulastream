CREATE LOGICAL SOURCE generator10KNotFail(timestamp UINT64 NOT NULL, id1 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR generator10KNotFail TYPE GENERATOR SET(
    'ALL' as `SOURCE`.STOP_GENERATOR_WHEN_SEQUENCE_FINISHES,
    1 AS `SOURCE`.SEED,
    'FIXED' AS `SOURCE`.GENERATOR_RATE_TYPE,
    'emit_rate 1000' AS `SOURCE`.GENERATOR_RATE_CONFIG,
    'SEQUENCE UINT64 0 10000 1, SEQUENCE UINT64 0 100 1' AS `SOURCE`.GENERATOR_SCHEMA
);

CREATE LOGICAL SOURCE generator10KFailSource(timestamp UINT64 NOT NULL, id0 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR generator10KFailSource TYPE GENERATOR SET(
    'ALL' as `SOURCE`.STOP_GENERATOR_WHEN_SEQUENCE_FINISHES,
    1 AS `SOURCE`.SEED,
    'FIXED' AS `SOURCE`.GENERATOR_RATE_TYPE,
    'emit_rate 1000' AS `SOURCE`.GENERATOR_RATE_CONFIG,
    "1s" as `SOURCE`.FAIL_AFTER,
    'SEQUENCE UINT64 0 10000 1, SEQUENCE UINT64 0 100 1' AS `SOURCE`.GENERATOR_SCHEMA
);


CREATE LOGICAL SOURCE generator10KFailSourceSlow(timestamp UINT64 NOT NULL, id0 UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR generator10KFailSourceSlow TYPE GENERATOR SET(
    'ALL' as `SOURCE`.STOP_GENERATOR_WHEN_SEQUENCE_FINISHES,
    1 AS `SOURCE`.SEED,
    'FIXED' AS `SOURCE`.GENERATOR_RATE_TYPE,
    'emit_rate 1' AS `SOURCE`.GENERATOR_RATE_CONFIG,
    "20ms" as `SOURCE`.FAIL_AFTER,
    'SEQUENCE UINT64 0 10000 1, SEQUENCE UINT64 0 100 1' AS `SOURCE`.GENERATOR_SCHEMA
);

SELECT * FROM generator10KFailSource
INTO VOID("200ms" as `SINK`.INGESTION);
----
ERROR 4002

SELECT * FROM (SELECT * FROM generator10KFailSource) INNER JOIN (SELECT * FROM generator10KNotFail) ON id0 = id1 WINDOW TUMBLING (timestamp, size 10 ms)
INTO VOID("1s" as `SINK`.INGESTION);
----
ERROR 4002

SELECT * FROM generator10KFailSourceSlow
INTO VOID("200ms" as `SINK`.INGESTION);
----
ERROR 4002
