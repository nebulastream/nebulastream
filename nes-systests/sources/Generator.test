CREATE LOGICAL SOURCE generator_with_timeout(id FLOAT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR generator_with_timeout TYPE Generator SET(
       'ONE' as `SOURCE`.STOP_GENERATOR_WHEN_SEQUENCE_FINISHES, # Normal Distribution Never finishes
       '2s' AS `SOURCE`.MAX_RUNTIME,
       1 AS `SOURCE`.SEED,
       'NORMAL_DISTRIBUTION FLOAT64 0 10' AS `SOURCE`.GENERATOR_SCHEMA
);
CREATE SINK generator_sink_timeout(generator_with_timeout.id FLOAT64 NOT NULL) TYPE File;

# Predicate eliminates all tuples on purpose, as this test does not care about the result.
# The test only validates that the query terminates based on the `MAX_RUNTIME`
SELECT * FROM generator_with_timeout
WHERE BOOLEAN(FALSE)
INTO generator_sink_timeout;
----

CREATE LOGICAL SOURCE generator_text(id UINT64 NOT NULL, word VARSIZED NOT NULL, random_word VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR generator_text TYPE GENERATOR SET(
    'ONE' as `SOURCE`.STOP_GENERATOR_WHEN_SEQUENCE_FINISHES, # Text generator never finishes
    1 as `SOURCE`.SEED,
    'SEQUENCE UINT64 0 20 1, WORDLIST_PATH TESTDATA/small/wordlist.csv, RANDOMSTR 1 6' AS `SOURCE`.GENERATOR_SCHEMA
);
CREATE SINK generator_sink_text(generator_text.id UINT64 NOT NULL, generator_text.word VARSIZED NOT NULL, generator_text.random_word VARSIZED NOT NULL) TYPE File;
SELECT * FROM generator_text
INTO generator_sink_text;
