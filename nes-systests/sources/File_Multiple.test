# name: sources/FileMultiple.test
# description: Combine two files sources with different input formatter configurations
# groups: [Sources]

CREATE LOGICAL SOURCE combinedSource(id UINT64, value UINT64, timestamp
 UINT64);
CREATE PHYSICAL SOURCE FOR combinedSource TYPE File;
INLINE
Attach File CSV combinedSource FILE
TESTDATA/small/stream8.csv

Attach File CSV CONFIG/inputFormatters/csv_pipe_delimiter.yaml combinedSource INLINE
1|6|67
1|7|78
1|8|89
1|9|100

CREATE SINK unifiedStreamSink(combinedSource.id UINT64, combinedSource.value UINT64, combinedSource.timestamp
 UINT64)  TYPE File;

SELECT * FROM combinedSource INTO unifiedStreamSink
