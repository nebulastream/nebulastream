# name: selection/Selection_Equals.test
# description: Simple selection tests
# groups: [Selection]

CREATE LOGICAL SOURCE medical_data_source(LabVal_ID INT32, mlife_FallNr INT32, Zeitpunkt UINT64, GruppenNr INT32, Gruppe INT32, Bez VARSIZED, Wert VARSIZED, Einheit VARSIZED, Wertebereich VARSIZED, SampleNr VARSIZED, TSFail UINT64, TSLog UINT64, Lab_ID INT32);

#CREATE PHYSICAL SOURCE FOR stream TYPE File;
CREATE PHYSICAL SOURCE FOR medical_data_source TYPE File;
ATTACH INLINE
small/medical-data.csv


# basic alert rule 01
SELECT LabVal_ID, mlife_FallNr, Zeitpunkt, Bez, VarSizedToDouble(Wert) AS wert_double, Einheit, Wertebereich, SampleNr, TSFail, TSLog, Lab_ID
FROM odbc_source
WHERE Bez = VARSIZED("PO2") AND NOT(isNull(VarSizedToDouble(Wert))) AND VarSizedToDouble(Wert) < FLOAT64(60)
INTO File();
----


