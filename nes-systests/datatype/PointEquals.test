# name: datatype/PointEquals.test
# description: Validates the overload-resolution path: parser emits an
#              UnboundLogicalFunction for `==`, which during type inference
#              resolves to `Equals_Point_Point` because both operand logical
#              types are `Point`. The bound PointEquals function lowers to a
#              component-wise physical comparison, sidestepping the legacy
#              Value::operator== that aborts on compound Values.
# groups: [DataType, LogicalType, Point]

CREATE LOGICAL SOURCE points(x FLOAT NOT NULL, y FLOAT NOT NULL, z FLOAT NOT NULL);
CREATE PHYSICAL SOURCE FOR points TYPE File;
ATTACH INLINE
1.0,2.0,3.0

CREATE SINK out(eq BOOL NOT NULL) TYPE File;

SELECT Point(x, y, z) == Point(x, y, z) AS eq
FROM points INTO out;
----
true
