# name: sinks/AnonymousSink.test
# description: Creating anonymous sinks within queries
# groups: [Sources]

SELECT ID, VALUE, TIMESTAMP
FROM File(
	'small/stream8.csv' AS "SOURCE".FILE_PATH,
	'CSV' AS INPUT_FORMATTER."TYPE",
	SCHEMA(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL) AS "SOURCE"."SCHEMA")
INTO File();
----
1,1,12
1,2,23
1,3,34
1,4,45
1,5,56

SELECT ID, VALUE, TIMESTAMP
FROM File(
	'small/stream8.csv' AS "SOURCE".FILE_PATH,
	'CSV' AS INPUT_FORMATTER."TYPE",
	SCHEMA(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL) AS "SOURCE"."SCHEMA")
INTO File(SCHEMA(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL) AS "SINK"."SCHEMA");
----
1,1,12
1,2,23
1,3,34
1,4,45
1,5,56


SELECT ID, VALUE, TIMESTAMP
FROM File(
	'small/stream8.csv' AS "SOURCE".FILE_PATH,
	'CSV' AS INPUT_FORMATTER."TYPE",
	SCHEMA(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL) AS "SOURCE"."SCHEMA")
INTO Checksum();
----
5 1505

CREATE SINK output_file(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL) TYPE File;

SELECT ID, VALUE, TIMESTAMP
FROM File(
	'small/stream8.csv' AS "SOURCE".FILE_PATH,
	'CSV' AS INPUT_FORMATTER."TYPE",
	SCHEMA(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL) AS "SOURCE"."SCHEMA")
INTO output_file;
====
SELECT ID, VALUE, TIMESTAMP
FROM File(
	'small/stream8.csv' AS "SOURCE".FILE_PATH,
	'CSV' AS INPUT_FORMATTER."TYPE",
	SCHEMA(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL) AS "SOURCE"."SCHEMA")
INTO File();



CREATE SINK output_checksum(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL) TYPE Checksum;

SELECT ID, VALUE, TIMESTAMP
FROM File(
	'small/stream8.csv' AS "SOURCE".FILE_PATH,
	'CSV' AS INPUT_FORMATTER."TYPE",
	SCHEMA(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL) AS "SOURCE"."SCHEMA")
INTO output_checksum;
====
SELECT ID, VALUE, TIMESTAMP
FROM File(
	'small/stream8.csv' AS "SOURCE".FILE_PATH,
	'CSV' AS INPUT_FORMATTER."TYPE",
	SCHEMA(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL) AS "SOURCE"."SCHEMA")
INTO Checksum();


# The sink type is looked up as written, so "FileSink" does not resolve to the registered "File" sink and the
# query must be rejected with an error instead of being silently accepted.
SELECT ID, VALUE, TIMESTAMP
FROM File(
	'small/stream8.csv' AS "SOURCE".FILE_PATH,
	'CSV' AS INPUT_FORMATTER."TYPE",
	SCHEMA(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL) AS "SOURCE"."SCHEMA")
INTO FileSink();
----
ERROR 1000
