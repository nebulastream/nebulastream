# name: sinks/TCPSink.test
# description: sending query output to a TCP sink
# groups: [Sinks, TCP]
#
# This file is the sink-side TCP query specification in the same style as sources/TCP.test.
# It is valid SQL for the systest parser.
# For real end-to-end validation, an external TCP listener must be running on the configured port,
# and the current automated assertion path is implemented in TCPSink.test.cpp.

CREATE SINK tcp_sink(ID UINT64 NOT NULL, VALUE UINT64 NOT NULL, TIMESTAMP UINT64 NOT NULL) TYPE TCP SET(
    '127.0.0.1' AS `SINK`.SOCKET_HOST,
    50501 AS `SINK`.SOCKET_PORT,
    'AF_INET' AS `SINK`.SOCKET_DOMAIN,
    'SOCK_STREAM' AS `SINK`.SOCKET_TYPE,
    10 AS `SINK`.CONNECT_TIMEOUT_SECONDS,
    'CSV' AS `SINK`.OUTPUT_FORMAT
);

SELECT ID, VALUE, TIMESTAMP
FROM File(
    'small/stream8.csv' AS `SOURCE`.FILE_PATH,
    'CSV' AS PARSER.`TYPE`,
    SCHEMA(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL) AS `SOURCE`.`SCHEMA`)
INTO tcp_sink;
----
1,1,12
1,2,23
1,3,34
1,4,45
1,5,56
