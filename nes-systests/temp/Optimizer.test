SELECT id, value, timestamp FROM (
    SELECT id AS id, value AS value, timestamp as timestamp FROM stream1
    UNION
    SELECT id AS id, value AS value, timestamp as timestamp FROM stream2
    )
WHERE id >= UINT64(2)
INTO File();
