CREATE LOGICAL SOURCE stream3(id UINT64 NOT NULL, id2 UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream3 TYPE File;
