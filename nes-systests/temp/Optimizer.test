CREATE LOGICAL SOURCE stream1(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream1 TYPE File;
ATTACH INLINE
