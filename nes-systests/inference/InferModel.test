# name: inference/InferModel.test
# description: ML model inference with INFER_MODEL operator using the Iris model
# groups: [Inference]

CREATE LOGICAL SOURCE stream(p1 FLOAT32, p2 FLOAT32, p3 FLOAT32, p4 FLOAT32);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
6.1,3.5,1.4,0.2
4.9,3.0,1.4,0.2
4.7,3.2,1.3,0.2

CREATE MODEL iris ('model/model.onnx')
INPUT (p1 FLOAT32, p2 FLOAT32, p3 FLOAT32, p4 FLOAT32)
OUTPUT (setosa FLOAT32, versicolor FLOAT32, virginica FLOAT32);

CREATE SINK result(`STREAM$P1` FLOAT32, `STREAM$P2` FLOAT32, `STREAM$P3` FLOAT32, `STREAM$P4` FLOAT32, SETOSA FLOAT32, VERSICOLOR FLOAT32, VIRGINICA FLOAT32) TYPE File;

SELECT INFER_MODEL(iris, p1, p2, p3, p4), * FROM stream
INTO result;
----
6.1,3.5,1.4,0.2,0.946717,0.051443,0.00184
4.9,3.0,1.4,0.2,0.888224,0.103913,0.007863
4.7,3.2,1.3,0.2,0.898816,0.094172,0.007012
