# name: inference/InferModelVarsizedOutput.test
# description: ML model inference with MODEL_INFERENCE TVF producing VARSIZED output, verified via TO_BASE64
# groups: [Inference]

CREATE LOGICAL SOURCE stream(p1 FLOAT32 NOT NULL, p2 FLOAT32 NOT NULL, p3 FLOAT32 NOT NULL, p4 FLOAT32 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
6.1,3.5,1.4,0.2

CREATE MODEL iris_blob ('model/iris.onnx')
INPUT (p1 FLOAT32, p2 FLOAT32, p3 FLOAT32, p4 FLOAT32)
OUTPUT (result VARSIZED);

CREATE SINK result(`STREAM$P1` FLOAT32 NOT NULL, `STREAM$P2` FLOAT32 NOT NULL, `STREAM$P3` FLOAT32 NOT NULL, `STREAM$P4` FLOAT32 NOT NULL, ENCODED VARSIZED NOT NULL) TYPE File;

SELECT `STREAM$P1`, `STREAM$P2`, `STREAM$P3`, `STREAM$P4`, TO_BASE64(result) AS ENCODED
FROM MODEL_INFERENCE(iris_blob, stream)
INTO result;
----
6.1,3.5,1.4,0.2,DlxyP7y1Uj1vLfE6
