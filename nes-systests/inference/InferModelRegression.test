# name: inference/InferModelRegression.test
# description: ML model inference with INFER_MODEL operator using a regression model (5 inputs, 1 output)
# groups: [Inference]

CREATE LOGICAL SOURCE stream(f1 FLOAT32, f2 FLOAT32, f3 FLOAT32, f4 FLOAT32, f5 FLOAT32);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
2.0,45.0,1.0,0.0,10.0
3.0,20.0,2.0,1.0,5.0
1.0,10.0,0.0,1.0,3.0

CREATE MODEL inspections ('model/inspections.onnx')
INPUT (f1 FLOAT32, f2 FLOAT32, f3 FLOAT32, f4 FLOAT32, f5 FLOAT32)
OUTPUT (v1 FLOAT32);

CREATE SINK result(`STREAM$F1` FLOAT32, `STREAM$F2` FLOAT32, `STREAM$F3` FLOAT32, `STREAM$F4` FLOAT32, `STREAM$F5` FLOAT32, V1 FLOAT32) TYPE File;

SELECT INFER_MODEL(inspections, f1, f2, f3, f4, f5), * FROM stream
INTO result;
----
2.0,45.0,1.0,0.0,10.0,2.55389
3.0,20.0,2.0,1.0,5.0,1.387451
1.0,10.0,0.0,1.0,3.0,1.010856
