# name: inference/InferModelTwoModels.test
# description: Two MODEL_INFERENCE operators nested in a single query
# groups: [Inference]

CREATE LOGICAL SOURCE stream(f1 FLOAT32, f2 FLOAT32, f3 FLOAT32, f4 FLOAT32, f5 FLOAT32);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
2.0,45.0,1.0,0.0,10.0

CREATE MODEL inspections ('model/inspections.onnx')
INPUT (f1 FLOAT32, f2 FLOAT32, f3 FLOAT32, f4 FLOAT32, f5 FLOAT32)
OUTPUT (v1 FLOAT32);

CREATE MODEL iris ('model/model.onnx')
INPUT (f1 FLOAT32, f2 FLOAT32, f3 FLOAT32, f4 FLOAT32)
OUTPUT (setosa FLOAT32, versicolor FLOAT32, virginica FLOAT32);

CREATE SINK result(`STREAM$F1` FLOAT32, `STREAM$F2` FLOAT32, `STREAM$F3` FLOAT32, `STREAM$F4` FLOAT32, `STREAM$F5` FLOAT32, V1 FLOAT32, SETOSA FLOAT32, VERSICOLOR FLOAT32, VIRGINICA FLOAT32) TYPE File;

SELECT * FROM MODEL_INFERENCE(iris, MODEL_INFERENCE(inspections, stream))
INTO result;
----
2.0,45.0,1.0,0.0,10.0,2.55389,0.758012,0.241783,0.000205
