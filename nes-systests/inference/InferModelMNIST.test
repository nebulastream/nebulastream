# name: inference/InferModelMNIST.test
# description: ML model inference with MODEL_INFERENCE TVF using FROM_BASE64 to decode VARSIZED image input
# groups: [Inference]

CREATE LOGICAL SOURCE stream(pixels VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE


CREATE MODEL mnist ('model/mnist.onnx')
INPUT (pixels VARSIZED)
OUTPUT (c0 FLOAT32, c1 FLOAT32, c2 FLOAT32, c3 FLOAT32, c4 FLOAT32, c5 FLOAT32, c6 FLOAT32, c7 FLOAT32, c8 FLOAT32, c9 FLOAT32);

CREATE SINK result(C0 FLOAT32 NOT NULL, C1 FLOAT32 NOT NULL, C2 FLOAT32 NOT NULL, C3 FLOAT32 NOT NULL, C4 FLOAT32 NOT NULL, C5 FLOAT32 NOT NULL, C6 FLOAT32 NOT NULL, C7 FLOAT32 NOT NULL, C8 FLOAT32 NOT NULL, C9 FLOAT32 NOT NULL) TYPE File;

SELECT c0, c1, c2, c3, c4, c5, c6, c7, c8, c9
FROM MODEL_INFERENCE(mnist, (SELECT FROM_BASE64(pixels) AS pixels FROM stream))
INTO result;
----
0.000000,0.000000,0.000007,0.000003,0.000000,0.000000,0.000000,0.999989,0.000000,0.000000
