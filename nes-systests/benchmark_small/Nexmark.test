# name: milestone/Nexmark.test
# description: Nexmark benchmark taken from https://github.com/nexmark/nexmark/tree/master/nexmark-flink/src/main/resources/queries
# groups: [milestone, benchmark, benchmark_small, Aggregation, Join]

# Source definitions
CREATE LOGICAL SOURCE bid(timestamp UINT64, auctionId INT32, bidder INT32, datetime INT64, price FLOAT64);
CREATE PHYSICAL SOURCE FOR bid TYPE File;
ATTACH FILE small/nexmark/bid_modified_100K.csv
CREATE LOGICAL SOURCE auction(timestamp UINT64, id INT32, initialbid INT32, reserve INT32, expires INT64, seller INT32, category INT32);
CREATE PHYSICAL SOURCE FOR auction TYPE File;
ATTACH FILE small/nexmark/auction_modified_100K.csv

CREATE SINK q1CheckSum(price FLOAT64)  TYPE Checksum;
CREATE SINK q2CheckSum(timestamp UINT64, auctionId INT32, bidder INT32, datetime INT64, price FLOAT64)  TYPE Checksum;
CREATE SINK q5Checksum(start UINT64 NOT NULL, end UINT64 NOT NULL, auctionId INT32, num UINT64 NOT NULL, max_tmp UINT64 NOT NULL)  TYPE Checksum;
CREATE SINK q8VariantChecksum(start UINT64 NOT NULL, end UINT64 NOT NULL, bid_timestamp UINT64, auctionId INT32, bidder INT32, datetime INT64, price FLOAT64, auction_timestamp UINT64, id INT32, initialbid INT32, reserve INT32, expires INT64, seller INT32, category INT32)  TYPE Checksum;

# Query 0
SELECT * FROM bid INTO q2CheckSum;
----
4445 4706576

# Query 1
SELECT price * 89 / 100 AS price FROM bid INTO q1CheckSum;
----
4445 1336553

# Query 2
SELECT * FROM bid WHERE auctionId % 123 = 0 INTO q2CheckSum;
----
47 47464

# Query 5
SELECT start, end, auctionId, num, max_tmp
FROM (SELECT auctionId, num, start as auction_start, end as auction_end
      FROM (SELECT auctionId, COUNT(auctionId) AS num, start, end
            FROM bid
            GROUP BY auctionId
            WINDOW SLIDING(timestamp, SIZE 10 SEC, ADVANCE BY 2 SEC)))
INNER JOIN (SELECT max_tmp, start as bid_start, end as bid_end
              FROM (SELECT MAX(num_ids) AS max_tmp, start, end
                    FROM
                          (SELECT auctionId, COUNT(auctionId) AS num_ids, start
                           FROM bid
                           GROUP BY auctionId
                           WINDOW SLIDING(timestamp, SIZE 10 SEC, ADVANCE BY 2 SEC))
                    WINDOW TUMBLING(start, SIZE 2 SEC)))
ON num == max_tmp
WINDOW TUMBLING(auction_start, bid_start, SIZE 2 SEC)
INTO q5Checksum;
----
69 69347


# Query 8 Variant (We are not using the actual Q8 but a variant, as we have swapped the Person stream with the Bid stream)
SELECT start, end, bid_timestamp, auctionId, bidder, datetime, price, auction_timestamp, id, initialbid, reserve, expires, seller, category
    FROM (SELECT timestamp as bid_timestamp, auctionId, bidder, datetime, price FROM bid)
INNER JOIN
    (SELECT timestamp as auction_timestamp, id, initialbid, reserve, expires, seller, category FROM auction)
ON auctionId = id WINDOW TUMBLING (bid_timestamp, auction_timestamp, size 10 sec) INTO q8VariantChecksum;
----
2160 6293051
