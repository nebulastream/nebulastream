# name: milestone/Nexmark_with_varsized.test
# description: Nexmark benchmark taken from https://github.com/nexmark/nexmark/tree/master/nexmark-flink/src/main/resources/queries
# We have used https://github.com/risingwavelabs/nexmark-rs to generate the source csv files
# groups: [milestone, benchmark, benchmark_small, Aggregation, Join]

# Source definition. We have removed some columns that are not needed in our queries
CREATE LOGICAL SOURCE bid5K(timestamp UINT64 NOT NULL, auctionId INT32, bidder INT32, price FLOAT64);
CREATE PHYSICAL SOURCE FOR bid5K TYPE File;
ATTACH FILE small/nexmark/bid_5K.csv

CREATE LOGICAL SOURCE bid100K(timestamp UINT64 NOT NULL, auctionId INT32, bidder INT32, price FLOAT64);
CREATE PHYSICAL SOURCE FOR bid100K TYPE File;
ATTACH FILE small/nexmark/bid_100K.csv

CREATE LOGICAL SOURCE auction(timestamp UINT64 NOT NULL, id INT32, initialbid INT32, reserve INT32, expires UINT64, seller INT32, category INT32);
CREATE PHYSICAL SOURCE FOR auction TYPE File;
ATTACH FILE small/nexmark/auction_100K.csv

CREATE LOGICAL SOURCE person(id INT32, name VARSIZED, email_address VARSIZED, credit_card VARSIZED, city VARSIZED, state VARSIZED, timestamp UINT64 NOT NULL, extra VARSIZED);
CREATE PHYSICAL SOURCE FOR person TYPE File;
ATTACH FILE small/nexmark/person_100K.csv

CREATE SINK bidCheckSum(timestamp UINT64 NOT NULL, auctionId INT32, bidder INT32, price FLOAT64)  TYPE Checksum;
CREATE SINK q1CheckSum(timestamp UINT64 NOT NULL, auctionId INT32, bidder INT32, price FLOAT64)  TYPE Checksum;
CREATE SINK q2CheckSum(auctionId INT32, price FLOAT64)  TYPE Checksum;
CREATE SINK q5Checksum(start UINT64 NOT NULL, end UINT64 NOT NULL, auctionId INT32, num UINT64 NOT NULL, max_tmp UINT64 NOT NULL)  TYPE Checksum;
CREATE SINK q8CheckSum(start UINT64 NOT NULL, end UINT64 NOT NULL, id INT32, name VARSIZED)  TYPE Checksum;
CREATE SINK q8VariantCheckSum(start UINT64 NOT NULL, end UINT64 NOT NULL, bid_timestamp UINT64 NOT NULL, auctionId INT32, bidder INT32, price FLOAT64, auction_timestamp UINT64 NOT NULL, id INT32, initialbid INT32, reserve INT32, expires UINT64, seller INT32, category INT32)  TYPE Checksum;


# Query 0
SELECT * FROM bid100K INTO bidCheckSum;
----
3357 5379403

# Query 1
SELECT timestamp, auctionId, bidder, price * FLOAT64(908) / FLOAT64(1000) AS price FROM bid100K INTO q1CheckSum;
----
3357 5698622

# Query 2
SELECT auctionId, price FROM bid100K WHERE auctionId % 123 = 0 INTO q2CheckSum;
----
12 7772

# Query 5
SELECT start, end, auctionId, num, max_tmp
FROM (SELECT auctionId, num, start as auction_start, end as auction_end
      FROM (SELECT auctionId, COUNT(auctionId) AS num, start, end
            FROM bid100K
            GROUP BY auctionId
            WINDOW SLIDING(timestamp, SIZE 10 SEC, ADVANCE BY 2 SEC)))
INNER JOIN (SELECT max_tmp, start as bid_start, end as bid_end
              FROM (SELECT MAX(num_ids) AS max_tmp, start, end
                    FROM
                          (SELECT auctionId, COUNT(auctionId) AS num_ids, start
                           FROM bid100K
                           GROUP BY auctionId
                           WINDOW SLIDING(timestamp, SIZE 10 SEC, ADVANCE BY 2 SEC))
                    WINDOW TUMBLING(start, SIZE 2 SEC)))
ON num == max_tmp
WINDOW TUMBLING(auction_start, bid_start, SIZE 2 SEC)
INTO q5Checksum;
----
6 12261


# Query 8
# Until PR #755 is not merged, we need to do another subquery to project the required fields
SELECT start, end, id, name
FROM (
        SELECT *
            FROM (SELECT timestamp as person_timestamp, id, name, email_address, credit_card, city, state, extra FROM person)
        INNER JOIN
            (SELECT timestamp as auction_timestamp, id as auction_id, initialbid, reserve, expires, seller, category FROM auction)
        ON id = seller WINDOW TUMBLING (person_timestamp, auction_timestamp, size 10 sec)
    )
INTO q8CheckSum;
----
1336 3919836



# Query 8 Variant (We are not using the actual Q8 but a variant, as we have swapped the Person stream with the Bid stream)
# We use the smaller bid5K file/source, as otherwise this test takes more than >45s for NLJ and a single thread.
SELECT start, end, bid_timestamp, auctionId, bidder, price, auction_timestamp, id, initialbid, reserve, expires, seller, category
    FROM (SELECT timestamp as bid_timestamp, auctionId, bidder, price FROM bid5K)
INNER JOIN
    (SELECT timestamp as auction_timestamp, id, initialbid, reserve, expires, seller, category FROM auction)
ON auctionId = id WINDOW TUMBLING (bid_timestamp, auction_timestamp, size 10 sec) INTO q8VariantCheckSum;
----
165 956509
