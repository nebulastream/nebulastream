# name: process-intelligence.test
# description: Example queries
# groups: [Inference]


CREATE MODEL auto_vi ('../../auto-model/pipe_staple_pca.onnx')
INPUT (pixels VARSIZED)
OUTPUT (anomaly_score FLOAT32);

CREATE LOGICAL SOURCE PIPE_STABLE(id VARSIZED NOT NULL, timestamp UINT64 NOT NULL, data VARSIZED NOT NULL);
CREATE PHYSICAL SOURCE FOR PIPE_STABLE TYPE File;
ATTACH INLINE
g0005,1000,
g0006,1100,
g0007,1200,
g0008,1300,
b0005,1400,
b0006,1500,
b0007,1600,
b0008,1700,


# PIPES - ALL
SELECT id, timestamp, anomaly_score
FROM MODEL_INFERENCE(auto_vi, (SELECT id, timestamp, AUTOVI_PREPROCESS_IMAGE(FROM_BASE64(data)) AS pixels FROM PIPE_STABLE))
INTO File();
----
g0005,1000,0.020308
g0006,1100,0.005077
g0007,1200,0.004848
g0008,1300,0.00752
b0005,1400,0.015895
b0006,1500,0.012444
b0007,1600,0.009366
b0008,1700,0.009015


# PIPES - ANOMALIES
SELECT id, timestamp, anomaly_score
FROM MODEL_INFERENCE(auto_vi, (SELECT id, timestamp, AUTOVI_PREPROCESS_IMAGE(FROM_BASE64(data)) AS pixels FROM PIPE_STABLE))
WHERE anomaly_score > FLOAT64(0.009)
INTO File();
----
g0005,1000,0.020308
b0005,1400,0.015895
b0006,1500,0.012444
b0007,1600,0.009366
b0008,1700,0.009015


# PIPES - ANOMALIES AS EVENTS
SELECT
  VARSIZED("manufacturing-anomaly") AS event,
  VARSIZED("pipe_staple") AS component_type,
  id AS component_id,
  anomaly_score AS confidence,
  timestamp AS timestamp
FROM MODEL_INFERENCE(auto_vi, (SELECT id, timestamp, AUTOVI_PREPROCESS_IMAGE(FROM_BASE64(data)) AS pixels FROM PIPE_STABLE))
WHERE anomaly_score > FLOAT64(0.009)
INTO File('JSON' as `SINK`.OUTPUT_FORMAT);
----
{"EVENT":"manufacturing-anomaly" "COMPONENT_TYPE":"pipe_staple" "COMPONENT_ID":"g0005" "CONFIDENCE":0.020308 "TIMESTAMP":1000}
{"EVENT":"manufacturing-anomaly" "COMPONENT_TYPE":"pipe_staple" "COMPONENT_ID":"b0005" "CONFIDENCE":0.015895 "TIMESTAMP":1400}
{"EVENT":"manufacturing-anomaly" "COMPONENT_TYPE":"pipe_staple" "COMPONENT_ID":"b0006" "CONFIDENCE":0.012444 "TIMESTAMP":1500}
{"EVENT":"manufacturing-anomaly" "COMPONENT_TYPE":"pipe_staple" "COMPONENT_ID":"b0007" "CONFIDENCE":0.009366 "TIMESTAMP":1600}
{"EVENT":"manufacturing-anomaly" "COMPONENT_TYPE":"pipe_staple" "COMPONENT_ID":"b0008" "CONFIDENCE":0.009015 "TIMESTAMP":1700}

