#pragma once

#ifndef INCLUDED_FROM_SOURCE_VALIDATION_REGISTRY
#    error "This file should not be included directly! Include instead include SourceRegistry.hpp"
#endif

#include <string>
#include <vector>
#include <Util/Registry.hpp>

namespace NES
{
SourceValidationRegistryReturnType validateTokioSourceFromRegistry(std::string name, SourceValidationRegistryArguments args);
std::vector<std::string> getRegisteredTokioSourceNames();

@REGISTER_FUNCTION_DECLARATIONS@
}

namespace NES
{
template <>
inline void
Registrar<SourceValidationRegistry, std::string, SourceValidationRegistryReturnType, SourceValidationRegistryArguments>::registerAll(Registry<Registrar>& registry)
{
    for (const auto& n : getRegisteredTokioSourceNames())
    {
        registry.addEntry(n, [n](SourceValidationRegistryArguments args) {
            return validateTokioSourceFromRegistry(n, std::move(args));
        });
    }

    using namespace NES;
    @REGISTER_ALL_FUNCTION_CALLS@
}
}
